{$R *.RES}
{$R WindowsXP.RES}

var
  i : integer;
  MostrarLogo : boolean;
  MostrarFondo : boolean;
  SincPureworks : boolean;
  SincPrestashop : boolean;
  SincWoocommerce : boolean;
  SincSpeedLock : Boolean;
  SincSellforege : boolean;
  Pondera : boolean;
  ActualizaPMP : boolean;
  InformeCaja : boolean;
  DiarioFacturacion : boolean;
  TrazabilidadCompras : boolean;
begin
  {$IFDEF Debug}
  MemChk;
  {$ENDIF}

  InicializaIdioma; //IDIOMA_CODE

  CrearRegistroEntorno;

  Application.Initialize;

  Leeini;

  // Tratamiento de parámetros de la aplicacion
  // - Merge.exe /nologo : no muestra el logo al cargar la aplicación
  // - Merge.exe /nobackground : oculta el fondo al iniciar la aplicación
  // - Merge.exe /sinc-pureworks : Ejecuta sincronización Pureworks y cierra la aplicación.
  // - Merge.exe /sinc-prestashop : Ejecuta sincronización Prestashop y cierra la aplicación.
  // - Merge.exe /sinc-woocommerce : Ejecuta sincronización Woocommerce y cierra la aplicación.
  // - Merge.exe /sinc-speedlock : Ejecuta sincronización de stock hacia SpeedLock.
  // - Merge.exe /pondera : Almacenes -> Procesos -> "Recalcula Precio de Coste de Lineas de Venta"
  // - Merge.exe /actualiza-pmp : Almacenes -> Procesos -> "Recalcula Precio de Coste de Lineas de Venta"
  MostrarLogo := True;
  MostrarFondo := True;
  SincPureworks := False;
  SincPrestashop := False;
  SincWoocommerce := False;
  SincSpeedLock := False;
  SincSellforege := False;
  Pondera := False;
  ActualizaPMP := False;
  InformeCaja := False;
  DiarioFacturacion := False;
  TrazabilidadCompras := False;

  for i := 1 to ParamCount do
  begin
     if LowerCase(ParamStr(i)) = '/nologo' then
        MostrarLogo := False
     else
     if LowerCase(ParamStr(i)) = '/nobackground' then
        MostrarFondo := False
     else
     if LowerCase(ParamStr(i)) = '/sinc-sellforge' then
     begin
        MostrarLogo := False;
        MostrarFondo := False;
        SincSellforege := True;
     end
     else
     if LowerCase(ParamStr(i)) = '/sinc-pureworks' then
     begin
        MostrarLogo := False;
        MostrarFondo := False;
        SincPureworks := True;
     end
     else
     if LowerCase(ParamStr(i)) = '/sinc-prestashop' then
     begin
        MostrarLogo := False;
        MostrarFondo := False;
        SincPrestashop := True;
     end
     else
     if LowerCase(ParamStr(i)) = '/sinc-woocommerce' then
     begin
        MostrarLogo := False;
        MostrarFondo := False;
        SincWoocommerce := True;
     end
     else
     if LowerCase(ParamStr(i)) = '/sinc-speedlock' then
     begin
        // Solo actualiza stock
        MostrarLogo := False;
        MostrarFondo := False;
        SincSpeedLock := True;
     end
     else
     if LowerCase(ParamStr(i)) = '/pondera' then
     begin
        MostrarLogo := False;
        MostrarFondo := False;
        Pondera := True;
     end
     else
     if LowerCase(ParamStr(i)) = '/actualiza-pmp' then
     begin
        MostrarLogo := False;
        MostrarFondo := False;
        ActualizaPMP := True;
     end
     else
     if LowerCase(ParamStr(i)) = '/informe-caja' then
     begin
        MostrarLogo := False;
        MostrarFondo := False;
        InformeCaja := True;
     end
     else
     if LowerCase(ParamStr(i)) = '/diario-facturacion' then
     begin
        MostrarLogo := False;
        MostrarFondo := False;
        DiarioFacturacion := True;
     end
     else
     if LowerCase(ParamStr(i)) = '/trazabilidad-compras' then
     begin
        MostrarLogo := False;
        MostrarFondo := False;
        TrazabilidadCompras := True;
     end;
  end;

  if (MostrarLogo) then
  begin
     FLogo := TFLogo.Create(Application);
     FLogo.Show;
     FLogo.Update;
     {$IFDEF Debug}
     Sleep(2000);
     {$ENDIF}
  end;

{
  if not LicenciaActiva then
     Application.Terminate;
}

  Application.Title := 'Delfos';
  Application.CreateForm(TDMMain, DMMain);
  Application.CreateForm(TFMain, FMain);
  FMain.SincronizacionPureWorks := SincPureworks;
  FMain.SincronizacionPrestashop := SincPrestashop;
  FMain.SincronizacionWoocommerce := SincWoocommerce;
  FMain.SincronizacionSpeedLock := SincSpeedLock;
  FMain.SincronizacionSellforege := SincSellforege;
  FMain.PonderaArticulos := Pondera;
  FMain.ActualizaPMPArticulos := ActualizaPMP;
  FMain.ReporteInformeCaja := InformeCaja;
  FMain.ReporteDiarioFacturacion := DiarioFacturacion;
  FMain.ReporteTrazabilidadCompras := TrazabilidadCompras;

  if (Assigned(FLogo)) then
  begin
     FLogo.Hide;
     FreeAndNil(FLogo);
  end;

  if (not MostrarFondo) then
     FMain.OcultarFondo;

  Application.Run;

  DestruirRegistroEntorno;
end.
