procedure TFMOfertas.MuestraResumenFiltrado(Modo: byte);
var
  TempSQL, SQLFiltro : TStringList;
begin
  TempSql := TStringList.Create;
  SqlFiltro := TStringList.Create;
  try
     SqlFiltro.AddStrings(DMOfertas.QMCabecera.SelectSQL);
     AbreData(TDMLstOfertasCli, DMLstOfertasCli);
     with DMLstOfertasCli do
     begin
        TempSql.AddStrings(QMCabecera.SelectSQL);
        QMCabecera.Close;
        QMCabecera.SelectSQL.Assign(SqlFiltro);
        // Utilizo la vista para listado
        QMCabecera.SelectSQL.Text := StringReplace(QMCabecera.SelectSQL.Text, 'VER_CABECERAS_OFERTA_C', 'VER_CABECERAS_OFERTA_C_LST', [rfReplaceAll]);
        if (DMMain.EstadoKri(214) = 1) then
        begin
           // Si SQL está ordenado, quito el orden
           if (Pos('ORDER', QMCabecera.SelectSQL.Text) > 0) then
              QMCabecera.SelectSQL.Text := Copy(QMCabecera.SelectSQL.Text, 1, Pos('ORDER', QMCabecera.SelectSQL.Text) - 1);

           // Asingo nuevo orden
           QMCabecera.SelectSQL.Text := QMCabecera.SelectSQL.Text + ' ORDER BY AGENTE, CLIENTE, FECHA, RIG';
        end;
        QMCabecera.Params.ByName['SERIE'].AsString := EFSerie.Text;
        MostrarListadoFiltrado(Modo, FiltroListadoFiltrado, EFSerie.Text);
        QMCabecera.Close;
        QMCabecera.SelectSQL.Assign(TempSQL);
     end;
     CierraData(DMLstOfertasCli);
  finally
     SqlFiltro.Free;
     TempSql.Free;
  end;
end;

