procedure TFMOfertas.DBGFDetalleDblClick(Sender: TObject);
var
  CodigoCliente : string;
begin
  if DMOfertas.HayDetalle then
  begin
     if (UpperCase(ColActual.FieldName) = 'ARTICULO') then
        AArticulo.Execute;
  end;

  if (UpperCase(ColActual.FieldName) = 'CODIGO_CLIENTE') then
  begin
     CodigoCliente := DMOfertas.QMDetalleCODIGO_CLIENTE.AsString;
     if (PideDato('STR', CodigoCliente, _('Nuevo codigo de cliente'))) then
     begin
        with THYFIBQuery.Create(nil) do
        begin
           try
              Close;
              DataBase := DMMain.DataBase;
              SQL.Add(' UPDATE OR INSERT INTO ART_ARTICULOS_CODCLI ( ');
              SQL.Add(' EMPRESA, ARTICULO, CLIENTE, CODIGO_CLIENTE) ');
              SQL.Add(' VALUES ( ');
              SQL.Add(' :EMPRESA, :ARTICULO, :CLIENTE, :CODIGO_CLIENTE) ');
              SQL.Add(' MATCHING (EMPRESA, ARTICULO, CLIENTE) ');
              Params.ByName['EMPRESA'].AsInteger := DMOfertas.QMDetalleEMPRESA.AsInteger;
              Params.ByName['ARTICULO'].AsString := DMOfertas.QMDetalleARTICULO.AsString;
              Params.ByName['CLIENTE'].AsInteger := DMOfertas.QMCabeceraCLIENTE.AsInteger;
              Params.ByName['CODIGO_CLIENTE'].AsString := CodigoCliente;
              ExecQuery;
              FreeHandle;
           finally
              Free;
           end;
        end;

        DMOfertas.QMDetalle.Refresh;
     end;
  end;

  // Si la oferta está cerrada, preguntamos el valor de Precio de Coste y Coste Adicional.
  if (DMOfertas.QMCabeceraESTADO.AsInteger = 5) then
