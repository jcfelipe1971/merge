procedure TFMOfertas.AAReparacionExecute(Sender: TObject);
var
  Serie : string;
  Fecha : TDateTime;
  IdReparacion : integer;
begin
  {$IFNDEF TPV}
  if (DMOfertas.QMCabeceraESTADO.AsInteger = 5) then
     raise Exception.Create(_('No puede modificar un documento cerrado.'))
  else
  begin
     Serie := DMOfertas.QMCabeceraSERIE.AsString;
     Fecha := Now;
     if PideDato('SER', Serie, Fecha) then
     begin
        // Creo una reparacion con datos de la oferta
        IdReparacion := DMOfertas.GeneraReparacion(Serie, Fecha);
        // Cierro oferta
        DMOfertas.AbrirCerrar(5);
        // Abro Ficha de Reparacion creada
        FMain.EjecutaAccion(FMain.AReparaciones, 'IDCABREPARAR = ' + IntToStr(IdReparacion));
     end;
  end;
  {$ENDIF}
end;

procedure TFMOfertas.AReparacionExecute(Sender: TObject);
var
  IdReparacion : integer;
begin
  {$IFNDEF TPV}
