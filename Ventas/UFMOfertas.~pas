procedure TFMOfertas.EstableceVisibilidadStockAlmacen;

  procedure EstableceVisibilidad(Campo, Parametro, Descripcion: string);
  var
     i : smallint;
     AlmacenStock : string;
  begin
     AlmacenStock := LeeParametro(Parametro, EFSerie.Text);
     if (AlmacenStock = '') then
        AlmacenStock := 'NOCALC';
     if (AlmacenStock <> 'NOCALC') then
        AlmacenStock := Copy(AlmacenStock, 1, 3);

     if ((Parametro <> 'OFCSTKV009') and (Parametro <> 'OFCSTKR009') and (Parametro <> 'OFCSTKM001') and (Parametro <> 'OFCSTKB001') and (Parametro <> 'OFCSTKA000')) then
        Descripcion := Descripcion + ' ' + AlmacenStock;

     i := EncuentraField(DBGFDetalle, Campo);
     if (i >= 0) then
     begin
        with DBGFDetalle.Columns[i] do
        begin
           if ((Parametro = 'OFCSTKV009') or (Parametro = 'OFCSTKR009') or (Parametro = 'OFCSTKM001') or (Parametro = 'OFCSTKB001') or (Parametro = 'OFCSTKA000')) then
              Visible := (AlmacenStock = 'S')
           else
              Visible := (AlmacenStock <> 'NOCALC');
           Title.Caption := Descripcion;
        end;
     end
     else
     begin
        with DBGFDetalle.Columns.Add do
        begin
           FieldName := Campo;
           Title.Caption := Descripcion;
           if ((Parametro = 'OFCSTKV009') or (Parametro = 'OFCSTKR009') or (Parametro = 'OFCSTKM001') or (Parametro = 'OFCSTKB001') or (Parametro = 'OFCSTKA000')) then
              Visible := (AlmacenStock = 'S')
           else
              Visible := (AlmacenStock <> 'NOCALC');
        end;
     end;
  end;

begin
  EstableceVisibilidad('STOCK_ALM', 'OFCSTKA001', _('Stock'));
  EstableceVisibilidad('STOCK_ALM2', 'OFCSTKA002', _('Stock'));
  EstableceVisibilidad('STOCK_ALM3', 'OFCSTKA003', _('Stock'));

  EstableceVisibilidad('STOCKV_ALM', 'OFCSTKV001', _('S. Virt.'));
  EstableceVisibilidad('STOCKV_ALM2', 'OFCSTKV002', _('S. Virt.'));
  EstableceVisibilidad('STOCKV_ALM3', 'OFCSTKV003', _('S. Virt.'));

  EstableceVisibilidad('STOCKR_ALM', 'OFCSTKR001', _('S. Real'));
  EstableceVisibilidad('STOCKR_ALM2', 'OFCSTKR002', _('S. Real'));
  EstableceVisibilidad('STOCKR_ALM3', 'OFCSTKR003', _('S. Real'));

  EstableceVisibilidad('STOCKM_ALM', 'OFCSTKM002', _('S. Mont.'));
  EstableceVisibilidad('STOCKM_ALM2', 'OFCSTKM003', _('S. Mont.'));
  EstableceVisibilidad('STOCKM_ALM3', 'OFCSTKM004', _('S. Mont.'));

  EstableceVisibilidad('STOCK', 'OFCSTKA000', _('Sock'));
  EstableceVisibilidad('STOCK_VIRTUAL', 'OFCSTKV009', _('S. Virt.'));
  EstableceVisibilidad('STOCK_REAL', 'OFCSTKR009', _('S. Real.'));
