procedure TFMOfertas.ABuscaReferenciasExecute(Sender: TObject);
begin
  EFReferencia.Text := '';
  EFReferencia.Visible := True;
  EFReferencia.SetFocus;
  EFReferencia.Visible := False;
  NavMain.SetFocus;
  with DMOfertas.QMCabecera do
  begin
     DisableControls;
     First;
     while ((DMOfertas.QMCabeceraID_S.AsString <> EFReferencia.Text) and (not EOF)) do
        Next;
     if (DMOfertas.QMCabeceraID_S.AsString <> EFReferencia.Text) then
     begin
        with DMOfertas.QMCabecera do
        begin
           Close;
           SelectSQL.Text := 'SELECT * FROM VER_CABECERAS_OFERTA_C ' +
              'WHERE EMPRESA=?EMPRESA AND ' +
              '      CANAL=?CANAL AND ' +
              '      SERIE=?SERIE AND ' +
              '      TIPO=''OFC'' ' +
              '      AND EJERCICIO <= ?EJERCICIO ' +
              ' ORDER BY EJERCICIO,RIG';
           DMMain.FiltraTabla(DMOfertas.QMCabecera, '11100', False);
           DMOfertas.CambiaSerie(EFSerie.Text);
           Open;
        end;
        Last;
        while ((DMOfertas.QMCabeceraID_S.AsString <> EFReferencia.Text) and (not BOF)) do
           Prior;
     end;
     EnableControls;
     DMOfertas.QMCabecera.Refresh;
     if (DMOfertas.QMCabeceraID_S.AsString <> EFReferencia.Text) then
        ShowMessage(_('No se encontró la referencia.'));
  end;
end;

