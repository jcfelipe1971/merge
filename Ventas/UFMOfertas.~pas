procedure TFMOfertas.MuestraFiltrado(Modo: byte);
var
  TempSQL, SQLFiltro : TStringList;
  PlanTmp : string;
begin
  TempSql := TStringList.Create;
  SqlFiltro := TStringList.Create;
  try
     SqlFiltro.AddStrings(DMOfertas.QMCabecera.SelectSQL);
     AbreData(TDMLstOfertas, DMLstOfertas);
     try
        with DMLstOfertas do
        begin
           TempSql.AddStrings(QMCabecera.SelectSQL);
           QMCabecera.Close;
           PlanTmp := QMCabecera.Plan.Text;
           QMCabecera.SelectSQL.Assign(SqlFiltro);
           // Utilizo la vista para listado
           QMCabecera.SelectSQL.Text := StringReplace(QMCabecera.SelectSQL.Text, 'VER_CABECERAS_OFERTA_C', 'VER_CABECERAS_OFERTA_C_LST', [rfReplaceAll]);
           QMCabecera.Plan.Text := '';
           QMCabecera.Params.ByName['SERIE'].AsString := EFSerie.Text;
           MostrarListadoFiltrado(Modo, FiltroListadoFiltrado, EFSerie.Text);
           QMCabecera.Close;
           QMCabecera.SelectSQL.Assign(TempSQL);
           QMCabecera.Plan.Text := PlanTmp;
        end;
     finally
        CierraData(DMLstOfertas);
     end
  finally
     SqlFiltro.Free;
     TempSql.Free;
  end;
  RefrescaAvisos;
end;

procedure TFMOfertas.EFSerieChange(Sender: TObject);
var
  serie_aux : string;
begin
  if (EFSerie.Text <> '') then
  begin
     serie_aux := dame_serie_activa(EFSerie.Text);
     // Bloqueo series
     if (serie_aux <> EFSerie.Text) then
        EFSerie.Text := serie_aux;

     if (EFSerie.Text = REntorno.SerieRestringida) or ((DMMain.EstadoKri(184) = 1) and (EFSerie.Text = 'MO')) then
     begin
        EFSerie.Text := REntorno.SerieRestringida;
        EFSerie.CondicionBusqueda := 'SERIE=''' + REntorno.SerieRestringida + '''';
        if (DMMain.EstadoKri(184) = 1) then
           EFSerie.CondicionBusqueda := '(SERIE=''' + REntorno.SerieRestringida + ''' OR SERIE=''MO'')';
     end
     else
     if (REntorno.SerieRestringida > ' ') then
        EFSerie.Text := REntorno.SerieRestringida;

     DMOfertas.CambiaSerie(EFSerie.Text);
  end;

