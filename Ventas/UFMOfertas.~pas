procedure TFMOfertas.HabilitaBotonesDetalle;
var
  Habil, HabilEd, Habilitado : boolean;
  GestOfeEsc : integer;
  Q : THYFIBQuery;
begin
  // Todos los botones INACTIVOS (No hay Detalle)
  Habil := ((DMOfertas.HayDetalle) or (DMOfertas.QMDetalle.State = dsInsert));
  HabilEd := Habil;

  // Ciertos botones INACTIVOS (Modo inserción/edición)
  if Habil then
     HabilEd := not (DMOfertas.QMDetalle.State in [dsInsert, dsEdit]);

  TButtEditaLineas.Enabled := HabilEd;
  TButtHerencia.Enabled := HabilEd;
  TButtStock.Enabled := Habil;
  TButtUnidadesExt.Enabled := HabilEd;
  TButtPrecios.Enabled := Habil;
  TButtInfoHistorico.Enabled := Habil;
  AOrdenaLineas.Enabled := Habil;
  TBArtCli.Enabled := Habil;
  ACambiaTitulo.Enabled := HabilEd;
  TButtBuscarArticulo.Enabled := True;   // Siempre habilitado
  TButtImportarDetalle.Enabled := True;  // Siempre Activo
  ADetallesDeLinea.Enabled := HabilEd;

  if (LeeParametro('MODREST006') = 'S') then
  begin
     Q := THYFIBQuery.Create(nil);
     try
        with Q do
        begin
           Close;
           DataBase := DMMain.DataBase;
           SQL.Text := 'SELECT GEST_OFE_ESC FROM PRO_CONSTANTES';
           ExecQuery;
           GestOfeEsc := Fields[0].AsInteger;
           Close;
           if (GestOfeEsc = 0) then
              SQL.Text := 'SELECT ID_OFERTA_ESC, ID_MEDIDA FROM GES_DETALLES_S_OFC WHERE ID_DETALLES_S = ?ID_DETALLES'
           else
              SQL.Text := 'SELECT ID_ESC, ID_MEDIDA FROM GES_DETALLES_S_OFC WHERE ID_DETALLES_S = ?ID_DETALLES';
           Params.ByName['ID_DETALLES'].AsInteger := DMOfertas.QMDetalleID_DETALLES_S.AsInteger;
           ExecQuery;

           if (Fields[0].AsInteger <> 0) then
           begin
              TBOfertasEsc.ImageIndex := 7; // verd // escandallo
              AProMedidas.Enabled := True;
              if (FieldByName['ID_MEDIDA'].AsInteger = 0) then // id_medida
                 AProMedidas.ImageIndex := 8 // groc
              else
                 AProMedidas.ImageIndex := 7; // verd
           end
           else
           begin
              TBOfertasEsc.ImageIndex := 6; // vermell
              AProMedidas.Enabled := False;
              AProMedidas.ImageIndex := 6; // vermell
           end;
           FreeHandle;
        end;
     finally
        FreeAndNil(Q);
     end;
  end;

  // Controlamos que se pueda modificar el precio de venta + descuentos + tipo IVA
  Habilitado := (DMOfertas.QMDetalleARTICULO.AsString = REntorno.ArtTextoLibre) or (DMOfertas.xArticulos.Active and (DMOfertas.xArticulos.FieldByName('TIPO_ARTICULO').AsString = 'DTO')) or param_OFCPREC001;
  HabilitaColumna(DBGFDetalle, 'PRECIO', Habilitado);
  HabilitaColumna(DBGFDetalle, 'DESCUENTO', Habilitado and (not param_VENREST002));
  HabilitaColumna(DBGFDetalle, 'DESCUENTO_2', Habilitado and (not param_VENREST002));
  HabilitaColumna(DBGFDetalle, 'DESCUENTO_3', Habilitado and (not param_VENREST002));
  // En el caso del Tipo de IVA también tenemos que ver el parámetro VENTIVA001
  HabilitaColumna(DBGFDetalle, 'TIPO_IVA', Habilitado and Param_VENTIVA001);
end;

