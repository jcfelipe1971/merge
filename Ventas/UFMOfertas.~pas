  if Param_ARTBUSQ004 and (TDBGridFind2000(Sender).ColumnaActual = 'ARTICULO') then
  begin
     if (Key = VK_F3) then
     begin
        if PideArticulo(DBGDetalleArticulo, True, False) then
        begin
           DMOfertas.QMDetalle.Edit;
           DMOfertas.QMDetalleARTICULO.AsString := DBGDetalleArticulo;
        end;
        Key := 0;
     end;
  end
  else
  begin
     with DMOfertas.QMDetalle do
     begin
        if ((Key = VK_F3) and (not (State in [dsEdit, dsInsert]))) then
        begin
           if RecordCount = 0 then
              Insert
           else
              Edit;
        end;
     end;
