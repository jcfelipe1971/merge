procedure TFMOfertas.AEnviarOfertasMailPDF2Execute(Sender: TObject);
var
  Asunto : string;
  CuerpoMail : TStrings;
begin
  DMMain.LogIni('FMOfertas.AEnviarOfertasMailPDF2Execute');
  try
     DMMain.Log('AbreData(TDMLstOfertas, DMLstOfertas)');
     AbreData(TDMLstOfertas, DMLstOfertas);
     try

        DMMain.Log('DMLstOfertas.MostrarListadoMail()');
        DMLstOfertas.MostrarListadoMail(DMOfertas.QMCabeceraID_S.AsInteger, EFSerie.Text, 2,
           DMOfertas.QMCabeceraEJERCICIO.AsInteger, (LeeParametro('OFCLSTM001') = 'S'));

        DMMain.Log('DamePartesEmail()');
        InicializaVariableEmail(DMOfertas.QMCabeceraTIPO.AsString);
        with VariableEmail do
        begin
           Ejercicio := DMOfertas.QMCabeceraEJERCICIO.AsInteger;
           Serie := DMOfertas.QMCabeceraSERIE.AsString;
           NumeroDocumento := DMOfertas.QMCabeceraRIG.AsInteger;
           Fecha := DMOfertas.QMCabeceraFECHA.AsDateTime;
           SuReferencia := DMOfertas.QMCabeceraSU_REFERENCIA.AsString;
           SuPedido := DMOfertas.QMCabeceraPEDIDO_CLIENTE.AsString;
           Folio := '';
           TituloDocTributario := '';
           NombreFichero := DMLstOfertas.nombreFich;
           Matricula := DMMain.DameMatriculaFichaTecnica(DMOfertas.QMCabeceraID_FICHA_TECNICA.AsInteger);
           if (DMOfertas.QMCabeceraCLIENTE.AsInteger > 0) then
           begin
              NombreComercial := DMOfertas.QMCabeceraNOMBRE_COMERCIAL.AsString;
              RazonSocial := DMOfertas.QMCabeceraTITULO.AsString;
           end
           else
           begin
              // El campo TITULO se rellena con el nombre asignado al Tercero Vario
              NombreComercial := DMOfertas.QMCabeceraTITULO.AsString;
              RazonSocial := DMOfertas.QMCabeceraTITULO.AsString;
           end;
           OrdenTrabajo := 0;
           UsuarioCreadorDocumento := DameTituloUsuario(DameUsuarioSegunEntrada(DMOfertas.QMCabeceraENTRADA.AsInteger));
        end;
        DamePartesEmail(Asunto, CuerpoMail);
        try
           DMMain.Log('DMListados.SendMailClientePDF2()');
           DMListados.SendMailClientePDF2(DMOfertas.QMCabeceraCLIENTE.AsInteger, CuerpoMail, DMLstOfertas.rutaFich,
              DMLstOfertas.nombreFich, Asunto, DMOfertas.QMCabeceraTIPO.AsString, DMOfertas.QMCabeceraID_S.AsInteger, True, DMMain.DameCorreoCopiaAgente(DMOfertas.QMCabeceraAGENTE.AsInteger, 'OFC'));
        finally
           DMMain.Log('CuerpoMail.Free');
           CuerpoMail.Free;
        end;

        DMMain.Log('DMLstOfertas.UpdateaDocumentos');
        // Marco el documento como listado
        DMLstOfertas.UpdateaDocumentos;
     finally
        DMMain.Log('CierraData(DMLstOfertas);');
        CierraData(DMLstOfertas);
     end;
  finally
     DMMain.LogFin('FMOfertas.AEnviarOfertasMailPDF2Execute');
  end;
end;
