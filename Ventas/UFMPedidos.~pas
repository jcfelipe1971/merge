  Asunto : string;
  CuerpoMail : TStrings;
begin
  AbreData(TDMLstPedidos, DMLstPedidos);
  try
     DMLstPedidos.MostrarListadoMail(DMPedidos.QMCabeceraID_S.AsInteger, DMPedidos.QMCabeceraSERIE.AsString,
