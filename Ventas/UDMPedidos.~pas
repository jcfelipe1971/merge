                       SQL.Add(' UNIDADES = UNIDADES + :UNIDADES ');
                       SQL.Add(' WHERE ');
                       SQL.Add(' ID_DETALLES_S = :ID_DETALLES_S ');
                       Params.ByName['ID_DETALLES_S'].AsInteger := IdDetallesS;
                       ExecQuery;
                       FreeHandle;
                    finally
                       Free;
                    end;
                 end;
              end
              else
              begin
              }

