     conpromociones: boolean;
     FlagModificandoUnidades: boolean;
     GEST_OFERTAS_ESC: boolean;
     GEST_ESC_PORDEFECTO: boolean;
     KriConf126, KriConf462: boolean;
     OldLinea: TStrings;
     gUnidades: integer;
