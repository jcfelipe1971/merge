procedure TDMOfertas.VersionesDeOFCKri;
var
  s : string;
  DS : TFIBDataSet;
begin
  DS := TFIBDataSet.Create(nil);
  try
     with DS do
     begin
        Transaction := TFIBTransaction.Create(nil);
        try
           with Transaction do
           begin
              DefaultDatabase := DMMain.DataBase;
              TRParams.Clear;
              TRParams.Add('read_committed');
              TRParams.Add('read');
           end;
           Close;
           DataBase := DMMain.DataBase;
           if (not Transaction.InTransaction) then
              Transaction.StartTransaction;
           SelectSQL.Text := 'select ''EMPRESA=''||REMPRESA||'' AND EJERCICIO=''||REJERCICIO||'' AND CANAL='' ||RCANAL||'' AND SERIE=''''''||RSERIE||'''''' AND RIG=''||RRIG ' +
              'from g_relaciones_origenes (?EMPRESA, ?EJERCICIO, ?CANAL, ?SERIE, ?TIPO, ?RIG) where RTIPO=''OFC'' ' +
              'union ' +
              'select ''EMPRESA=''||REMPRESA||'' AND EJERCICIO=''||REJERCICIO||'' AND CANAL='' ||RCANAL||'' AND SERIE=''''''||RSERIE||'''''' AND RIG=''||RRIG  ' +
              'from g_relaciones_destinos (?EMPRESA, ?EJERCICIO, ?CANAL, ?SERIE, ?TIPO, ?RIG) where RTIPO=''OFC'' ';
           Params.ByName['EMPRESA'].AsInteger := QMCabeceraEMPRESA.AsInteger;
           Params.ByName['EJERCICIO'].AsInteger := QMCabeceraEJERCICIO.AsInteger;
           Params.ByName['CANAL'].AsInteger := QMCabeceraCANAL.AsInteger;
           Params.ByName['SERIE'].AsString := QMCabeceraSERIE.AsString;
           Params.ByName['TIPO'].AsString := QMCabeceraTIPO.AsString;
           Params.ByName['RIG'].AsInteger := QMCabeceraRIG.AsInteger;
           Open;
           s := '(empresa=' + QMCabeceraEMPRESA.AsString + ' and ejercicio=' + QMCabeceraEJERCICIO.AsString + ' and canal=' + QMCabeceraCANAL.AsString + ' and serie=''' + QMCabeceraSERIE.AsString + ''' and tipo=''OFC'' and rig=' + QMCabeceraRIG.AsString + ')';
           while not EOF do
           begin
              s := s + ' or ' + '(' + Fields[0].AsString + ')';
              Next;
           end;
           Close;
           Transaction.Commit;
        finally
           Transaction.Free;
        end;
     end;
  finally
     FreeAndNil(DS);
  end;
  with QMCabecera do
  begin
     Close;
     SelectSQL.Text := 'SELECT * FROM VER_CABECERAS_OFERTA_C WHERE ' + s + ' ORDER BY EJERCICIO,RIG';
     Open;
  end;
end;

procedure TDMOfertas.AbrirCerrar(Estado: integer);
begin
  with THYFIBQuery.Create(nil) do
  begin
     try
        Close;
        DataBase := DMMain.DataBase;
        SQL.Text := 'UPDATE VER_CABECERAS_OFERTA_C SET ESTADO=?ESTADO WHERE ID_S=?ID_S AND ESTADO<>?ESTADO';
        Params.ByName['ESTADO'].AsInteger := Estado;
        Params.ByName['ID_S'].AsInteger := QMCabeceraID_S.AsInteger;
        ExecQuery;
        FreeHandle;
     finally
        Free;
     end;
  end;

  QMCabecera.Refresh;
end;

function TDMOfertas.PuedeHacerPedidoOferta: boolean;
var
  RiesgoAut, RiesgoAct, RiesgoPed, RLinea : double;
  pot10 : extended;
  P_IVA : real;
begin
  Result := True;
  // PECCORI001 - Que chequee el riesgo en pedidos.
  if (LeeParametro('PECCORI001', Serie) = 'S') then
  begin
     RiesgoPed := DMMain.DameRiesgoPedido(QMCabeceraCLIENTE.AsInteger);

     with THYFIBQuery.Create(nil) do
     begin
        try
           Close;
           DataBase := DMMain.DataBase;
           SQL.Text := 'SELECT RIESGO_AUT, RIESGO_ACT FROM EMP_CLIENTES WHERE EMPRESA = :EMPRESA AND CLIENTE = :CLIENTE';
           Params.ByName['EMPRESA'].AsInteger := QMCabeceraEMPRESA.AsInteger;
           Params.ByName['CLIENTE'].AsInteger := QMCabeceraCLIENTE.AsInteger;
           ExecQuery;
           RiesgoAut := FieldByName['RIESGO_AUT'].AsFloat;
           RiesgoAct := FieldByName['RIESGO_ACT'].AsFloat;
           FreeHandle;
        finally
           Free;
        end;
     end;

     pot10 := Power(10, REntorno.DecimalesCalculo);
     RiesgoAut := (Trunc(RiesgoAut * pot10)) / pot10;

     RLinea := QMDetallePRECIO.AsFloat * QMDetalleUNIDADES.AsFloat;
     RLinea := RLinea - (RLinea * QMDetalleDESCUENTO.AsFloat / 100);
     RLinea := RLinea - (RLinea * QMDetalleDESCUENTO_2.AsFloat / 100);
     RLinea := RLinea - (RLinea * QMDetalleDESCUENTO_3.AsFloat / 100);

     if (QMDetalle.State = dsEdit) then
     begin
        RLinea := RLinea + (RLinea * QMDetalleP_IVA.AsFloat / 100);
        RLinea := RLinea - LiquidoAnt;
     end
     else
     begin
        {Busco porcentaje IVA}
        with THYFIBQuery.Create(nil) do
        begin
           try
              Close;
              DataBase := DMMain.DataBase;
              SQL.Text := 'SELECT P_IVA FROM SYS_TIPO_IVA WHERE PAIS = :PAIS AND TIPO = :TIPO';
              Params.ByName['PAIS'].AsString := REntorno.Pais;
              Params.ByName['TIPO'].AsInteger := QMDetalleTIPO_IVA.AsInteger;
              ExecQuery;
              P_IVA := FieldByName['P_IVA'].AsFloat;
              FreeHandle;
           finally
              Free;
           end;
        end;

        RLinea := RLinea + (RLinea * P_IVA / 100);
     end;

     if (((RiesgoAut > 0) or (KriConf126)) and
        (RiesgoAut < RiesgoAct + RiesgoPed + RLinea)) then
     begin
        ShowMessage(
           format(_('El Riesgo Autorizado para el Cliente se ha superado.' + #13#10 +
           'Riesgo Autorizado: %s' + #13#10 +
           'Riesgo Actual: %s'), [FormatFloat(MascaraN, RiesgoAut), FormatFloat(MascaraN, RiesgoAct + RiesgoPed + RLinea)])
           );

        if (xCliente.FieldByName('NO_VENTA_RIESGO').AsInteger = 1) then
           Abort;

        InfoActualiza;
     end;
  end;
end;

{procedure TDMOfertas.QMDetalleAfterScroll(DataSet: TDataSet);
begin
   LiquidoAnt := QMDetalleLIQUIDO.AsFloat;
end;}

procedure TDMOfertas.InsertarOferta(id_s: integer; AgregarAlFinal, MantenerPrecioYDescuentos: boolean);
var
  FQ : TFIBQuery;
  id_detalles_s : integer;
  CantLineas : integer;
  Orden : integer;
  Linea, LineaAux : integer;
begin
  // Veo cuantas lineas tiene la oferta a insertar
  CantLineas := DMMain.DameLineaSiguiente(QMCabeceraTIPO.AsString, QMCabeceraID_S.AsInteger);

  id_detalles_s := QMDetalleID_DETALLES_S.AsInteger;
  // Linea a partir de la que inserto
  Orden := QMDetalleORDEN.AsInteger;

  QMDetalle.DisableControls;
  try
     if (not AgregarAlFinal) then
     begin
        // Avanzo el orden de las lineas
        with QMDetalle do
        begin
           // Renumero el resto de las lineas para generar hueco
           while (not EOF) do
           begin
              with THYFIBQuery.Create(nil) do
              begin
                 try
                    Close;
                    DataBase := DMMain.DataBase;
                    SQL.Text := 'UPDATE GES_DETALLES_S SET ORDEN = ORDEN + ?AVANCE WHERE ID_DETALLES_S = ?ID_DETALLES_S';
                    Params.ByName['AVANCE'].AsInteger := CantLineas - 1;
                    Params.ByName['ID_DETALLES_S'].AsInteger := QMDetalleID_DETALLES_S.AsInteger;
                    ExecQuery;
                    FreeHandle;
                 finally
                    Free;
                 end;
              end;

              Next;
           end;
        end;
     end;

     // Insertamos las lineas
     FQ := TFIBQuery.Create(nil);
     try
        with FQ do
        begin
           Close;
           DataBase := DMMain.DataBase;
           Transaction := TFIBTransaction.Create(nil);
           try
              Transaction.TRParams.Add('read_committed');
              Transaction.TRParams.Add('rec_version');
              Transaction.TRParams.Add('nowait');
              Transaction.DefaultDataBase := DMMain.DataBase;
              Transaction.StartTransaction;

              FSendCorreo := TFSendCorreo.Create(Self);
              try
                 FSendCorreo.Titulo(_('Importando Oferta'));
                 FSendCorreo.Show;

                 if (not Transaction.InTransaction) then
                    Transaction.StartTransaction;
                 Close;
                 SQL.Text := 'SELECT ARTICULO, TITULO, UNIDADES, PRECIO, DESCUENTO, DESCUENTO_2, DESCUENTO_3 FROM GES_DETALLES_S WHERE ID_S = :ID_S ORDER BY ORDEN';
                 Params.ByName['ID_S'].AsInteger := id_s;
                 ExecQuery;
                 LineaAux := 1;
                 while (not EOF) do
                 begin
                    FSendCorreo.Texto(Format(_('Importando linea %d de %d'), [LineaAux, CantLineas]));
                    with QMDetalle do
                    begin
                       Append;
                       Linea := FieldByName('LINEA').AsInteger;
                       FieldByName('ARTICULO').AsString := FQ.FieldByName['ARTICULO'].AsString;
                       FieldByName('TITULO').AsString := FQ.FieldByName['TITULO'].AsString;
                       FieldByName('UNIDADES').AsFloat := FQ.FieldByName['UNIDADES'].AsFloat;
                       if (MantenerPrecioYDescuentos) then
                       begin
                          FieldByName('PRECIO').AsFloat := FQ.FieldByName['PRECIO'].AsFloat;
                          FieldByName('DESCUENTO').AsFloat := FQ.FieldByName['DESCUENTO'].AsFloat;
                          FieldByName('DESCUENTO_2').AsFloat := FQ.FieldByName['DESCUENTO_2'].AsFloat;
                          FieldByName('DESCUENTO_3').AsFloat := FQ.FieldByName['DESCUENTO_3'].AsFloat;
                       end;
                       Post;

                       if (not AgregarAlFinal) then
                       begin
                          // Asigno orden a la linea recien insertada
                          with THYFIBQuery.Create(nil) do
                          begin
                             try
                                Close;
                                DataBase := DMMain.DataBase;
                                SQL.Text := 'UPDATE GES_DETALLES_S SET ORDEN=?ORDEN WHERE ID_S = ?ID_S AND LINEA = ?LINEA';
                                Params.ByName['ORDEN'].AsInteger := Orden;
                                Params.ByName['ID_S'].AsInteger := QMCabeceraID_S.AsInteger;
                                Params.ByName['LINEA'].AsInteger := Linea;
                                ExecQuery;
                                FreeHandle;
                             finally
                                Free;
                             end;
                          end;
                          Inc(Orden);
                       end;

                       Inc(LineaAux);
                    end;
                    FQ.Next;
                 end;
                 Transaction.Commit;
              finally
                 Transaction.Free;
              end;
              FreeHandle;
              FSendCorreo.SePuede := True;
           finally
              FreeAndNil(FSendCorreo);
           end;
        end;
     finally
        FreeAndNil(FQ);
     end;
  finally
     QMDetalle.EnableControls;
  end;

  // Me posiciono sobre la ultima linea insertada
  QMCabecera.Refresh;
  Posicionar(QMDetalle, 'ID_DETALLES_S', id_detalles_s);
end;

