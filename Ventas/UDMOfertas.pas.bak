procedure TDMOfertas.HabilitarBotonesEsc;
begin
  {
  if (LeeParametro('MODREST006') = 'S') then
  begin
     xBuscarEscandalloPed.Close;
     xBuscarEscandalloPed.Params.ByName['id_detalles'].AsInteger := QMDetalleID_DETALLES_S.AsInteger;
     xBuscarEscandalloPed.Prepare;
     xBuscarEscandalloPed.ExecQuery;

     if (xBuscarEscandalloPed.Fields[0].AsInteger <> 0) then
     begin
        FMPedidos.TBEscandall.ImageIndex := 7; //verd
        FMPedidos.AProCrearOF.Enabled := True;
        if (xBuscarEscandalloPed.Fields[2].AsInteger = 0) then //id_orden
           FMPedidos.AProCrearOF.ImageIndex := 8//groc
        else
           FMPedidos.AProCrearOF.ImageIndex := 7;//verd

        FMPedidos.AProADatosEsc.Enabled := True;
        if (xBuscarEscandalloPed.Fields[1].AsInteger = 0) then //id_medida
           FMPedidos.AProADatosEsc.ImageIndex := 8//groc
        else
           FMPedidos.AProADatosEsc.ImageIndex := 7;//verd
     end
     else
     begin
        FMPedidos.TBEscandall.ImageIndex := 6; //vermell
        FMPedidos.AProCrearOF.Enabled := False;
        FMPedidos.AProCrearOF.ImageIndex := 6;//vermell
        FMPedidos.AProADatosEsc.Enabled := False;
        FMPedidos.AProADatosEsc.ImageIndex := 6; //vermell
     end;

     xBuscarEscandalloPed.FreeHandle;
  end;
}
end;

