function TDMOfertas.MargenMinimoSuperado: boolean;
var
  MargenMinimo : double;
  id : integer;
  PermiteModificar : string;
begin
  /// Verifica si todas las lineas se estan vendiendo con un margen minimo
  /// No se tiene en cuenta ARTICULOS_VARIOS
  /// *** SI SE VENDE POR DEBAJO DE MARGEN PERO HAY UN PEDIDO QUE TAMBIEN LO HACE, DEJAMOS SEGUIR
  /// Establecido mediante parámetro DOCMARG001

  Result := True;
  MargenMinimo := StrToFloatDef(LeeParametro('DOCMARG001', Serie), -1);

  if (MargenMinimo >= 0) then
  begin
     PermiteModificar := LeeParametro('DOCMARG002', Serie);

     if (PermiteModificar = 'N') then
     begin
        id := QMDetalleID_DETALLES_S.AsInteger;
        with QMDetalle do
        begin
           DisableControls;
           try
              First;
              // Mientras los margenes se superen recorro las lineas exceptuando "Articulos Varios".
              while (not EOF) and Result do
              begin
                 {
                 if ((DMOfertas.QMDetalleARTICULO.AsString <> REntorno.ArtTextoLibre) and (MargenMinimo > DMOfertas.QMDetalleMARGEN.AsFloat)) then
                    Result := False;
                 }

                 // Se verifica si se vende por debajo del margen.
                 // Si se vende por debajo de margen pero hay un pedido que tambien lo hace, dejamos seguir
                 with THYFIBQuery.Create(nil) do
                 begin
                    try
                       Close;
                       DataBase := DMMain.DataBase;
                       SQL.Text := 'SELECT PUEDE FROM OFC_SUPERA_MARGEN_MINIMO(:ID_DETALLES_S, :MARGEN_MINIMO, :MARGEN)';
                       Params.ByName['ID_DETALLES_S'].AsInteger := QMDetalleID_DETALLES_S.AsInteger;
                       Params.ByName['MARGEN_MINIMO'].AsDouble := MargenMinimo;
                       Params.ByName['MARGEN'].AsDouble := QMDetalleMARGEN.AsFloat;
                       ExecQuery;
                       Result := (FieldByName['PUEDE'].AsInteger = 1);
                       FreeHandle;
                    finally
                       Free;
                    end;
                 end;

                 if Result then
                    Next;
              end;
           finally
              EnableControls;
           end;
        end;

        // Si todo supera margenes reposiciono en la linea en la que estaba.
        if Result then
           Posicionar(QMDetalle, 'ID_DETALLES_S', id);
     end;
  end;
end;

procedure TDMOfertas.TraspasarOfertaActual(TipoDestino: string);
var
  id_s_destino : integer;
  Seguir : boolean;
begin
  if not MargenMinimoSuperado then
     ShowMessage(_('No se ha superado el margen minimo de venta.'))
  else
  begin
     Seguir := True;
     if (QMCabeceraFORMA_PAGO.AsString <> xCliente.FieldByName('FORMA_PAGO').AsString) then
        Seguir := (MessageDlg(format(_('La forma de pago del documento es distinta de la forma de pago habitual del cliente (%s). żDesea seguir?'), [xCliente.FieldByName('FORMA_PAGO').AsString]), mtConfirmation, [mbYes, mbNo], 0) = mrYes);

     if Seguir then
     begin
        with THYFIBQuery.Create(nil) do
        begin
           try
              Close;
              DataBase := DMMain.DataBase;

              SQL.Add(' EXECUTE PROCEDURE G_TRASPASO_OFERTA_A_OTRO_MUL ');
              SQL.Add(' (:EMPRESA, :EJERCICIO, :CANAL, :SERIE, :TIPO, :RIG, ');
              SQL.Add(' :D_TIPO, :ENTRADA, :FECHA, :D_EJERCICIO, :D_CANAL, :D_SERIE, ');
              SQL.Add(' :ID_S, 0, 0, 0) ');

              // Datos de la oferta a traspasar
              Params.ByName['EMPRESA'].AsInteger := QMCabeceraEMPRESA.AsInteger;
              Params.ByName['EJERCICIO'].AsInteger := QMCabeceraEJERCICIO.AsInteger;
              Params.ByName['CANAL'].AsInteger := QMCabeceraCANAL.AsInteger;
              Params.ByName['SERIE'].AsString := QMCabeceraSERIE.AsString;
              Params.ByName['TIPO'].AsString := QMCabeceraTIPO.AsString;
              Params.ByName['RIG'].AsInteger := QMCabeceraRIG.AsInteger;
              Params.ByName['ID_S'].AsInteger := QMCabeceraID_S.AsInteger;

              // Datos del documento destino a generar
              Params.ByName['D_TIPO'].AsString := TipoDestino; // 'PEC', 'ALB', 'FAC'
              Params.ByName['D_EJERCICIO'].AsInteger := REntorno.Ejercicio;
              Params.ByName['D_CANAL'].AsInteger := QMCabeceraCANAL.AsInteger;
              Params.ByName['D_SERIE'].AsString := QMCabeceraSERIE.AsString;
              Params.ByName['FECHA'].AsDateTime := REntorno.FechaTrab; // Debe estar dentro del ejercicio destino
              { TODO -oDuilio : Garantias Navarrete. Filtrar comportamiento con KRICONF_XXX }
              if (QMCabeceraSERIE.AsString = 'RP') then
                 Params.ByName['FECHA'].AsDateTime := Now;

              // Otros datos menos importantes
              Params.ByName['ENTRADA'].AsInteger := REntorno.Entrada;

              ExecQuery;

              // Id del documento generado
              id_s_destino := FieldByName['ID_S_D'].AsInteger;

              FreeHandle;
           finally
              Free;
           end;
        end;

        {TOLYCOR}
        // Es fa el traspas de l'escandall d'ofertes de ventes a les comandes,
        // sempre que el check de configuración a gestión, estigui marcat
        if (GEST_OFERTAS_ESC and (TipoDestino = 'PEC')) then
        begin
           with THYFIBQuery.Create(nil) do
           begin
              try
                 Close;
                 DataBase := DMMain.DataBase;
                 SQL.Text := 'EXECUTE PROCEDURE PRO_TRASPASO_OFERTASV_ESC(:ID_OFERTAS_V, :ID_NUEVO_PEDIDO, :ENTRADA)';
                 Params.ByName['ID_OFERTAS_V'].AsInteger := QMDetalleID_S.AsInteger;
                 Params.ByName['ID_NUEVO_PEDIDO'].AsInteger := id_s_destino;
                 Params.ByName['ENTRADA'].AsInteger := REntorno.Entrada;
                 ExecQuery;
                 FreeHandle;
              finally
                 Free;
              end;
           end;
        end;

        with QMDetalle do
        begin
           try
              DisableControls;
              First;
              while not EOF do
              begin
                 ReiniciaStock(FieldByName('ARTICULO').AsString);
                 Next;
              end;
              First;
           finally
              EnableControls;
           end;
        end;

        if (REntorno.Ejercicio >= QMCabeceraEJERCICIO.AsInteger) then
        begin
           QMCabecera.Refresh;
           AbreDocumentos(id_s_destino, TipoDestino, QMCabeceraSERIE.AsString);
        end
        else
        begin
           QMCabecera.Close;
           QMCabecera.Open;
        end;
     end;
  end;
end;

