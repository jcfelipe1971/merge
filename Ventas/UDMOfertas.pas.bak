        Params.ByName['EMPRESA'].AsInteger := REntorno.Empresa;
        Params.ByName['RANGO'].AsInteger := Rango;
        ExecQuery;
        Result := HayDatos;
        FreeHandle;
     finally
        Free;
     end;
  end;
end;

