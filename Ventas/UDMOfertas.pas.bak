procedure TDMOfertas.CrearOfertaCrm(IDAccion, IDContacto, Cliente, Agente: integer);
begin
  QMCabecera.Insert;

  if (Cliente <> 0) then
     QMCabeceraCLIENTE.AsInteger := Cliente
  else
     QMCabeceraCLIENTE.AsInteger := -1;

  if (Agente > 0) then
     QMCabeceraAGENTE.AsInteger := Agente;

  QMCabecera.Post;

  if (IDAccion <> 0) then
  begin
     with THYFIBQuery.Create(nil) do
     begin
        try
           Close;
           DataBase := DMMain.DataBase;
           SQL.Add(' UPDATE CRM_CONTACTOS_ACCIONES ');
           SQL.Add(' SET ');
           SQL.Add(' DOC_ACCION = :RIG, ');
           SQL.Add(' DOC_EMPRESAS = :EMPRESA, ');
           SQL.Add(' DOC_EJERCICIO = :EJERCICIO, ');
           SQL.Add(' DOC_CANAL = :CANAL, ');
           SQL.Add(' DOC_SERIES = :SERIE ');
           SQL.Add(' WHERE ');
           SQL.Add(' ID_ACCION = :ID_ACCION ');
           Params.ByName['RIG'].AsInteger := QMCabeceraRIG.AsInteger;
           Params.ByName['EMPRESA'].AsInteger := QMCabeceraEMPRESA.AsInteger;
           Params.ByName['EJERCICIO'].AsInteger := QMCabeceraEJERCICIO.AsInteger;
           Params.ByName['CANAL'].AsInteger := QMCabeceraCANAL.AsInteger;
           Params.ByName['SERIE'].AsString := QMCabeceraSERIE.AsString;
           Params.ByName['ID_ACCION'].AsInteger := IDAccion;
           ExecQuery;
           FreeHandle;
        finally
           Free;
        end;
     end;
  end;

  //S'inserta les dades del contacte provinents del contacto
  if ((QMCabeceraCLIENTE.AsInteger <= -1) and (IDContacto > 0)) then
  begin
     with THYFIBQuery.Create(nil) do
     begin
        try
           Close;
           DataBase := DMMain.DataBase;
           SQL.Add(' INSERT INTO GES_CABECERAS_S_FAC_NIF ( ');
           SQL.Add(' EMPRESA, EJERCICIO, CANAL, SERIE, TIPO, RIG, NIF, DIRECCION, C_POSTAL, PROVINCIA, NOMBRE, PAIS, TELEFONO01, TELEFONO02, ');
           SQL.Add(' TELEFAX, EMAIL, LOCALIDAD, TERCERO, PAIS_DOC_IDENT, TIPO_DOC_IDENT) ');
           SQL.Add(' SELECT :EMPRESA, :EJERCICIO, :CANAL, :SERIE, :TIPO, :RIG, C.NIF, SUBSTRING(C.DIR_NOMBRE FROM 1 FOR 100), L.CODPOSTAL, ');
           SQL.Add('        L.PROVINCIA, C.NOMBRE_COMERCIAL, C.PAIS, C.TELEFONO01, C.TELEFONO02, C.TELEFAX, C.EMAIL, L.TITULO, C.TERCERO, ');
           SQL.Add('        L.C_PAIS, ');
           SQL.Add('        (SELECT TIPO_DOC_IDENT ');
           SQL.Add('         FROM SYS_TIPO_DOC_IDENT_PAIS ');
           SQL.Add('         WHERE ');
           SQL.Add('         PAIS = L.C_PAIS AND ');
           SQL.Add('         DEFECTO = 1) ');
           SQL.Add(' FROM CRM_CONTACTOS C ');
           SQL.Add(' LEFT JOIN VER_LOCALIDADES L ON L.LOCALIDAD = C.DIR_LOCALIDAD ');
           SQL.Add(' WHERE ');
           SQL.Add(' C.ID_CONTACTO = :ID_CONTACTO ');
           Params.ByName['EMPRESA'].AsInteger := REntorno.Empresa;
           Params.ByName['EJERCICIO'].AsInteger := REntorno.Ejercicio;
           Params.ByName['CANAL'].AsInteger := REntorno.Canal;
           Params.ByName['SERIE'].AsString := QMCabeceraSERIE.AsString;
           Params.ByName['TIPO'].AsString := QMCabeceraTIPO.AsString;
           Params.ByName['RIG'].AsInteger := QMCabeceraRIG.AsInteger;
           Params.ByName['ID_CONTACTO'].AsInteger := IDContacto;
           ExecQuery;
           FreeHandle;
        finally
           Free;
        end;
     end;
  end;
end;


