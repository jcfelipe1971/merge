function TDMRModelosHacienda.Declarante340(Ejercicio: integer; Periodo: string; NroSecuencia, TipoDeclaracion: integer; DeclaracionAnterior: string; ModoPresentacion: integer): string;
var
  Secuencia : string;
  DeclaracionComplementaria : string;
  DeclaracionSustitutiva : string;
  NumeroDeRegistros : integer;
  BaseImponible : double;
  CuotaImpuesto : double;
  CuotaImpuestoAux : double;
  TotalFacturas : double;
  CodModoPresentacion : string;
  DocSerie : string;
  DocNumero : integer;
begin
  {Para la identificacion no se tiene en cuenta el periodo, solo el mes}
  if (Periodo = '13') then
     Periodo := '01'
  else
  if (Periodo = '14') then
     Periodo := '02'
  else
  if (Periodo = '15') then
     Periodo := '03'
  else
  if (Periodo = '16') then
     Periodo := '04';
  Secuencia := '340' + IntToStr(Ejercicio) + Periodo + ajusta(IntToStr(NroSecuencia), 'I', 4, '0');

  if (Periodo = '13') then
     Periodo := '1T'
  else
  if (Periodo = '14') then
     Periodo := '2T'
  else
  if (Periodo = '15') then
     Periodo := '3T'
  else
  if (Periodo = '16') then
     Periodo := '4T';

  if (TipoDeclaracion = 1) then
     DeclaracionComplementaria := 'C'
  else
     DeclaracionComplementaria := ' ';
  if (TipoDeclaracion = 2) then
     DeclaracionSustitutiva := 'S'
  else
     DeclaracionSustitutiva := ' ';
  if (TipoDeclaracion = 0) then
     DeclaracionAnterior := '0000000000000'
  else
     DeclaracionAnterior := DeclaracionAnterior;

  if (ModoPresentacion = 0) then
     CodModoPresentacion := 'T'
  else
     CodModoPresentacion := 'C';

  {Calculo totales}
  NumeroDeRegistros := 0;
  BaseImponible := 0;
  CuotaImpuesto := 0;
  TotalFacturas := 0;

  xModelo340_expedidas.First;
  while not xModelo340_expedidas.EOF do
  begin
     Inc(NumeroDeRegistros);
     BaseImponible := BaseImponible + xModelo340_expedidasB_IMPONIBLE.AsFloat;

     CuotaImpuestoAux := xModelo340_expedidasI_IVA.AsFloat + xModelo340_expedidasI_REC.AsFloat;
     {Si es una autofactura y tiene Cuota de IVA=0, calculo el IVA - Especial para Fercam}
     if ((xModelo340_expedidasADQUISICION.AsInteger = 1) and (CuotaImpuestoAux = 0)) then
     begin
        if (xModelo340_expedidasDOC_FECHA.AsDateTime < EncodeDate(2010, 07, 01)) then
           CuotaImpuestoAux := Round(xModelo340_expedidasB_IMPONIBLE.AsFloat * 16) / 100
        else
        if ((xModelo340_expedidasDOC_FECHA.AsDateTime >= EncodeDate(2010, 07, 01)) and (xModelo340_expedidasDOC_FECHA.AsDateTime < EncodeDate(2012, 09, 01))) then
           CuotaImpuestoAux := Round(xModelo340_expedidasB_IMPONIBLE.AsFloat * 18) / 100
        else
           CuotaImpuestoAux := Round(xModelo340_expedidasB_IMPONIBLE.AsFloat * 21) / 100;
     end;
     CuotaImpuesto := CuotaImpuesto + CuotaImpuestoAux;

     xModelo340_expedidas.Next;
  end;

  // Debo contar 1 registro por cada grupo de facturas (tickets)
  xModelo340_expedidas_ticket.First;
  DocSerie := xModelo340_expedidas_ticketDOC_SERIE.AsString;
  DocNumero := xModelo340_expedidas_ticketDOC_NUMERO.AsInteger;
  while not xModelo340_expedidas_ticket.EOF do
  begin
     Inc(NumeroDeRegistros);
     while ((DocSerie = xModelo340_expedidas_ticketDOC_SERIE.AsString) and (DocNumero = xModelo340_expedidas_ticketDOC_NUMERO.AsInteger) and (not xModelo340_expedidas_ticket.EOF)) do
     begin
        BaseImponible := BaseImponible + xModelo340_expedidas_TicketB_IMPONIBLE.AsFloat;
        CuotaImpuesto := CuotaImpuesto + xModelo340_expedidas_TicketI_IVA.AsFloat + xModelo340_expedidas_TicketI_REC.AsFloat;

        Inc(DocNumero);
        xModelo340_expedidas_ticket.Next;
     end;

     DocSerie := xModelo340_expedidas_ticketDOC_SERIE.AsString;
     DocNumero := xModelo340_expedidas_ticketDOC_NUMERO.AsInteger;
  end;

  xModelo340_recibidas.First;
  while not xModelo340_recibidas.EOF do
  begin
     Inc(NumeroDeRegistros);
     BaseImponible := BaseImponible + xModelo340_recibidasB_IMPONIBLE.AsFloat;

     CuotaImpuestoAux := xModelo340_recibidasI_IVA.AsFloat + xModelo340_recibidasI_REC.AsFloat;
     {Si es una autofactura y tiene Cuota de IVA=0, calculo el IVA - Especial para Fercam}
     if ((xModelo340_recibidasADQUISICION.AsInteger = 1) and (CuotaImpuestoAux = 0)) then
     begin
        if (xModelo340_recibidasDOC_FECHA.AsDateTime < EncodeDate(2010, 07, 01)) then
           CuotaImpuestoAux := Round(xModelo340_recibidasB_IMPONIBLE.AsFloat * 16) / 100
        else
        if ((xModelo340_recibidasDOC_FECHA.AsDateTime >= EncodeDate(2010, 07, 01)) and (xModelo340_recibidasDOC_FECHA.AsDateTime < EncodeDate(2012, 09, 01))) then
           CuotaImpuestoAux := Round(xModelo340_recibidasB_IMPONIBLE.AsFloat * 18) / 100
        else
           CuotaImpuestoAux := Round(xModelo340_recibidasB_IMPONIBLE.AsFloat * 21) / 100;
     end;
     // ***********************************************************************************
     // OJO Si cambia esto, también debe cambiar en el procedimiento declarado340_recibidas
     // ***********************************************************************************
     if (xModelo340_recibidasPAIS.AsString <> 'ESP') then
     begin
        // Si es una compra intracomunitaria en la que me cobran el IVA
        if (xModelo340_recibidasMODO.AsInteger = 1) then
        begin
           BaseImponible := BaseImponible + CuotaImpuestoAux;
           CuotaImpuestoAux := 0;
        end;

        if (xModelo340_recibidasMODO.AsInteger = 3) then
        begin
           if (CuotaImpuestoAux = 0) then
           begin
              if (xModelo340_recibidasDOC_FECHA.AsDateTime < EncodeDate(2010, 07, 01)) then
                 CuotaImpuestoAux := Round(xModelo340_recibidasB_IMPONIBLE.AsFloat * 16) / 100
              else
              if ((xModelo340_recibidasDOC_FECHA.AsDateTime >= EncodeDate(2010, 07, 01)) and (xModelo340_recibidasDOC_FECHA.AsDateTime < EncodeDate(2012, 09, 01))) then
                 CuotaImpuestoAux := Round(xModelo340_recibidasB_IMPONIBLE.AsFloat * 18) / 100
              else
                 CuotaImpuestoAux := Round(xModelo340_recibidasB_IMPONIBLE.AsFloat * 21) / 100;
           end;
        end;
     end;
     // ***********************************************************************************
     // Hasta aqui
     // ***********************************************************************************

     CuotaImpuesto := CuotaImpuesto + CuotaImpuestoAux;

     xModelo340_recibidas.Next;
  end;

  xModelo340_Op_Intracomunitarias.First;
  while not xModelo340_Op_Intracomunitarias.EOF do
  begin
     Inc(NumeroDeRegistros);
     BaseImponible := BaseImponible + xModelo340_Op_IntracomunitariasB_IMPONIBLE.AsFloat;

     CuotaImpuestoAux := xModelo340_Op_IntracomunitariasI_IVA.AsFloat + xModelo340_Op_IntracomunitariasI_REC.AsFloat;
     {Si es una autofactura y tiene Cuota de IVA=0, calculo el IVA - Especial para Fercam}
     if ((xModelo340_Op_IntracomunitariasADQUISICION.AsInteger = 1) and (CuotaImpuestoAux = 0)) then
     begin
        if (xModelo340_Op_IntracomunitariasDOC_FECHA.AsDateTime < EncodeDate(2010, 07, 01)) then
           CuotaImpuestoAux := Round(xModelo340_Op_IntracomunitariasB_IMPONIBLE.AsFloat * 16) / 100
        else
        if ((xModelo340_Op_IntracomunitariasDOC_FECHA.AsDateTime >= EncodeDate(2010, 07, 01)) and (xModelo340_Op_IntracomunitariasDOC_FECHA.AsDateTime < EncodeDate(2012, 09, 01))) then
           CuotaImpuestoAux := Round(xModelo340_Op_IntracomunitariasB_IMPONIBLE.AsFloat * 18) / 100
        else
           CuotaImpuestoAux := Round(xModelo340_Op_IntracomunitariasB_IMPONIBLE.AsFloat * 21) / 100;
     end;
     CuotaImpuesto := CuotaImpuesto + CuotaImpuestoAux;

     xModelo340_Op_Intracomunitarias.Next;
  end;
  TotalFacturas := TotalFacturas + BaseImponible + CuotaImpuesto;

  {Aqui hay que sumar los Bienes de Inversion}

  with xTercero do
  begin
     Close;
     Params.ByName['TERCERO'].AsInteger := REntorno.Tercero;
     Open;
  end;

  with xDatosModelosHacienda do
  begin
     Close;
     Params.ByName['EMPRESA'].AsInteger := REntorno.Empresa;
     Params.ByName['EJERCICIO'].AsInteger := Ejercicio;
     Params.ByName['CANAL'].AsInteger := REntorno.Canal;
     Open;
  end;

  nif_declarante := Trim(xDatosModelosHaciendaDECLARANTE_NIF.AsString);
  {dji lrk kri - Tomo los últimos 9 digitos, por si le puso el pais adelante (ESB62846530)}
  if (Length(nif_declarante) > 9) then
     nif_declarante := Copy(nif_declarante, Length(nif_declarante) - 8, 9);

  Result := '1340' + IntToStr(Ejercicio) +
     ajusta(nif_declarante, 'D', 9, '0') +
     ajusta(xDatosModelosHaciendaDECLARANTE_NOMBRE.AsString, 'D', 40, ' ') +
     CodModoPresentacion + {Transmision telemática (C = DVD)}
     ajusta(xDatosModelosHaciendaPRESENTADOR_TELEFONO.AsString, 'D', 9, '0') + // Telefono contacto
     ajusta(xDatosModelosHaciendaPRESENTADOR_NOMBRE.AsString, 'D', 40, ' ') +   // Contacto
     Secuencia + //340EEEEPPSSSS
     DeclaracionComplementaria + DeclaracionSustitutiva + DeclaracionAnterior +
     Periodo + {01-12, 1T, 2T, 3T, 4T}

     FormatFloat('000000000', NumeroDeRegistros) +

     FormatFloat340(BaseImponible, 2, 18) +
     FormatFloat340(CuotaImpuesto, 2, 18) +
     FormatFloat340(TotalFacturas, 2, 18) +

     StringOfChar(' ', 190) + {Blancos}
     StringOfChar(' ', 9) + {NIF representante legal para menores de 14}
     StringOfChar(' ', 16) + {Codigo electronico de autiliquidacion iva}
     StringOfChar(' ', 85); {Blancos al final}
  FiltraDatosDeclarante;
end;

function TDMRModelosHacienda.Declarado340_expedidas: string;
var
  nif_declarado : string;
  nif_declarado_intra : string;
  ClaveTipoLibro : string;
  ClaveOperacion : string;
  FechaExpedicion : string;
  FechaOperacion : string;
  Pais : string;
  TipoIdentificacion : string;
  BaseImponible : double;
  CuotaImpuesto : double;
  TotalFacturas : double;
  PorcImpuesto : double;
  ImporteEnMetalico : double;
  EjercicioMetalico : string;
  BaseImponibleACoste : double;
begin
  BaseImponible := xModelo340_expedidasB_IMPONIBLE.AsFloat;
  CuotaImpuesto := xModelo340_expedidasI_IVA.AsFloat + xModelo340_expedidasI_REC.AsFloat;
  PorcImpuesto := xModelo340_expedidasP_IVA.AsFloat;
  BaseImponibleACoste := 0;
  if (xModelo340_expedidasPAIS.AsString = 'ESP') then
  begin
     {tomo los 9 ultimos caracteres porque a veces ponen ES antes de nif (ESX3249299E)}
     nif_declarado := ajusta(Trim(Copy(Trim(xModelo340_expedidasNIF.AsString), Length(Trim(xModelo340_expedidasNIF.AsString)) - 8, 9)), 'D', 9, '0');
     nif_declarado_intra := ajusta(' ', 'D', 20, ' ');
     Pais := xModelo340_expedidasPAIS_C2.AsString;
     TipoIdentificacion := '1';
  end
  else
  begin
     nif_declarado := ajusta(' ', 'D', 9, ' ');
     nif_declarado_intra := ajusta(Trim(xModelo340_expedidasNIF.AsString), 'D', 20, ' '); {Pais (2 pos.)+Nro (15 pos.)+ Blanco (3 pos.)}
     Pais := xModelo340_expedidasPAIS_C2.AsString;
     {Suiza, Vaticano y Monaco tiene un trato especial}
     if ((xModelo340_expedidasPERTENECE_CEE.AsInteger = 1) and
        (xModelo340_expedidasPAIS.AsString <> 'CHE') and
        (xModelo340_expedidasPAIS.AsString <> 'VAT') and
        (xModelo340_expedidasPAIS.AsString <> 'MCO')) then
        TipoIdentificacion := '2'
     else
        TipoIdentificacion := '6';
  end;

  ClaveTipoLibro := 'E'; {Libro de registro de facturas expedidas}
  ClaveOperacion := ' ';

  if (xModelo340_expedidasADQUISICION.AsInteger = 1) then
  begin
     {Especial para Fercam}
     if (CuotaImpuesto = 0) then
     begin
        if (xModelo340_expedidasDOC_FECHA.AsDateTime < EncodeDate(2010, 07, 01)) then
           PorcImpuesto := 16
        else
        if ((xModelo340_expedidasDOC_FECHA.AsDateTime >= EncodeDate(2010, 07, 01)) and (xModelo340_expedidasDOC_FECHA.AsDateTime < EncodeDate(2012, 09, 01))) then
           PorcImpuesto := 18
        else
           PorcImpuesto := 21;
        CuotaImpuesto := Round(BaseImponible * PorcImpuesto) / 100;
        {Prueba parece que las autofacturas no tienen que llevar el porcentaje pero si la base y la cuota}
        PorcImpuesto := 0;
     end;
  end;

  { La clave de operacion es siempre ' '. Tanto para las intracomunitarias como para las nacionales
  if (xModelo340_expedidasMODO.AsInteger = 3) then
     ClaveOperacion := 'I'
  else
     ClaveOperacion := ' ';
  }

  TotalFacturas := BaseImponible + CuotaImpuesto;

  FechaExpedicion := FormatDateTime('yyyymmdd', xModelo340_expedidasFECHA_REGISTRO.AsDateTime);
  FechaOperacion := FormatDateTime('yyyymmdd', xModelo340_expedidasDOC_FECHA.AsDateTime);

  {cuando la fecha de operación sea mayor a la de expedición las iguales - Fercam}
  if (xModelo340_expedidasDOC_FECHA.AsDateTime > xModelo340_expedidasFECHA_REGISTRO.AsDateTime) then
     FechaOperacion := FechaExpedicion;

  Result := '2340' + xModelo340_expedidasEJERCICIO.AsString +
     ajusta(nif_declarante, 'D', 9, '0') +
     nif_declarado +
     ajusta(' ', 'D', 9, ' ') + {NIF representante legal de menot de 14}
     ajusta(QuitaCaracteresNoValidos(xModelo340_expedidasNOMBRE.AsString), 'D', 40, ' ') + {NIF del declarado}
     ajusta(Pais, 'D', 2, ' ') + {Pais}
     ajusta(TipoIdentificacion, 'I', 1, '0') + {Clave nro de identificacion (1-6)}
     nif_declarado_intra +
     ajusta(ClaveTipoLibro, 'D', 1, ' ') +
     ajusta(ClaveOperacion, 'D', 1, ' ') +
     FechaExpedicion +
     FechaOperacion +
     FormatFloat('000', Abs(Trunc(PorcImpuesto))) + FormatFloat('00', (Abs(PorcImpuesto - Trunc(PorcImpuesto)) * 100)) +
     FormatFloat340(BaseImponible, 2, 14) +
     FormatFloat340(CuotaImpuesto, 2, 14) +
     FormatFloat340(TotalFacturas, 2, 14) +
     FormatFloat340(BaseImponibleACoste, 2, 14);

  {Identificacion de la factura}
  {Si es una autofactura le agrego (AF) al final de la identificacion de factura}
  if (xModelo340_expedidasADQUISICION.AsInteger = 0) then
     Result := Result + ajusta(xModelo340_expedidasDOC_TIPO.AsString + '-' + xModelo340_expedidasDOC_SERIE.AsString + '/' + xModelo340_expedidasDOC_NUMERO.AsString, 'D', 40, ' ')
  else
     Result := Result + ajusta(xModelo340_expedidasDOC_TIPO.AsString + '-' + xModelo340_expedidasDOC_SERIE.AsString + '/' + xModelo340_expedidasDOC_NUMERO.AsString + '(AF)', 'D', 40, ' ');

  // Importe precibido en metalico.
  ImporteEnMetalico := 0;
  EjercicioMetalico := xModelo340_expedidasEJERCICIO.AsString;

  // **** NO ES ASI **** - Si el importe es 0, el ejercicio debe estar vacio
  // if (ImporteEnMetalico = 0) then
  //    EjercicioMetalico := '    ';

  Result := Result + ajusta(xModelo340_expedidasREGISTRO.AsString + '.' + xModelo340_expedidasLINEA.AsString, 'D', 18, ' ') + {Numero de registro}

     {Hasta acá son todos los registros iguales}

     ajusta('1', 'I', 8, '0') + {Numero de facturas}
     '01' + {Numero de registros (desglose)}
     ajusta(' ', 'D', 40, ' ') + {Intervalo de identificacion de la acumulacion - primer numero}
     ajusta(' ', 'D', 40, ' ') + {Intervalo de identificacion de la acumulacion - ultimo numero}
     ajusta(' ', 'D', 40, ' ') + {Identificacion de la factura rectificativa}
     FormatFloat('000', Abs(Trunc(xModelo340_expedidasP_REC.AsFloat))) + FormatFloat('00', (Abs(xModelo340_expedidasP_REC.AsFloat - Trunc(xModelo340_expedidasP_REC.AsFloat)) * 100)) + {Tipo recargo de equivalencia}
     FormatFloat340(xModelo340_expedidasI_REC.AsFloat, 2, 14) + {Cuota recargo de equivalencia}
     '0' + {Situacion del inmueble - (Si se pone R en la clave de la operacion)}
     ajusta(' ', 'D', 25, ' ') + {Referencia Catastral}
     FormatFloat('0000000000000', Abs(Trunc(ImporteEnMetalico))) + FormatFloat('00', (Abs(ImporteEnMetalico - Trunc(ImporteEnMetalico)) * 100)) + {Importe recibido en metalico}
     ajusta(EjercicioMetalico, 'D', 4, ' ') + {Ejercicio del cobro en metalico}
     FormatFloat('0000000000000', Abs(Trunc(0))) + FormatFloat('00', (Abs(0 - Trunc(0)) * 100)); {Importe recibido por transmisiones de inmuebles}

  if (xModelo340_expedidasEJERCICIO.AsInteger = 2013) then
     Result := Result + ajusta(' ', 'D', 56, ' '); {Blancos}

  if (xModelo340_expedidasEJERCICIO.AsInteger >= 2014) then
  begin
     if (REntorno.RECC = 1) then
     begin
        Result := Result + FormatDateTime('yyyymmdd', Today) + {Fecha de Cobro}
           FormatFloat('00000000000', Abs(Trunc(0))) + FormatFloat('00', (Abs(0 - Trunc(0)) * 100)) + {Importes cobrados}
           'Z' + {Medio utilizado}
           ajusta(' ', 'D', 34, ' '); {Cta. Bancaria o medio de cobro utilizado}
     end
     else
     begin
        Result := Result + '00000000' + {Fecha de Cobro}
           FormatFloat('00000000000', Abs(Trunc(0))) + FormatFloat('00', (Abs(0 - Trunc(0)) * 100)) + {Importes cobrados}
           ' ' + {Medio utilizado}
           ajusta(' ', 'D', 34, ' '); {Cta. Bancaria o medio de cobro utilizado}
     end;
  end;
end;

function TDMRModelosHacienda.FormatFloat340(Numero: real; Dec: integer; long: integer): string;
begin
  /// Formato sin separador decimal primero char es signo y solo puede ser 'N' o ' ',

  Result := DMMain.FloatToStrSinComa(numero, Dec, long, 'N');
  if (Result[1] <> 'N') then
     Result[1] := ' ';
end;

function TDMRModelosHacienda.Declarado340_expedidas_ticket: string;
var
  nif_declarado : string;
  nif_declarado_intra : string;
  ClaveTipoLibro : string;
  ClaveOperacion : string;
  FechaExpedicion : string;
  FechaOperacion : string;
  Pais : string;
  TipoIdentificacion : string;
  BaseImponible : double;
  CuotaImpuesto : double;
  TotalFacturas : double;
  PorcImpuesto : double;
  ImporteEnMetalico : double;
  EjercicioMetalico : string;
  BaseImponibleACoste : double;
  DocSerie : string;
  DocNumero : integer;
  MinDocNumero : integer;
  MaxDocNumero : integer;
  Registro : integer;
  Ejercicio : string;
  NumeroFacturas : integer;
begin
  // Agrupo facturas de tercero -1 correlativas y devuelvo un registro con clave "J"

  Ejercicio := xModelo340_expedidasEJERCICIO.AsString;
  DocSerie := xModelo340_expedidas_ticketDOC_SERIE.AsString;
  DocNumero := xModelo340_expedidas_ticketDOC_NUMERO.AsInteger;
  MinDocNumero := DocNumero;
  MaxDocNumero := DocNumero;
  Registro := xModelo340_expedidas_ticketREGISTRO.AsInteger;
  FechaExpedicion := '99999999'; // Pondré la fecha menor
  FechaOperacion := '99999999'; // Pondré la fecha menor
  BaseImponible := 0;
  CuotaImpuesto := 0;
  // Según Joana de Fercam debe ser siempre 1
  NumeroFacturas := 1;
  while ((DocSerie = xModelo340_expedidas_ticketDOC_SERIE.AsString) and (DocNumero = xModelo340_expedidas_ticketDOC_NUMERO.AsInteger) and (not xModelo340_expedidas_ticket.EOF)) do
  begin
     BaseImponible := BaseImponible + xModelo340_expedidas_TicketB_IMPONIBLE.AsFloat;
     CuotaImpuesto := CuotaImpuesto + xModelo340_expedidas_TicketI_IVA.AsFloat + xModelo340_expedidas_TicketI_REC.AsFloat;
     if (FechaExpedicion > FormatDateTime('yyyymmdd', xModelo340_expedidas_ticketFECHA_REGISTRO.AsDateTime)) then
        FechaExpedicion := FormatDateTime('yyyymmdd', xModelo340_expedidas_ticketFECHA_REGISTRO.AsDateTime);
     if (FechaOperacion > FormatDateTime('yyyymmdd', xModelo340_expedidas_ticketDOC_FECHA.AsDateTime)) then
        FechaOperacion := FormatDateTime('yyyymmdd', xModelo340_expedidas_ticketDOC_FECHA.AsDateTime);
     MaxDocNumero := DocNumero;

     Inc(DocNumero);
     xModelo340_expedidas_ticket.Next;
  end;

  // Si no llegue al final, me posiciono en el anterior que es el ultimo de esta serie
  if (not xModelo340_expedidas_ticket.EOF) then
     xModelo340_expedidas_ticket.Prior;

  TotalFacturas := BaseImponible + CuotaImpuesto;

  PorcImpuesto := 0;
  BaseImponibleACoste := 0;
  nif_declarado := ajusta('', 'D', 9, '0');
  nif_declarado_intra := ajusta(' ', 'D', 20, ' ');
  Pais := DamePaisC2(REntorno.Pais);
  TipoIdentificacion := '1';
  ClaveTipoLibro := 'E'; {Libro de registro de facturas expedidas}
  ClaveOperacion := 'J'; {Tickets}

  {cuando la fecha de operación sea mayor a la de expedición las iguales - Fercam}
  if (FechaOperacion > FechaExpedicion) then
     FechaOperacion := FechaExpedicion;

  Result := '2340' + Ejercicio +
     ajusta(nif_declarante, 'D', 9, '0') +
     nif_declarado +
     ajusta(' ', 'D', 9, ' ') + {NIF representante legal de menot de 14}
     ajusta(QuitaCaracteresNoValidos(_('TERCEROS VARIOS')), 'D', 40, ' ') +
     ajusta(Pais, 'D', 2, ' ') + {Pais}
     ajusta(TipoIdentificacion, 'I', 1, '0') + {Clave nro de identificacion (1-6)}
     nif_declarado_intra +
     ajusta(ClaveTipoLibro, 'D', 1, ' ') +
     ajusta(ClaveOperacion, 'D', 1, ' ') +
     FechaExpedicion +
     FechaOperacion +
     FormatFloat('000', Abs(Trunc(PorcImpuesto))) + FormatFloat('00', (Abs(PorcImpuesto - Trunc(PorcImpuesto)) * 100)) +
     FormatFloat340(BaseImponible, 2, 14) +
     FormatFloat340(CuotaImpuesto, 2, 14) +
     FormatFloat340(TotalFacturas, 2, 14) +
     FormatFloat340(BaseImponibleACoste, 2, 14);

  {Identificacion de la factura}
  Result := Result + ajusta('TIC' + '-' + DocSerie + '/' + IntToStr(MaxDocNumero), 'D', 40, ' ');

  // Importe precibido en metalico.
  ImporteEnMetalico := 0;
  EjercicioMetalico := Ejercicio;

  Result := Result + ajusta(IntToStr(Registro), 'D', 18, ' ') + {Numero de registro}

     {Hasta acá son todos los registros iguales}

     ajusta(IntToStr(NumeroFacturas), 'I', 8, '0') + {Numero de facturas}
     '01' + {Numero de registros (desglose)}
     ajusta(DocSerie + '/' + IntToStr(MinDocNumero), 'D', 40, ' ') + {Intervalo de identificacion de la acumulacion - primer numero}
     ajusta(DocSerie + '/' + IntToStr(MaxDocNumero), 'D', 40, ' ') + {Intervalo de identificacion de la acumulacion - ultimo numero}
     ajusta(' ', 'D', 40, ' ') + {Identificacion de la factura rectificativa}
     FormatFloat('000', Abs(Trunc(0))) + FormatFloat('00', (Abs(0 - Trunc(0)) * 100)) + {Tipo recargo de equivalencia}
     FormatFloat340(0, 2, 14) + {Cuota recargo de equivalencia}
     '0' + {Situacion del inmueble - (Si se pone R en la clave de la operacion)}
     ajusta(' ', 'D', 25, ' ') + {Referencia Catastral}
     FormatFloat('0000000000000', Abs(Trunc(ImporteEnMetalico))) + FormatFloat('00', (Abs(ImporteEnMetalico - Trunc(ImporteEnMetalico)) * 100)) + {Importe recibido en metalico}
     ajusta(EjercicioMetalico, 'D', 4, ' ') + {Ejercicio del cobro en metalico}
     FormatFloat('0000000000000', Abs(Trunc(0))) + FormatFloat('00', (Abs(0 - Trunc(0)) * 100)); {Importe recibido por transmisiones de inmuebles}

  if (Ejercicio = '2013') then
     Result := Result + ajusta(' ', 'D', 56, ' '); {Blancos}

  if (Ejercicio >= '2014') then
  begin
     if (REntorno.RECC = 1) then
     begin
        Result := Result + FormatDateTime('yyyymmdd', Today) + {Fecha de Cobro}
           FormatFloat('00000000000', Abs(Trunc(0))) + FormatFloat('00', (Abs(0 - Trunc(0)) * 100)) + {Importes cobrados}
           'Z' + {Medio utilizado}
           ajusta(' ', 'D', 34, ' '); {Cta. Bancaria o medio de cobro utilizado}
     end
     else
     begin
        Result := Result + '00000000' + {Fecha de Cobro}
           FormatFloat('00000000000', Abs(Trunc(0))) + FormatFloat('00', (Abs(0 - Trunc(0)) * 100)) + {Importes cobrados}
           ' ' + {Medio utilizado}
           ajusta(' ', 'D', 34, ' '); {Cta. Bancaria o medio de cobro utilizado}
     end;
  end;
end;

function TDMRModelosHacienda.Declarado340_recibidas: string;
var
  nif_declarado : string;
  nif_declarado_intra : string;
  ClaveTipoLibro : string;
  ClaveOperacion : string;
  FechaExpedicion : string;
  FechaOperacion : string;
  Pais : string;
  TipoIdentificacion : string;
  BaseImponible : double;
  CuotaImpuesto : double;
  TotalFacturas : double;
  PorcImpuesto : double;
  CuotaDeducible : double;
  BaseImponibleACoste : double;
begin
  BaseImponible := xModelo340_recibidasB_IMPONIBLE.AsFloat;
  CuotaImpuesto := xModelo340_recibidasI_IVA.AsFloat + xModelo340_recibidasI_REC.AsFloat;
  PorcImpuesto := xModelo340_recibidasP_IVA.AsFloat;
  BaseImponibleACoste := 0;
  CuotaDeducible := 0;
  ClaveOperacion := ' ';
  if (xModelo340_recibidasPAIS.AsString = 'ESP') then
  begin
     {tomo los 9 ultimos caracteres porque a veces ponen ES antes de nif (ESX3249299E)}
     nif_declarado := ajusta(Trim(Copy(Trim(xModelo340_recibidasNIF.AsString), Length(Trim(xModelo340_recibidasNIF.AsString)) - 8, 9)), 'D', 9, '0');
     nif_declarado_intra := ajusta(' ', 'D', 20, ' ');
     Pais := xModelo340_recibidasPAIS_C2.AsString;
     TipoIdentificacion := '1';
  end
  else
  begin
     nif_declarado := ajusta(' ', 'D', 9, ' ');
     nif_declarado_intra := ajusta(Trim(xModelo340_recibidasNIF.AsString), 'D', 20, ' '); {Pais (2 pos.)+Nro (15 pos.)+ Blanco (3 pos.)}
     Pais := xModelo340_recibidasPAIS_C2.AsString;
     {Suiza, Vaticano y Monaco tiene un trato especial}
     if ((xModelo340_recibidasPERTENECE_CEE.AsInteger = 1) and
        (xModelo340_recibidasPAIS.AsString <> 'CHE') and
        (xModelo340_recibidasPAIS.AsString <> 'VAT') and
        (xModelo340_recibidasPAIS.AsString <> 'MCO')) then
        TipoIdentificacion := '2'
     else
        TipoIdentificacion := '6';

     // ***********************************************************************************
     // OJO Si cambia esto, también debe cambiar en el procedimiento declarado340_recibidas
     // ***********************************************************************************
     // Si es una compra intracomunitaria en la que me cobran el IVA
     if (xModelo340_recibidasMODO.AsInteger = 1) then
     begin
        BaseImponible := BaseImponible + CuotaImpuesto;
        CuotaImpuesto := 0;
        PorcImpuesto := 0;
     end;
     if (xModelo340_recibidasMODO.AsInteger = 3) then
     begin
        if (CuotaImpuesto = 0) then
        begin
           if (xModelo340_recibidasDOC_FECHA.AsDateTime < EncodeDate(2010, 07, 01)) then
              PorcImpuesto := 16
           else
           if (xModelo340_recibidasDOC_FECHA.AsDateTime >= EncodeDate(2010, 07, 01)) and (xModelo340_recibidasDOC_FECHA.AsDateTime < EncodeDate(2012, 09, 01)) then
              PorcImpuesto := 18
           else
              PorcImpuesto := 21;

           CuotaImpuesto := Round(BaseImponible * PorcImpuesto) / 100;
        end;
        ClaveOperacion := 'I';
     end;

     // Si es una compra intracomunitaria
     if (xModelo340_recibidasMODO.AsInteger = 3) then
        CuotaDeducible := CuotaImpuesto;
  end;

  ClaveTipoLibro := 'R'; {Libro de registro de facturas recibidas}

  {Especial para Fercam. Esto calcula el cuota de IVA en las autofacturas, que puede venir a 0}
  if (xModelo340_recibidasADQUISICION.AsInteger = 1) then
  begin
     if (CuotaImpuesto = 0) then
     begin
        if (xModelo340_recibidasDOC_FECHA.AsDateTime < EncodeDate(2010, 07, 01)) then
           PorcImpuesto := 16
        else
        if ((xModelo340_recibidasDOC_FECHA.AsDateTime >= EncodeDate(2010, 07, 01)) and (xModelo340_recibidasDOC_FECHA.AsDateTime < EncodeDate(2012, 09, 01))) then
           PorcImpuesto := 18
        else
           PorcImpuesto := 21;

        CuotaImpuesto := Round(BaseImponible * PorcImpuesto) / 100;
        {Prueba parece que las autofacturas no tienen que llevar el porcentaje pero si la base y la cuota}
        PorcImpuesto := 0;
     end;
  end;

  // Si es una autofactura
  if (xModelo340_recibidasADQUISICION.AsInteger = 1) then
     ClaveOperacion := 'I';

  TotalFacturas := BaseImponible + CuotaImpuesto;

  FechaExpedicion := FormatDateTime('yyyymmdd', xModelo340_recibidasFECHA_REGISTRO.AsDateTime);
  FechaOperacion := FormatDateTime('yyyymmdd', xModelo340_recibidasDOC_FECHA.AsDateTime);

  {cuando la fecha de operación sea mayor a la de expedición las iguales - Fercam}
  if (xModelo340_recibidasDOC_FECHA.AsDateTime > xModelo340_recibidasFECHA_REGISTRO.AsDateTime) then
     FechaOperacion := FechaExpedicion;

  Result := '2340' + xModelo340_recibidasEJERCICIO.AsString +
     ajusta(nif_declarante, 'D', 9, '0') +
     nif_declarado +
     ajusta(' ', 'D', 9, ' ') + {NIF representante legal de menot de 14}
     ajusta(QuitaCaracteresNoValidos(xModelo340_recibidasNOMBRE.AsString), 'D', 40, ' ') + {NIF del declarado}
     ajusta(Pais, 'D', 2, ' ') + {Pais}
     ajusta(TipoIdentificacion, 'I', 1, '0') + {Clave nro de identificacion (1-6)}
     nif_declarado_intra +
     ajusta(ClaveTipoLibro, 'D', 1, ' ') +
     ajusta(ClaveOperacion, 'D', 1, ' ') +
     FechaExpedicion +
     FechaOperacion +
     FormatFloat('000', Abs(Trunc(PorcImpuesto))) + FormatFloat('00', (Abs(PorcImpuesto - Trunc(PorcImpuesto)) * 100)) +
     FormatFloat340(BaseImponible, 2, 14) +
     FormatFloat340(CuotaImpuesto, 2, 14) +
     FormatFloat340(TotalFacturas, 2, 14) +
     FormatFloat340(BaseImponibleACoste, 2, 14);

  if (xModelo340_recibidasADQUISICION.AsInteger = 0) then
     Result := Result + ajusta(xModelo340_recibidasDOC_TIPO.AsString + '-' + xModelo340_recibidasDOC_SERIE.AsString + '/' + xModelo340_recibidasDOC_NUMERO.AsString, 'D', 40, ' ')  {Identificacion de la factura}
  else
     Result := Result + ajusta(xModelo340_recibidasDOC_TIPO.AsString + '-' + xModelo340_recibidasDOC_SERIE.AsString + '/' + xModelo340_recibidasDOC_NUMERO.AsString + '(AF)', 'D', 40, ' '); {Identificacion de la factura}

  Result := Result + ajusta(xModelo340_recibidasREGISTRO.AsString + '.' + xModelo340_recibidasLINEA.AsString, 'D', 18, ' ') + {Numero de registro}

     {Hasta acá son todos los registros iguales}

     ajusta('1', 'I', 18, '0') + {Numero de facturas}
     '01' + {Numero de registros (desglose)}
     ajusta(' ', 'D', 40, ' ') + {Intervalo de identificacion de la acumulacion - primer numero}
     ajusta(' ', 'D', 40, ' ') + {Intervalo de identificacion de la acumulacion - ultimo numero}

     FormatFloat340(CuotaDeducible, 2, 14); {Cuota Deducible - Configuracion voluntaria}

  if (xModelo340_recibidasEJERCICIO.AsInteger = 2013) then
     Result := Result + ajusta(' ', 'D', 151, ' '); {Blancos}

  if (xModelo340_recibidasEJERCICIO.AsInteger >= 2014) then
  begin
     if (REntorno.RECC = 1) then
     begin
        Result := Result + FormatDateTime('yyyymmdd', Today) + {Fecha de Pago}
           FormatFloat('00000000000', Abs(Trunc(0))) + FormatFloat('00', (Abs(0 - Trunc(0)) * 100)) + {Importes cobrados}
           'Z' + {Medio utilizado}
           ajusta(' ', 'D', 34, ' '); {Cta. Bancaria o medio de cobro utilizado}
     end
     else
     begin
        Result := Result + '00000000' + {Fecha de Pago}
           FormatFloat('00000000000', Abs(Trunc(0))) + FormatFloat('00', (Abs(0 - Trunc(0)) * 100)) + {Importes cobrados}
           ' ' + {Medio utilizado}
           ajusta(' ', 'D', 34, ' '); {Cta. Bancaria o medio de cobro utilizado}
     end;

     Result := Result + ajusta(' ', 'D', 95, ' '); {Blancos}
  end;
end;

