        Write(f, Ajusta(DMMain.FloatToStrSinComa(QMModelo303C67.AsFloat, 2, 17, 'N'), 'I', 17, '0')); // Resultado - Cuotas a compensar de periodos anteriores [110] (antes [67])
        Write(f, Ajusta(DMMain.FloatToStrSinComa(0, 2, 17, 'N'), 'I', 17, '0')); // Cuotas a compensar de periodos anteriores aplicadas en este periodo [78]
        Write(f, Ajusta(DMMain.FloatToStrSinComa(0, 2, 17, 'N'), 'I', 17, '0')); // Cuotas a compensar de periodos previos pendientes para periodos posteriores ([110] - [78]) [87]
        Write(f, Ajusta(DMMain.FloatToStrSinComa(QMModelo303C68.AsFloat, 2, 17, 'N'), 'I', 17, '0')); // Resultado - Exclusivamente para sujetos pasivos que tributan conjuntamente con la administracion ... [68]
        Write(f, Ajusta(DMMain.FloatToStrSinComa(QMModelo303C69.AsFloat, 2, 17, 'N'), 'I', 17, '0')); // Resultado - Resultado ( [66] + [77] /* ** (En 2021) - [67]** */ - [78] + [68] ) [69]
        Write(f, Ajusta(DMMain.FloatToStrSinComa(QMModelo303C70.AsFloat, 2, 17, 'N'), 'I', 17, '0')); // Resultado - A deducir [70]
        Write(f, Ajusta(DMMain.FloatToStrSinComa(QMModelo303C71.AsFloat, 2, 17, 'N'), 'I', 17, '0')); // Resultado - Resultado de la liquidacion (69 - 70) [71]
        Write(f, Ajusta('', 'D', 1, ' ')); // Declaracion complementaria
        Write(f, Ajusta('', 'D', 13, ' ')); // Numero de justificante anterior
        // Declaracion sin actividad
        if (QMModelo303ACTIVIDAD.AsInteger = 0) then
           Write(f, Ajusta(' ', 'D', 1, ' '))
        else
           Write(f, Ajusta('X', 'D', 1, ' ')); // Declaracion sin actividad

        // Devolucion BIC / SWIFT
        if (QMModelo303C71.AsFloat < 0) then
           Write(f, Ajusta(xDatosModelosHaciendaDECLARANTE_BIC.AsString, 'D', 11, ' '))
        else
           Write(f, Ajusta('', 'D', 11, ' '));

        Write(f, Ajusta(xDatosModelosHaciendaDECLARANTE_IBAN.AsString, 'D', 34, ' ')); // Domiciliacion/Devolucion - IBAN

        Write(f, Ajusta('', 'D', 17, ' ')); // Reservado para la AEAT
        Write(f, Ajusta('', 'D', 70, ' ')); // Devolucion - Banco/Bank Name
        Write(f, Ajusta('', 'D', 35, ' ')); // Devolucion - Direccion del Banco / Bank Address
        Write(f, Ajusta('', 'D', 30, ' ')); // Devolucion - Ciudad / City
        Write(f, Ajusta('', 'D', 2, ' ')); // Devolucion - Codigo Pais / Country Code

        // Solo si es devolucion
        if QMModelo303C71.AsFloat >= 0 then
           if ((Periodo = '1T') or (Periodo = '2T') or ((Periodo >= '01') and (Periodo <= '06'))) then
              Write(f, Ajusta('', 'D', 1, ' '))
           else
              Write(f, Ajusta('0', 'D', 1, ' '))
        else
        begin
           // Devolucion - Marca SEPA (blanco=Solo periodos 1T, 2T, 01 a 06, 0=Vacia, 1=Cta Espańa, 2=Union Europea SEPA, 3=Resto Paises)
           if ((Periodo = '1T') or (Periodo = '2T') or ((Periodo >= '01') and (Periodo <= '06'))) then
              Write(f, Ajusta('', 'D', 1, ' '))
           else
           if (Trim(xDatosModelosHaciendaDECLARANTE_IBAN.AsString) = '') then
              Write(f, Ajusta('0', 'D', 1, ' '))
           else
           if (Copy(xDatosModelosHaciendaDECLARANTE_IBAN.AsString, 1, 2) = 'ES') then
              Write(f, Ajusta('1', 'D', 1, ' '))
           else
              // Los casos 2 y 3 no los voy a tratar.
              Write(f, Ajusta('2', 'D', 1, ' '));
        end;

        Write(f, Ajusta('', 'D', 445, ' ')); // Reservado para la AEAT

        Write(f, Ajusta('</T30303000>', 'I', 12, ' '));
        // WriteLn(f);

        { CNAE ???
        En el caso de no tener contenido, esta página 4 no debe incluirse en el diseńo de registro.
        }
        if ExoneradoPresentacionMod390 then
        begin
           Write(f, Ajusta('<T', 'D', 2, ' '));
           Write(f, Ajusta('303', 'D', 3, ' '));
           Write(f, Ajusta('04000', 'D', 5, ' '));
           Write(f, Ajusta('>', 'D', 1, ' '));
           Write(f, Ajusta(' ', 'D', 1, ' ')); // Indicador de página complementaria.

           Write(f, Ajusta(DMMain.FloatToStrSinComa(0, 0, 1, 'N'), 'I', 1, '0')); // Información adicional - Exclusivamente a cumplimentar en el último periodo  exonerados de la Declaración-resumen anual del IVA: B - Clave - Principal
           Write(f, Ajusta(' ', 'D', 4, ' ')); // Información adicional - Exclusivamente a cumplimentar en el último periodo  exonerados de la Declaración-resumen anual del IVA: C - Epígrafe IAE - Principal
           Write(f, Ajusta(DMMain.FloatToStrSinComa(0, 0, 1, 'N'), 'I', 1, '0')); // Información adicional - Exclusivamente a cumplimentar en el último periodo  exonerados de la Declaración-resumen anual del IVA: B - Clave - Otras - 1Ş
           Write(f, Ajusta(' ', 'D', 4, ' ')); // Información adicional - Exclusivamente a cumplimentar en el último periodo  exonerados de la Declaración-resumen anual del IVA: C - Epígrafe IAE - Otras - 1Ş
           Write(f, Ajusta(DMMain.FloatToStrSinComa(0, 0, 1, 'N'), 'I', 1, '0')); // Información adicional - Exclusivamente a cumplimentar en el último periodo  exonerados de la Declaración-resumen anual del IVA: B - Clave - Otras - 2Ş
           Write(f, Ajusta(' ', 'D', 4, ' ')); // Información adicional - Exclusivamente a cumplimentar en el último periodo  exonerados de la Declaración-resumen anual del IVA: C - Epígrafe IAE - Otras - 2Ş
           Write(f, Ajusta(DMMain.FloatToStrSinComa(0, 0, 1, 'N'), 'I', 1, '0')); // Información adicional - Exclusivamente a cumplimentar en el último periodo  exonerados de la Declaración-resumen anual del IVA: B - Clave - Otras - 3Ş
           Write(f, Ajusta(' ', 'D', 4, ' ')); // Información adicional - Exclusivamente a cumplimentar en el último periodo  exonerados de la Declaración-resumen anual del IVA: C - Epígrafe IAE - Otras - 3Ş
           Write(f, Ajusta(DMMain.FloatToStrSinComa(0, 0, 1, 'N'), 'I', 1, '0')); // Información adicional - Exclusivamente a cumplimentar en el último periodo exonerados de la Declaración-resumen anual del IVA: B - Clave - Otras - 4Ş
           Write(f, Ajusta(' ', 'D', 4, ' ')); // Información adicional - Exclusivamente a cumplimentar en el último periodo  exonerados de la Declaración-resumen anual del IVA: C - Epígrafe IAE - Otras - 4Ş
           Write(f, Ajusta(DMMain.FloatToStrSinComa(0, 0, 1, 'N'), 'I', 1, '0')); // Información adicional - Exclusivamente a cumplimentar en el último periodo  exonerados de la Declaración-resumen anual del IVA: B - Clave - Otras - 5Ş
           Write(f, Ajusta(' ', 'D', 4, ' ')); // Información adicional - Exclusivamente a cumplimentar en el último periodo  exonerados de la Declaración-resumen anual del IVA: C - Epígrafe IAE - Otras - 5Ş

           Write(f, Ajusta(' ', 'D', 1, ' ')); // Información adicional - Exclusivamente a cumplimentar en el último periodo exonerados de la Declaración-resumen anual del IVA: D - Marque si ha efectuado operaciones por las que tenga obligación de presentar la declaración anual de operaciones con terceras personas (X o blanco).

           Write(f, Ajusta(DMMain.FloatToStrSinComa(0, 2, 5, 'N'), 'I', 5, '0')); // Información de la tributación por razón de territorio: Álava [89]
           Write(f, Ajusta(DMMain.FloatToStrSinComa(0, 2, 5, 'N'), 'I', 5, '0')); // Información de la tributación por razón de territorio: Guipuzcoa [90]
           Write(f, Ajusta(DMMain.FloatToStrSinComa(0, 2, 5, 'N'), 'I', 5, '0')); // Información de la tributación por razón de territorio: Vizcaya [91]
           Write(f, Ajusta(DMMain.FloatToStrSinComa(0, 2, 5, 'N'), 'I', 5, '0')); // Información de la tributación por razón de territorio: Navarra [92]
           Write(f, Ajusta(DMMain.FloatToStrSinComa(0, 2, 5, 'N'), 'I', 5, '0')); // Información de la tributación por razón de territorio: Territorio común [107]

           with THYFIBQuery.Create(nil) do
           begin
              try
                 Close;
                 DataBase := DMMain.DataBase;
                 SQL.Text := 'SELECT SUM(C07) FROM CON_MODELO_303 WHERE EMPRESA = :EMPRESA AND EJERCICIO = :EJERCICIO AND CANAL = :CANAL';
                 Params.ByName['EMPRESA'].AsInteger := REntorno.Empresa;
                 Params.ByName['EJERCICIO'].AsInteger := REntorno.Ejercicio;
                 Params.ByName['CANAL'].AsInteger := REntorno.Canal;
                 ExecQuery;
                 Casilla80 := FieldByName['SUM'].AsFloat;
                 FreeHandle;
              finally
                 Free;
              end;
           end;

           // Write(f, Ajusta(DMMain.FloatToStrSinComa(0{QMModelo303C80.AsFloat}, 2, 17, 'N'), 'I', 17, '0')); // Información adicional - Exclusivamente a cumplimentar en el último periodo exonerados de la Declaración-resumen anual del IVA - Operaciones realizadas en el ejercicio - Operaciones en régimen especial del criterio de caja conforme art. 75 LIVA [81]
           Write(f, Ajusta(DMMain.FloatToStrSinComa(Casilla80, 2, 17, 'N'), 'I', 17, '0')); // Información adicional - Exclusivamente a cumplimentar en el último periodo exonerados de la Declaración-resumen anual del IVA - Operaciones realizadas en el ejercicio - Operaciones en régimen general [80]

           Write(f, Ajusta(DMMain.FloatToStrSinComa(0{QMModelo303C81.AsFloat}, 2, 17, 'N'), 'I', 17, '0')); // Información adicional - Exclusivamente a cumplimentar en el último periodo exonerados de la Declaración-resumen anual del IVA - Operaciones realizadas en el ejercicio - Operaciones en régimen especial del criterio de caja conforme art. 75 LIVA [81]
           Write(f, Ajusta(DMMain.FloatToStrSinComa(0{QMModelo303C93.AsFloat}, 2, 17, 'N'), 'I', 17, '0')); // Información adicional - Exclusivamente a cumplimentar en el último periodo exonerados de la Declaración-resumen anual del IVA - Operaciones realizadas en el ejercicio - Entregas intracomunitarias de bienes y servicios [93]
           Write(f, Ajusta(DMMain.FloatToStrSinComa(0{QMModelo303C94.AsFloat}, 2, 17, 'N'), 'I', 17, '0')); // Información adicional - Exclusivamente a cumplimentar en el último periodo exonerados de la Declaración-resumen anual del IVA - Operaciones realizadas en el ejercicio - Exportaciones y otras operaciones exentas con derecho a deducción [94]
           Write(f, Ajusta(DMMain.FloatToStrSinComa(0{QMModelo303C83.AsFloat}, 2, 17, 'N'), 'I', 17, '0')); // Información adicional - Exclusivamente a cumplimentar en el último periodo exonerados de la Declaración-resumen anual del IVA - Operaciones realizadas en el ejercicio - Operaciones exentas sin derecho a deducción [83]

           Write(f, Ajusta(DMMain.FloatToStrSinComa(0{QMModelo303C84.AsFloat}, 2, 17, 'N'), 'I', 17, '0')); // Información adicional - Exclusivamente a cumplimentar en el último periodo exonerados de la Declaración-resumen anual del IVA - Operaciones realizadas en el ejercicio - Operaciones no sujetas por reglas de localización (excepto las incluidas en la casilla 126) [84]
           Write(f, Ajusta(DMMain.FloatToStrSinComa(0{QMModelo303C125.AsFloat}, 2, 17, 'N'), 'I', 17, '0')); // Operaciones sujetas con inversión del sujeto pasivo [125]
           Write(f, Ajusta(DMMain.FloatToStrSinComa(0{QMModelo303C126.AsFloat}, 2, 17, 'N'), 'I', 17, '0')); // OSS. Operaciones no sujetas por reglas de localización acogidas a la OSS [126]
           Write(f, Ajusta(DMMain.FloatToStrSinComa(0{QMModelo303C127.AsFloat}, 2, 17, 'N'), 'I', 17, '0')); // OSS. Operaciones sujetas y acogidas a la OSS [127]
           Write(f, Ajusta(DMMain.FloatToStrSinComa(0{QMModelo303C128.AsFloat}, 2, 17, 'N'), 'I', 17, '0')); // Operaciones intragrupo valoradas conforme a lo dispuesto en los arts. 78 y 79 LIVA [128]
           Write(f, Ajusta(DMMain.FloatToStrSinComa(0{QMModelo303C86.AsFloat}, 2, 17, 'N'), 'I', 17, '0')); // Información adicional - Exclusivamente a cumplimentar en el último periodo exonerados de la Declaración-resumen anual del IVA - Operaciones realizadas en el ejercicio - Operaciones en régimen simplificado [86]
           Write(f, Ajusta(DMMain.FloatToStrSinComa(0{QMModelo303C95.AsFloat}, 2, 17, 'N'), 'I', 17, '0')); // Información adicional - Exclusivamente a cumplimentar en el último periodo exonerados de la Declaración-resumen anual del IVA - Operaciones realizadas en el ejercicio - Operaciones en régimen especial de la agricultura, ganadería y pesca [95]
           Write(f, Ajusta(DMMain.FloatToStrSinComa(0{QMModelo303C96.AsFloat}, 2, 17, 'N'), 'I', 17, '0')); // Información adicional - Exclusivamente a cumplimentar en el último periodo exonerados de la Declaración-resumen anual del IVA - Operaciones realizadas en el ejercicio - Operaciones realizadas por sujetos pasivos acogidos al régimen especial del recargo de equivalencia [96]
           Write(f, Ajusta(DMMain.FloatToStrSinComa(0{QMModelo303C97.AsFloat}, 2, 17, 'N'), 'I', 17, '0')); // Información adicional - Exclusivamente a cumplimentar en el último periodo exonerados de la Declaración-resumen anual del IVA - Operaciones realizadas en el ejercicio - Operaciones en Régimen especial de bienes usados, objetos de arte, antigüedades y objetos de colección [97]
           Write(f, Ajusta(DMMain.FloatToStrSinComa(0{QMModelo303C98.AsFloat}, 2, 17, 'N'), 'I', 17, '0')); // Información adicional - Exclusivamente a cumplimentar en el último periodo exonerados de la Declaración-resumen anual del IVA - Operaciones realizadas en el ejercicio - Operaciones en régimen especial de Agencias de Viajes [98]
           Write(f, Ajusta(DMMain.FloatToStrSinComa(0{QMModelo303C79.AsFloat}, 2, 17, 'N'), 'I', 17, '0')); // Información adicional - Exclusivamente a cumplimentar en el último periodo exonerados de la Declaración-resumen anual del IVA - Operaciones realizadas en el ejercicio - Entregas de bienes inmuebles no habituales, operaciones financieras y relativas al oro de inversión no habituales [79]
           Write(f, Ajusta(DMMain.FloatToStrSinComa(0{QMModelo303C99.AsFloat}, 2, 17, 'N'), 'I', 17, '0')); // Información adicional - Exclusivamente a cumplimentar en el último periodo exonerados de la Declaración-resumen anual del IVA - Operaciones realizadas en el ejercicio - Entregas de bienes de inversión [99]
           // [88] = ([80]+[81]+[93]+[94]+[83]+[84]+[125]+[126]+[127]+[128]+[86]+[95]+[96]+[97]+[98]-[79]-[99])
           Write(f, Ajusta(DMMain.FloatToStrSinComa(Casilla80{QMModelo303C88.AsFloat}, 2, 17, 'N'), 'I', 17, '0')); // Información adicional - Exclusivamente a cumplimentar en el último periodo exonerados de la Declaración-resumen anual del IVA - Operaciones realizadas en el ejercicio - Total volumen de operaciones ([80]+[81]+[93]+[94]+[83]+[84]+[125]+[126]+[127]+[128]+[86]+[95]+[96]+[97]+[98]-[79]-[99]) [88]

           Write(f, Ajusta('', 'D', 600, ' ')); // Reservado para la AEAT
           Write(f, Ajusta('</T30304000>', 'I', 12, ' '));
        end;

        Write(f, Ajusta('</T', 'D', 3, ' '));
        Write(f, Ajusta('303', 'D', 3, ' '));
        Write(f, Ajusta('0', 'D', 1, ' '));
        Write(f, Ajusta(REntorno.EjercicioStr, 'I', 4, '0'));
        Write(f, Ajusta(Periodo, 'I', 2, '0'));
        Write(f, Ajusta('0000>', 'D', 5, ' '));
        // WriteLn(f);
     end;
     CloseFile(f);
  end;
end;

procedure TDMRModelosHacienda.ExportarMod303_2022(aTipoDeclaracion: integer; ExoneradoPresentacionMod390, VolumenAnualDistintoCero: boolean);
var
  f : TextFile;
  Archivo : string;
  Tipo_Declaracion : string;
  Periodo : string;
  Casilla80 : double;
begin
  { TODO : Ver cómo rellenar Tipo_Declaracion }
  // Tipo de Declaracion
  // C - Solicitud de compensación
  // D - Devolucion
  // G - Cuenta corriente tributaria-ingreso
  // I (ingreso)
  // N - Sin actividad/resultado cero
  // V - Cuenta corriente triguraria-devolucion
  // U - Domiciliacion del intgreso en CCC
  case aTipoDeclaracion of
     0: Tipo_Declaracion := 'C';
     1: Tipo_Declaracion := 'D';
     2: Tipo_Declaracion := 'G';
     3: Tipo_Declaracion := 'I';
     4: Tipo_Declaracion := 'N';
     5: Tipo_Declaracion := 'V';
     6: Tipo_Declaracion := 'U';
  end;

  Periodo := QMModelo303Periodo.AsString;
  {Si el periodo es trimestral tiene otro formato}
  if QMModelo303Periodo.AsString = '13' then
     Periodo := '1T';
  if QMModelo303Periodo.AsString = '14' then
     Periodo := '2T';
  if QMModelo303Periodo.AsString = '15' then
     Periodo := '3T';
  if QMModelo303Periodo.AsString = '16' then
     Periodo := '4T';

  Archivo := Format('Modelo303-%s-%d-%s.txt', [REntorno.CifEmpresa, REntorno.Ejercicio, Periodo]);
  if MySaveDialog(Archivo, 'TXT', '', 'DMRModelosHacienda-Mod303') then
  begin
     AssignFile(f, Archivo);
     Rewrite(f);
     with QMModelo303 do
     begin
        Rewrite(f);
        // A cumplimentar por las entidades desarrolladoras (EEDD)
        Write(f, Ajusta('<T', 'D', 2, ' '));
        Write(f, Ajusta('303', 'D', 3, ' '));
        Write(f, Ajusta('0', 'D', 1, ' '));
        Write(f, Ajusta(REntorno.EjercicioStr, 'I', 4, '0'));
        Write(f, Ajusta(Periodo, 'I', 2, '0'));
        Write(f, Ajusta('0000>', 'D', 5, ' '));
        Write(f, Ajusta('<AUX>', 'D', 5, ' '));
        Write(f, Ajusta('', 'D', 70, ' ')); // Reservado para la Administración. Rellenar con blancos
        Write(f, Ajusta('', 'D', 4, ' ')); // Versión del Programa
        Write(f, Ajusta('', 'D', 4, ' ')); // Reservado para la Administración. Rellenar con blancos
        Write(f, Ajusta('', 'D', 9, ' ')); // NIF Empresa Desarrollo
        Write(f, Ajusta('', 'D', 213, ' ')); // Reservado para la Administración. Rellenar con blancos
        Write(f, Ajusta('</AUX>', 'D', 6, ' '));

        // Contenido del fichero. Aquí se debe incluir el contenido de las páginas correspondientes a la declaración según el formato descrito para cada página en este mismo documento

        Write(f, Ajusta('<T', 'D', 2, ' '));
        Write(f, Ajusta('303', 'D', 3, ' '));
        Write(f, Ajusta('01000', 'D', 5, ' '));
        Write(f, Ajusta('>', 'D', 1, ' '));
        Write(f, Ajusta(' ', 'D', 1, ' '));
        Write(f, Ajusta(Tipo_Declaracion, 'D', 1, ' '));
        Write(f, Ajusta(Trim(xDatosModelosHaciendaDECLARANTE_NIF.AsString), 'D', 9, ' '));
        Write(f, Ajusta(xDatosModelosHaciendaDECLARANTE_NOMBRE.AsString, 'D', 80, ' '));
        Write(f, Ajusta(REntorno.EjercicioStr, 'I', 4, '0'));
        Write(f, Ajusta(Periodo, 'I', 2, '0'));
        Write(f, Ajusta('2', 'I', 1, ' ')); // Identificación (1) - Tributación exclusivamente foral. Sujeto pasivo que tributa exclusivamente a una Administración tributaria Foral con IVA a la importación liquidado por la Aduana pendiente de ingreso (1 si, 2 no)
        // Identificación (1) - Sujeto pasivo inscrito en el Registro de devolución mensual (art. 30 RIVA)
        if (xDatosModelosHaciendaDEVOLUCION_MENSUAL_M303.AsInteger = 1) then
           Write(f, Ajusta('1', 'I', 1, ' '))
        else
           Write(f, Ajusta('2', 'I', 1, ' '));

        Write(f, Ajusta('3', 'I', 1, ' ')); // Identificación (1) - Sujeto pasivo que tributa exclusivamente en régimen simplificado (1 si, 2 si y no, 3 no)
        Write(f, Ajusta('2', 'I', 1, ' ')); // Identificación (1) - Autoliquidación conjunta (1 si, 2 no)
        // Identificación (1) - Sujeto pasivo acogido al régimen especial del criterio de Caja (art. 163 undecies LIVA) (1 si, 2 no)
        if (REntorno.RECC = 0) then
           Write(f, Ajusta('2', 'I', 1, '0'))
        else
           Write(f, Ajusta('1', 'I', 1, '0'));
        Write(f, Ajusta('2', 'I', 1, ' ')); // Identificación (1) - Sujeto pasivo destinatario de operaciones acogidas al régimen especial del criterio de caja (1 si, 2 no)
        Write(f, Ajusta('2', 'I', 1, ' ')); // Identificación (1) - Opción por la aplicación de la prorrata especial (art. 103.Dos.1ş LIVA) (1 si, 2 no)
        Write(f, Ajusta('2', 'I', 1, ' ')); // Identificación (1) - Revocación de la opción por la aplicación de la prorrata especial (1 si, 2 no)
        Write(f, Ajusta('2', 'I', 1, ' ')); // Identificación (1) - Sujeto pasivo declarado en concurso de acreedores en el presente período de liquidación (1 si, 2 no)
        Write(f, Ajusta('', 'I', 8, '0')); // Identificación (1) - Fecha en que se dictó el auto de declaración de concurso // 00000000 si vacio?

        Write(f, Ajusta(' ', 'I', 1, ' ')); // Auto de declaracion de concurso dictado en el periodo (blanco NO, 1 SI Preconcursal, 2 SI Postconcursal)
        Write(f, Ajusta('2', 'I', 1, ' ')); // Identificación (1) - Sujeto pasivo acogido voluntariamente al SII (1 si, 2 no)

        // Identificación (1) - Sujeto pasivo exonerado de la Declaración-resumen anual del IVA, modelo 390
        //                      Solo 4T o 12 - 1=SI, 2=NO
        if ((Periodo <> '4T') and (Periodo <> '12')) then
           Write(f, Ajusta('0', 'I', 1, '0'))
        else
        begin
           if ExoneradoPresentacionMod390 then
              Write(f, Ajusta('1', 'I', 1, '0'))
           else
              Write(f, Ajusta('2', 'I', 1, '0'));
        end;

        // Identificación (1) - Sujeto pasivo con volumen anual de operaciones distinto de cero (art. 121 LIVA)
        //                      Solo 4T o 12 - 1=SI, 2=NO
        if (((Periodo <> '4T') and (Periodo <> '12')) or (not ExoneradoPresentacionMod390)) then
           Write(f, Ajusta('0', 'I', 1, '0'))
        else
        begin
           if VolumenAnualDistintoCero then
              Write(f, Ajusta('1', 'I', 1, '0'))
           else
              Write(f, Ajusta('2', 'I', 1, '0'));
        end;

