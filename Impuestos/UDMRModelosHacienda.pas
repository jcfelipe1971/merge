              Write(f, Ajusta('2', 'I', 1, '0'));
        end;

        // Identificación (1) - Sujeto pasivo con volumen anual de operaciones distinto de cero (art. 121 LIVA)
        //                      Solo 4T o 12 - 1=SI, 2=NO
        if (((Periodo <> '4T') and (Periodo <> '12'))) then
           Write(f, Ajusta('0', 'I', 1, '0'))
        else
        begin
           if VolumenAnualDistintoCero then
              Write(f, Ajusta('1', 'I', 1, '0'))
