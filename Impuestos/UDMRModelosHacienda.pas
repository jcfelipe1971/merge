        Write(f, Ajusta(DMMain.FloatToStrSinComa(QMModelo303C27.AsFloat, 2, 17, 'N'), 'I', 17, '0')); // IVA Devengado - Total cuota devengada ([152] + [03] + [155] + [06] + [09] + [11] + [13] + [15] + [158] + [18] + [21] + [24] + [26] ) [27]

        Write(f, Ajusta(DMMain.FloatToStrSinComa(QMModelo303C28.AsFloat, 2, 17, 'N'), 'I', 17, '0')); // IVA Deducible - por cuotas soportadas en oper. interiores corrientes - Base Imponible [28]
