procedure TDMRModelosHacienda.AbreCasillasModelo303(Ejercicio: smallint; Periodo: string);
var
  DesdeFecha, HastaFecha : TDateTime;

  procedure FiltraDataSet(DataSet: TFIBDataSetRO; DesdeFecha, HastaFecha: TDateTime);
  var
     i : integer;
  begin
     with DataSet do
     begin
        Close;
        Params.ByName['EMPRESA'].AsInteger := REntorno.Empresa;
        Params.ByName['CANAL'].AsInteger := REntorno.Canal;
        Params.ByName['INI_PERIODO'].AsDateTime := DesdeFecha;
        Params.ByName['FIN_PERIODO'].AsDateTime := HastaFecha;

        for i := 0 to FieldCount - 1 do
        begin
           if (Fields[i] is TFloatField) then
              TFloatField(Fields[i]).DisplayFormat := MascaraN;
           if (Fields[i] is TDateTimeField) then
              TDateTimeField(Fields[i]).DisplayFormat := ShortDateFormat;
        end;
        Open;
     end;
  end;

begin
  // El ejercicio debe ser natural y por esto no puedo utilizar la configuracion de periodos.
  // DameDesdeHastaPeriodo(Periodo, DesdeFecha, HastaFecha);

  if ((Periodo >= '01') and (Periodo <= '12')) then
  begin
     DesdeFecha := RecodeDate(DesdeFecha, Ejercicio, StrToInt(Periodo), 1);
     HastaFecha := RecodeDate(HastaFecha, Ejercicio, StrToInt(Periodo), DaysInAMonth(Ejercicio, StrToInt(Periodo)));
  end
  else
  if (Periodo = '13') then
  begin
     DesdeFecha := RecodeDate(DesdeFecha, Ejercicio, 1, 1);
     HastaFecha := RecodeDate(HastaFecha, Ejercicio, 3, DaysInAMonth(Ejercicio, 3));
  end
  else
  if (Periodo = '14') then
  begin
     DesdeFecha := RecodeDate(DesdeFecha, Ejercicio, 4, 1);
     HastaFecha := RecodeDate(HastaFecha, Ejercicio, 6, DaysInAMonth(Ejercicio, 6));
  end
  else
  if (Periodo = '15') then
  begin
     DesdeFecha := RecodeDate(DesdeFecha, Ejercicio, 7, 1);
     HastaFecha := RecodeDate(HastaFecha, Ejercicio, 9, DaysInAMonth(Ejercicio, 9));
  end
  else
  if (Periodo = '16') then
  begin
     DesdeFecha := RecodeDate(DesdeFecha, Ejercicio, 10, 1);
     HastaFecha := RecodeDate(HastaFecha, Ejercicio, 12, DaysInAMonth(Ejercicio, 12));
  end;

  DesdeFecha := RecodeTime(DesdeFecha, 0, 0, 0, 0);
  HastaFecha := RecodeTime(HastaFecha, 23, 59, 59, 999);

  FiltraDataSet(QMModelo303_C0103, DesdeFecha, HastaFecha);
  FiltraDataSet(QMModelo303_C0406, DesdeFecha, HastaFecha);
  FiltraDataSet(QMModelo303_C0709, DesdeFecha, HastaFecha);
  FiltraDataSet(QMModelo303_C1011, DesdeFecha, HastaFecha);
  FiltraDataSet(QMModelo303_C1213, DesdeFecha, HastaFecha);
  FiltraDataSet(QMModelo303_C1415, DesdeFecha, HastaFecha);
  FiltraDataSet(QMModelo303_C2829, DesdeFecha, HastaFecha);
  FiltraDataSet(QMModelo303_C3031, DesdeFecha, HastaFecha);
  FiltraDataSet(QMModelo303_C3233, DesdeFecha, HastaFecha);
  FiltraDataSet(QMModelo303_C3637, DesdeFecha, HastaFecha);
  FiltraDataSet(QMModelo303_C4041, DesdeFecha, HastaFecha);
  FiltraDataSet(QMModelo303_C59, DesdeFecha, HastaFecha);
  FiltraDataSet(QMModelo303_C60, DesdeFecha, HastaFecha);
  FiltraDataSet(QMModelo303_C61, DesdeFecha, HastaFecha);
end;

procedure TDMRModelosHacienda.ReCalcular390;
begin
  if ConfirmaMensaje(_('Se recalcularan los datos y se sobreescribiran los campos modificados manualmente. żDesea continuar?')) then
  begin
     with THYFIBQuery.Create(nil) do
     begin
        try
           Close;
           DataBase := DMMain.DataBase;
           SQL.Text := 'EXECUTE PROCEDURE C_MODELO_390 (:EMPRESA, :EJERCICIO, :CANAL, :DEVOLUCION_MENSUAL)';
           Params.ByName['EMPRESA'].AsInteger := REntorno.Empresa;
           Params.ByName['EJERCICIO'].AsInteger := REntorno.Ejercicio;
           Params.ByName['CANAL'].AsInteger := REntorno.Canal;
           Params.ByName['DEVOLUCION_MENSUAL'].AsInteger := xDatosModelosHaciendaDEVOLUCION_MENSUAL_M303.AsInteger;
           ExecQuery;
           FreeHandle;
        finally
           Free;
        end;
     end;

     QMModelo390.Close;
     QMModelo390.Open;
  end;
end;

