function TDMRModelosHacienda.Declarado340_op_intracomunitarias: string;
var
  nif_declarado : string;
  nif_declarado_intra : string;
  ClaveTipoLibro : string;
  ClaveOperacion : string;
  ClaveDeDeclarado : string;
  FechaExpedicion : string;
  FechaOperacion : string;
  Pais : string;
  TipoIdentificacion : string;
  BaseImponible : double;
  CuotaImpuesto : double;
  TotalFacturas : double;
  PorcImpuesto : double;
begin
  BaseImponible := xModelo340_Op_IntracomunitariasB_IMPONIBLE.AsFloat;
  CuotaImpuesto := xModelo340_Op_IntracomunitariasI_IVA.AsFloat + xModelo340_Op_IntracomunitariasI_REC.AsFloat;
  PorcImpuesto := xModelo340_Op_IntracomunitariasP_IVA.AsFloat;
  if (xModelo340_Op_IntracomunitariasPAIS.AsString = 'ESP') then
  begin
     {tomo los 9 ultimos caracteres porque a veces ponen ES antes de nif (ESX3249299E)}
     nif_declarado := ajusta(Trim(Copy(Trim(xModelo340_Op_IntracomunitariasNIF.AsString), Length(Trim(xModelo340_Op_IntracomunitariasNIF.AsString)) - 8, 9)), 'D', 9, '0');
     nif_declarado_intra := ajusta(' ', 'D', 20, ' ');
     Pais := xModelo340_Op_IntracomunitariasPAIS_C2.AsString;
     TipoIdentificacion := '1';
  end
  else
  begin
     nif_declarado := ajusta(' ', 'D', 9, ' ');
     nif_declarado_intra := ajusta(Trim(xModelo340_Op_IntracomunitariasNIF.AsString), 'D', 20, ' '); {Pais (2 pos.)+Nro (15 pos.)+ Blanco (3 pos.)}
     Pais := xModelo340_Op_IntracomunitariasPAIS_C2.AsString;
     {Suiza, Vaticano y Monaco tiene un trato especial}
     if ((xModelo340_Op_IntracomunitariasPERTENECE_CEE.AsInteger = 1) and
        (xModelo340_Op_IntracomunitariasPAIS.AsString <> 'CHE') and
        (xModelo340_Op_IntracomunitariasPAIS.AsString <> 'VAT') and
        (xModelo340_Op_IntracomunitariasPAIS.AsString <> 'MCO')) then
        TipoIdentificacion := '2'
     else
        TipoIdentificacion := '6';
  end;

  if (xModelo340_Op_IntracomunitariasSIGNO.AsString = 'R') then
  begin
     ClaveTipoLibro := 'U'; {Libro de registro de determinadas operaciones intracomunitarias}
     ClaveDeDeclarado := 'R'; {Remitente de la factura}
  end
  else
  begin
     ClaveTipoLibro := 'U'; {Libro de registro de determinadas operaciones intracomunitarias}
     ClaveDeDeclarado := 'D'; {Destinatario de la factura}
  end;

  if (xModelo340_Op_IntracomunitariasADQUISICION.AsInteger = 1) then
  begin
     {Especial para Fercam}
     if (CuotaImpuesto = 0) then
     begin
        if (xModelo340_Op_IntracomunitariasDOC_FECHA.AsDateTime < EncodeDate(2010, 07, 01)) then
           PorcImpuesto := 16
        else
        if ((xModelo340_Op_IntracomunitariasDOC_FECHA.AsDateTime >= EncodeDate(2010, 07, 01)) and (xModelo340_Op_IntracomunitariasDOC_FECHA.AsDateTime < EncodeDate(2012, 09, 01))) then
           PorcImpuesto := 18
        else
           PorcImpuesto := 21;
        CuotaImpuesto := Round(BaseImponible * PorcImpuesto) / 100;
        {Prueba parece que las autofacturas no tienen que llevar el porcentaje per si la base y la cuota}
        PorcImpuesto := 0;
     end;
  end;

  ClaveOperacion := ' '; { HAY QUE VER QUE PONER ACA}

  TotalFacturas := BaseImponible + CuotaImpuesto;

  FechaExpedicion := FormatDateTime('yyyymmdd', xModelo340_Op_IntracomunitariasFECHA_REGISTRO.AsDateTime);
  FechaOperacion := FormatDateTime('yyyymmdd', xModelo340_Op_IntracomunitariasDOC_FECHA.AsDateTime);

  {cuando la fecha de operación sea mayor a la de expedición las iguales - Fercam}
  if (xModelo340_Op_IntracomunitariasDOC_FECHA.AsDateTime > xModelo340_Op_IntracomunitariasFECHA_REGISTRO.AsDateTime) then
     FechaOperacion := FechaExpedicion;

  Result := '2340' + xModelo340_Op_IntracomunitariasEJERCICIO.AsString +
     ajusta(nif_declarante, 'D', 9, '0') +
     nif_declarado +
     ajusta(' ', 'D', 9, ' ') + {NIF representante legal de menot de 14}
     ajusta(QuitaCaracteresNoValidos(xModelo340_Op_IntracomunitariasNOMBRE.AsString), 'D', 40, ' ') + {NIF del declarado}
     ajusta(Pais, 'D', 2, ' ') + {Pais}
     ajusta(TipoIdentificacion, 'I', 1, '0') + {Clave nro de identificacion (1-6)}
     nif_declarado_intra +
     ajusta(ClaveTipoLibro, 'D', 1, ' ') +
     ajusta(ClaveOperacion, 'D', 1, ' ') +
     FechaExpedicion +
     FechaOperacion +
     FormatFloat('000', Abs(Trunc(PorcImpuesto))) + FormatFloat('00', (Abs(PorcImpuesto - Trunc(PorcImpuesto)) * 100)) +
     FormatFloat340(BaseImponible, 2, 14) +
     FormatFloat340(CuotaImpuesto, 2, 14) +
     FormatFloat340(TotalFacturas, 2, 14) +
     FormatFloat340(0, 2, 14) + {Base imponible a coste}

     ajusta(xModelo340_Op_IntracomunitariasDOC_TIPO.AsString + '-' + xModelo340_Op_IntracomunitariasDOC_SERIE.AsString + '/' + xModelo340_Op_IntracomunitariasDOC_NUMERO.AsString, 'D', 40, ' ') + {Identificacion de la factura}
     ajusta(xModelo340_Op_IntracomunitariasREGISTRO.AsString + '.' + xModelo340_Op_IntracomunitariasLINEA.AsString, 'D', 18, ' ') + {Numero de registro}

     {Hasta acá son todos los registros iguales}

     'B' + {Tipo de operacion intracomunitaria}
     ClaveDeDeclarado + {Destinatario o Remitente de la factura (D/R)}
     ajusta(Pais, 'D', 2, ' ') + {Codigo de estado miembro}
     '000' + {Plazo de la operacion}
     ajusta(' ', 'D', 35, ' ') + {Descripcion de los bienes}
     ajusta(xModelo340_Op_IntracomunitariasDIRECCION.AsString, 'D', 40, ' ') + {Direccion del operador intracomunitario - Domicilio}
     ajusta(xModelo340_Op_IntracomunitariasPROVINCIA.AsString, 'D', 22, ' ') + {Direccion del operador intracomunitario - Poblacion}
     ajusta(xModelo340_Op_IntracomunitariasC_POSTAL.AsString, 'D', 10, ' ') + {Direccion del operador intracomunitario - Codigo Postal}
     ajusta(' ', 'D', 135, ' ') + {Otras facturas documentacion}
     ajusta(' ', 'D', 16, ' '); {Blancos}
end;

procedure TDMRModelosHacienda.FormatoModelo347(Ejercicio: integer);
var
  Archivo : string;      // Nombre del Fichero
  NFic : TextFile;       // Fichero
  sReg : string;         // Registro
begin
  Archivo := Format('Modelo347-%s-%d.txt', [REntorno.CifEmpresa, REntorno.Ejercicio]);
  if MySaveDialog(Archivo, 'TXT', '', 'DMRModelosHacienda-Mod347') then
  begin
     AssignFile(NFic, Archivo);
     // Inicializamos el fichero
     {$I+}
     Rewrite(Nfic);
     {$I-}

     // Grabamos el declarante
     sReg := UpperCase(declarante(Ejercicio));
     sReg := ajusta(sReg, 'D', 500, ' '); {dji lrk kri - deben ser registros de 500 car.}
     WriteLn(NFic, sReg);

     // Grabamos los declarados
     with xModelo347 do
     begin
        Close;
        Params.ByName['EMPRESA'].AsInteger := REntorno.Empresa;
        Params.ByName['EJERCICIO'].AsInteger := Ejercicio;
        Params.ByName['CANAL'].AsInteger := REntorno.Canal;
        Open;

        while not EOF do
        begin
           sReg := UpperCase(declarado(Ejercicio));
           sReg := ajusta(sReg, 'D', 500, ' '); {dji lrk kri - deben ser registros de 500 car.}
           WriteLn(NFic, sReg);
           Next;
        end;
     end;

     // Cerramos el fichero
     CloseFile(NFic);
     ShowMessage(_('Exportación realizada con éxito'));
  end;
end;

function TDMRModelosHacienda.Declarante(Ejercicio: integer): string;
var
  num_declarados : integer;
  ImporteTotal, Importe : double;
begin
  with xTercero do
  begin
     Close;
     Params.ByName['TERCERO'].AsInteger := REntorno.Tercero;
     Open;
  end;

  with THYFIBQuery.Create(nil) do
  begin
     try
        Close;
        DataBase := DMMain.DataBase;
        SQL.Add(' SELECT COUNT(*) AS NUM_DECLARADOS, SUM(IMPORTE_TOTAL_PRESENTAR) AS IMPORTE FROM CON_MODELO_347 ');
        SQL.Add(' WHERE ');
        SQL.Add(' EMPRESA = :EMPRESA AND ');
        SQL.Add(' EJERCICIO = :EJERCICIO AND ');
        SQL.Add(' CANAL = :CANAL AND ');
        SQL.Add(' ((IMPORTE_T1_PRESENTAR <> 0) OR (IMPORTE_T2_PRESENTAR <> 0) OR (IMPORTE_T3_PRESENTAR <> 0) OR (IMPORTE_T4_PRESENTAR <> 0)) ');
        Params.ByName['EMPRESA'].AsInteger := REntorno.Empresa;
        Params.ByName['EJERCICIO'].AsInteger := Ejercicio;
        Params.ByName['CANAL'].AsInteger := REntorno.Canal;
        ExecQuery;
        num_declarados := FieldByName['NUM_DECLARADOS'].AsInteger;
        ImporteTotal := FieldByName['IMPORTE'].AsFloat;
        FreeHandle;
     finally
        Free;
     end;
  end;

  nif_declarante := Trim(xDatosModelosHaciendaDECLARANTE_NIF.AsString);
  // dji lrk kri - Tomo los últimos 9 digitos, por si le puso el pais adelante (ESB62846530)
  if (Length(nif_declarante) > 9) then
     nif_declarante := Copy(nif_declarante, Length(nif_declarante) - 8, 9);

  Importe := Round(ImporteTotal * 100) / 100;

  Result := '1347' + IntToStr(Ejercicio) +
     ajusta(nif_declarante, 'I', 9, '0') +
     ajusta(QuitaCaracteresNoValidos(xDatosModelosHaciendaDECLARANTE_NOMBRE.AsString), 'D', 40, ' ') +
     'T' + // [T] Telematica - [C] en soporte 'D' +
     ajusta(xDatosModelosHaciendaPRESENTADOR_TELEFONO.AsString, 'D', 9, '0') + //Telefono contacto
     ajusta(QuitaCaracteresNoValidos(xDatosModelosHaciendaPRESENTADOR_NOMBRE.AsString), 'D', 40, ' ') +   // Contacto
     // ajusta((xTercero.FieldByName('APELLIDOS').AsString+' '+xTercero.FieldByName('NOMBRE').AsString),'I',40,' ')+ // Contacto
     { TODO : Agregar configuracion para este contador en Parámetros Hacienda. }
     '347000000' + IntToStr(Ejercicio) + // número de justificante correspondiente a la declaración
     '  ' +                                // DECLARACION COMPLEMENTARIA O SUSTITUTIVA
     '0000000000000' +                     // NUMERO DE JUSTIFICANTE DE LA DECLARACIÓN ANTERIOR
     FormatFloat('000000000', num_declarados) +
     FormatFloat340(Importe, 2, 16) +
     '000000000' +                         // NUMERO TOTAL DE INMUEBLES.
     FormatFloat340(0, 2, 16) +            // IMPORTE TOTAL DE LAS OPERACIONES DE ARRENDAMIENTO DE LOCALES DE NEGOCIO
     ajusta(' ', 'D', 205, ' ') +          // Blancos
     ajusta(' ', 'D', 9, ' ') +            // NIF Representante Legal
     ajusta(' ', 'D', 88, ' ');            // Blancos

  ajusta(' ', 'D', 13, ' ');            // Sello electrónico
end;

function TDMRModelosHacienda.Declarado(Ejercicio: integer): string;
var
  Importe : double;
  Importe_T1 : double;
  Importe_T2 : double;
  Importe_T3 : double;
  Importe_T4 : double;
  Tercero : integer;
  InversionSujetoPasivo : string;
begin
  // Redondeamos a 2 decimales
  Importe := Round(xModelo347IMPORTE.AsFloat * 100) / 100;
  Importe_T1 := Round(xModelo347IMPORTE_T1.AsFloat * 100) / 100;
  Importe_T2 := Round(xModelo347IMPORTE_T2.AsFloat * 100) / 100;
  Importe_T3 := Round(xModelo347IMPORTE_T3.AsFloat * 100) / 100;
  Importe_T4 := Round(xModelo347IMPORTE_T4.AsFloat * 100) / 100;

  InversionSujetoPasivo := ' ';
  if xModelo347INVERSION_SUJETO_PASIVO.AsInteger = 1 then
     InversionSujetoPasivo := 'X';

  {
  with THYFIBQuery.Create(nil) do
  begin
     try
        Close;
        DataBase := DMMain.DataBase;
        SQL.Text := 'SELECT MIN(TERCERO) FROM SYS_TERCEROS WHERE NIF = ?NIF';
        Params.ByName['NIF'].AsString := xModelo347NIF.AsString;
        ExecQuery;
        Tercero := FieldByName['MIN'].AsInteger;
        FreeHandle;
        FreeHandle;
     finally
        Free;
     end;
  end;
  }
  Tercero := xModelo347TERCERO.AsInteger;

  with xTercero do
  begin
     Close;
     Params.ByName['TERCERO'].AsInteger := Tercero;
     Open;
  end;

  // Si es intracomunitario, no hay que poner los nif del declarado y hay que poner pais en 2 digitos
  if (Tercero <> 0) and (xTercero.FieldByName('PAIS').AsString <> 'ESP') then
  begin
     Result := '2347' + IntToStr(Ejercicio) +
        ajusta(nif_declarante, 'D', 9, '0') +
        '         ' +                       {Si es intracomunitario no se rellena el nif}
        '         ' +                       // NIF Representante legal
        ajusta(QuitaCaracteresNoValidos(xTercero.FieldByName('NOMBRE_R_SOCIAL').AsString), 'D', 40, ' ') +
        'D' +
        '99' + {la provincia siempre debe ser 99 en no espańoles}
        ajusta(xTercero.FieldByName('PAIS_C2').AsString, 'D', 2, ' ');        // Código País 2 digitos
  end
  else
  begin
     Result := '2347' + IntToStr(Ejercicio) +
        ajusta(nif_declarante, 'D', 9, '0') +
        {dji lrk kri - Tomo los últimos 9 digitos, por si le puso el pais adelante (ESB62846530)}
        ajusta(Copy(Trim(xModelo347NIF.AsString), Length(Trim(xModelo347NIF.AsString)) - 8, 9), 'D', 9, '0') +
        '         ' +                       // NIF Representante legal
        ajusta(QuitaCaracteresNoValidos(xModelo347NOMBRE_R_SOCIAL.AsString), 'D', 40, ' ') +
        'D' +
        ajusta(Copy(xModelo347CODIGO_POSTAL.AsString, 1, 2), 'D', 2, '0') +
        '  '; {'000' + dji lrk kri - 070221 Cambio de hacienda}        // Código País
  end;

  Result := Result +
     ' ' +                                           // Blancos
     ajusta(xModelo347SIGNO.AsString, 'I', 1, ' ') + // Clave (A-Adquisiciones de bienes; B-Entrega de bienes; C-Cobros por cuenta de terceros; D-Adquisiciones de bienes...; E-Subvenciones; F-Ventas agencia viaje; G-Compras agencia viaje)
     {Importe anual de las operaciones}
     FormatFloat340(Importe, 2, 16) + {Importe de las operaciones}
     ' ' + {Operaciones de Seguros}
     ' ' + {Arrendamiento de Local}
     DMMain.FloatToStrSinComa(0, 2, 15, '0') + {Importe percibido en Metalico}
     FormatFloat340(0, 2, 16) + {Importe transm. inmuebles}
     '0000' + {Modificacion AEAT 2010 - Ejercicio: Se consignaran las cuatro cifras del ejercicio en el que se hubieran declarado las operaciones que dan origen al cobro en metalico por importe superior a 6.000 euros.}
     {2012 - Se agregan los importes desglosados por trimestre}
     {Importe de las operaciones primer trimestre}
     FormatFloat340(Importe_T1, 2, 16) + {Importe de las operaciones}
     FormatFloat340(0, 2, 16) + {Importe transm. inmuebles primer trimestre}
     {Importe de las operaciones segundo trimestre}
     FormatFloat340(Importe_T2, 2, 16) + {Importe de las operaciones}
     FormatFloat340(0, 2, 16) + {Importe transm. inmuebles segundo trimestre}
     {Importe de las operaciones tercer trimestre}
     FormatFloat340(Importe_T3, 2, 16) + {Importe de las operaciones}
     FormatFloat340(0, 2, 16) + {Importe transm. inmuebles tercer trimestre}
     {Importe de las operaciones cuarto trimestre}
     FormatFloat340(Importe_T4, 2, 16) + {Importe de las operaciones}
     FormatFloat340(0, 2, 16) + {Importe transm. inmuebles cuarto trimestre}
     // Agregado 09/2014
     ajusta(' ', 'D', 17, ' ') + // NIF Operador comunitario - Pais(2) + NIF(15)
     ' ' + // Op. criterio de caja IVA - X Criterio de Caja ???
     InversionSujetoPasivo + // Op. inversion del sujeto pasivo - X si el sujeto pasivo es destinatario de la operacion.
     ' ' + // Op. con bienes vinculados al Regimen de Deposito distinto del aduanero. - X
     {Imp. anual operaciones devengadas criterio de caja IVA}
     FormatFloat340(0, 2, 16) + {Importe anual de las operaciones devengadas conforme al criterio de caja del IVA}
     '000000' + {Código de convocatoria de la subvención o ayuda en Base de Datos Nacional de Subvenciones (BDNS). (Solo se rellena en caso de CLAVE=E}
     ajusta(' ', 'D', 194, ' '); {Blancos}
end;

procedure TDMRModelosHacienda.FormatoModelo349(Periodo: string; ATipoDeclaracion, ANroDeclaracion: integer; ADeclaracionSustitutiva: boolean; NroDeclaracionSustituir: integer);
var
  Archivo : string;      // Nombre del Fichero
  NFic : TextFile;       // Fichero
  sReg : string;         // Registro
  aux : string;
begin
  ClavePeriodo(Periodo);

  {Si el periodo es trimestral tiene otro formato}
  if QMModelo303Periodo.AsString = '13' then
     aux := '1T';
  if QMModelo303Periodo.AsString = '14' then
     aux := '2T';
  if QMModelo303Periodo.AsString = '15' then
     aux := '3T';
  if QMModelo303Periodo.AsString = '16' then
     aux := '4T';

  Archivo := Format('Modelo349-%s-%d-%s.txt', [REntorno.CifEmpresa, REntorno.Ejercicio, aux]);
  if MySaveDialog(Archivo, 'TXT', '', 'DMRModelosHacienda-Mod349') then
  begin
     AssignFile(NFic, Archivo);
     // Inicializamos el fichero
    {$I+}
     Rewrite(Nfic);
    {$I-}

     // Abro declarados para poder contar cuantos son
     with xModelo349_Dec do
     begin
        Close;
        Params.ByName['EMPRESA'].AsInteger := REntorno.Empresa;
        Params.ByName['EJERCICIO'].AsInteger := REntorno.Ejercicio;
        Params.ByName['CANAL'].AsInteger := REntorno.Canal;
        Params.ByName['PERIODO'].AsString := Periodo;
        Open;
        FetchAll;
     end;

     // Abro rectificados para poder contar cuantos son
     with xModelo349_Rect do
     begin
        Close;
        Params.ByName['EMPRESA'].AsInteger := REntorno.Empresa;
        Params.ByName['EJERCICIO'].AsInteger := REntorno.Ejercicio;
        Params.ByName['CANAL'].AsInteger := REntorno.Canal;
        Params.ByName['PERIODO'].AsString := Periodo;
        Open;
        FetchAll;
     end;

     // Grabamos el declarante
     sReg := UpperCase(Declarante349(Periodo, ATipoDeclaracion, ANroDeclaracion, ADeclaracionSustitutiva, NroDeclaracionSustituir));
     WriteLn(NFic, sReg);

     // Grabamos los declarados
     with xModelo349_Dec do
     begin
        while not EOF do
        begin
           sReg := UpperCase(Declarado349_Dec);
           WriteLn(NFic, sReg);
           Next;
        end;
     end;

     // Grabamos los rectificados
     with xModelo349_Rect do
     begin
        while not EOF do
        begin
           sReg := UpperCase(Declarado349_Rect);
           WriteLn(NFic, sReg);
           Next;
        end;
     end;

     // Cerramos el fichero
     CloseFile(NFic);
     ShowMessage(_('Exportación realizada con éxito'));
  end;
end;

procedure TDMRModelosHacienda.ClavePeriodo(Periodo: string);
begin
  Periodo_Hacienda := Periodo;
  if (Periodo = '13') then
     Periodo_Hacienda := '1T'
  else if (Periodo = '14') then
     Periodo_Hacienda := '2T'
  else if (Periodo = '15') then
     Periodo_Hacienda := '3T'
  else if (Periodo = '16') then
     Periodo_Hacienda := '4T'
  else if (Periodo = '19') then
     Periodo_Hacienda := '0A';
end;

function TDMRModelosHacienda.QuitaCaracteresNoValidos(s: string): string;
var
  i : integer;
begin
  /// Procedimiento que dado un string devuelve solo letras, numeros y los caracteres '.', ',', '-' y '&'.
  /// Si las vocales son acentuadas, devuelve su equivalente sin acentuar
  /// Todo en mayusculas y 'Trimado'
  /// Si quedan dos espacios juntos solo deja uno.
  Result := '';
  s := Trim(UpperCase(s));
  for i := 1 to Length(s) do
  begin
     if (s[i] in ['A'..'Z', '0'..'9', '.', ',', '-', '&']) then
        Result := Result + s[i]
     else
     if ((s[i] = 'Á') or (s[i] = 'Ŕ')) then
        Result := Result + 'A'
     else
     if ((s[i] = 'É') or (s[i] = 'Č')) then
        Result := Result + 'E'
     else
     if ((s[i] = 'Í') or (s[i] = 'Ě')) then
        Result := Result + 'I'
     else
     if ((s[i] = 'Ó') or (s[i] = 'Ň')) then
        Result := Result + 'O'
     else
     if ((s[i] = 'Ú') or (s[i] = 'Ů')) then
        Result := Result + 'U'
     else
     if (s[i] = 'Ń') then
        Result := Result + 'Ń'
     else
     if (s[i] = 'Ç') then
        Result := Result + 'Ç'
     else
     if (Length(Result) > 0) then
        if (Result[Length(Result)] <> ' ') then
           Result := Result + ' ';
  end;
end;

function TDMRModelosHacienda.Declarante349(Periodo: string; ATipoDeclaracion, ANroDeclaracion: integer; ADeclaracionSustitutiva: boolean; NroDeclaracionSustituir: integer): string;
var
  num_declarados : integer;
  ImporteTotal, Importe : double;
  num_declarados_rect : integer;
  ImporteTotalRect, ImporteRect : double;
  TipoDeclaracion : string;
  DeclaracionSustitutiva : string;
  PrefijoDeclaracionSustitutiva : string;
begin
  with xTercero do
  begin
     Close;
     Params.ByName['TERCERO'].AsInteger := REntorno.Tercero;
     Open;
  end;

  with SPTotales349 do
  begin
     Close;
     SQL.Text :=
        'select sum(importe) as importe from c_modelo_349_lst(?empresa, ?ejercicio, ?canal, ?periodo) where tipo = 0';
     Params.ByName['EMPRESA'].AsInteger := REntorno.Empresa;
     Params.ByName['EJERCICIO'].AsInteger := REntorno.Ejercicio;
     Params.ByName['CANAL'].AsInteger := REntorno.Canal;
     Params.ByName['PERIODO'].AsString := Periodo;
     ExecQuery;
     ImporteTotal := FieldByName['IMPORTE'].AsFloat;
     FreeHandle;
  end;

  with SPTotales349 do
  begin
     Close;
     SQL.Text :=
        'select sum(importe) as importe from c_modelo_349_lst(?empresa, ?ejercicio, ?canal, ?periodo) where tipo = 1';
     Params.ByName['EMPRESA'].AsInteger := REntorno.Empresa;
     Params.ByName['EJERCICIO'].AsInteger := REntorno.Ejercicio;
     Params.ByName['CANAL'].AsInteger := REntorno.Canal;
     Params.ByName['PERIODO'].AsString := Periodo;
     ExecQuery;
     ImporteTotalRect := Abs(FieldByName['IMPORTE'].AsFloat);
     FreeHandle;
  end;

  num_declarados := xModelo349_Dec.RecordCount;
  num_declarados_rect := xModelo349_Rect.RecordCount;

  if (ATipoDeclaracion = 0) then
     TipoDeclaracion := 'C'
  else
  if (ATipoDeclaracion = 1) then
     TipoDeclaracion := 'T'
  else
     TipoDeclaracion := ' ';

  if (ADeclaracionSustitutiva) then
  begin
     DeclaracionSustitutiva := 'S';
     PrefijoDeclaracionSustitutiva := '349';
  end
  else
  begin
     DeclaracionSustitutiva := ' ';
     NroDeclaracionSustituir := 0;
     PrefijoDeclaracionSustitutiva := '000';
  end;

  Importe := ImporteTotal * 100;
  Importe := Round(Importe);
  Importe := Importe / 100;

  ImporteRect := ImporteTotalRect * 100;
  ImporteRect := Round(ImporteRect);
  ImporteRect := ImporteRect / 100;

  nif_declarante := Trim(xDatosModelosHaciendaDECLARANTE_NIF.AsString);

  Result := '1349' + REntorno.EjercicioStr +
     ajusta(nif_declarante, 'D', 9, '0') +
     ajusta(QuitaCaracteresNoValidos(xDatosModelosHaciendaDECLARANTE_NOMBRE.AsString), 'D', 40, ' ') +
     TipoDeclaracion +
     ajusta(xDatosModelosHaciendaPRESENTADOR_TELEFONO.AsString, 'D', 9, '0') +                            // Telefono contacto
     ajusta((QuitaCaracteresNoValidos(xDatosModelosHaciendaPRESENTADOR_NOMBRE.AsString)), 'D', 40, ' ') + // Contacto
     '349' + ajusta(IntToStr(ANroDeclaracion), 'I', 10, '0') +                                            // número de justificante correspondiente a la declaración
     ' ' + DeclaracionSustitutiva +                                                                       // DECLARACION COMPLEMENTARIA O SUSTITUTIVA
     PrefijoDeclaracionSustitutiva + ajusta(IntToStr(NroDeclaracionSustituir), 'I', 10, '0') +            // NUMERO DE JUSTIFICANTE DE LA DECLARACIÓN ANTERIOR
     Periodo_Hacienda +
     FormatFloat('000000000', num_declarados) +
     FormatFloat('0000000000000', Trunc(Importe)) +
     FormatFloat('00', (ImporteTotal - Trunc(Importe)) * 100) +

     FormatFloat('000000000', num_declarados_rect) + //Operadores con rectificaciones
     FormatFloat('0000000000000', Trunc(ImporteRect)) + //IMPORTE DE LAS RECTIFICACIONES
     FormatFloat('00', (ImporteTotalRect - Trunc(ImporteRect)) * 100) +

     ' ' +                                  //CAMBIO PERIODICIDAD
     ajusta(' ', 'D', 204, ' ') +           //Blancos y sello electrónico
     ajusta(' ', 'D', 9, ' ') +             //Representante legal
     ajusta(' ', 'D', 88, ' ') +            //Blancos
     ajusta(' ', 'D', 13, ' ');             //sello electrónico
end;

function TDMRModelosHacienda.Declarado349_Dec: string;
var
  Importe : double;
  nif_declarante : string;
  nif_declarado : string;
begin
  Importe := xModelo349_DecIMPORTE.AsFloat * 100;
  Importe := Round(Importe);
  Importe := Importe / 100;

  nif_declarante := Trim(xDatosModelosHaciendaDECLARANTE_NIF.AsString);
  {dji lrk kri - Tomo los últimos 9 digitos, por si le puso el pais adelante (ESB62846530)}
  if (Length(nif_declarante) > 9) then
     nif_declarante := Copy(nif_declarante, Length(nif_declarante) - 8, 9);

  nif_declarado := Trim(xModelo349_DecNIF.AsString);
  {dji lrk kri - Quito los primeros digotos si son los del pais (Portugal PT12345678X -> 12345678X)}
  if (Copy(nif_declarado, 1, 2) = xModelo349_DecCOD_PAIS.AsString) then
     nif_declarado := Copy(nif_declarado, 3, Length(nif_declarado) - 2);

  Result := '2349' + REntorno.EjercicioStr +
     ajusta(nif_declarante, 'D', 9, '0') +
     ajusta(' ', 'D', 58, ' ') +                        // Blancos
     ajusta(xModelo349_DecCOD_PAIS.AsString, 'D', 2, ' ') + // País
     ajusta(nif_declarado, 'D', 15, ' ') +     // NIF OPERADOR COMUNITARIO
     ajusta(QuitaCaracteresNoValidos(xModelo349_DecNOMBRE_R_SOCIAL.AsString), 'D', 40, ' ') +
     xModelo349_DecCLAVEOP.AsString +
     FormatFloat('00000000000', Trunc(Importe)) +
     FormatFloat('00', (xModelo349_DecIMPORTE.AsFloat - Trunc(Importe)) * 100) +
     ajusta(' ', 'D', 354, ' '); // Blancos
end;

function TDMRModelosHacienda.Declarado349_Rect: string;
var
  Importe : double;
  nif_declarante : string;
  nif_declarado : string;
begin
  Importe := Abs(xModelo349_RectIMPORTE.AsFloat * 100);
  Importe := Round(Importe);
  Importe := Importe / 100;

  nif_declarante := Trim(xDatosModelosHaciendaDECLARANTE_NIF.AsString);
  {dji lrk kri - Tomo los últimos 9 digitos, por si le puso el pais adelante (ESB62846530)}
  if (Length(nif_declarante) > 9) then
     nif_declarante := Copy(nif_declarante, Length(nif_declarante) - 8, 9);

  nif_declarado := Trim(xModelo349_RectNIF.AsString);
  {dji lrk kri - Quito los primeros digotos si son los del pais (Portugal PT12345678X -> 12345678X)}
  if (Copy(nif_declarado, 1, 2) = xModelo349_RectCOD_PAIS.AsString) then
     nif_declarado := Copy(nif_declarado, 3, Length(nif_declarado) - 2);

  Result := '2349' + REntorno.EjercicioStr +
     ajusta(nif_declarante, 'D', 9, '0') +
     ajusta(' ', 'D', 58, ' ') +                        // Blancos
     ajusta(xModelo349_RectCOD_PAIS.AsString, 'D', 2, ' ') + //País
     ajusta(nif_declarado, 'D', 15, ' ') +     // NIF OPERADOR COMUNITARIO
     ajusta(QuitaCaracteresNoValidos(xModelo349_RectNOMBRE_R_SOCIAL.AsString), 'D', 40, ' ') +
     xModelo349_RectCLAVEOP.AsString +
     ajusta(' ', 'D', 13, ' ') + // Blancos
     REntorno.EjercicioStr + // Ejercicio
     Periodo_Hacienda + // Periodo
     '0000000000000' + // Base Imponible Rectificada
     FormatFloat('00000000000', Trunc(Importe)) +
     FormatFloat('00', (Abs(xModelo349_RectIMPORTE.AsFloat) - Trunc(Importe)) * 100) + // Base Imponible Anterior
     ajusta(' ', 'D', 322, ' '); // Blancos
end;

