        if (xDatosModelosHaciendaDEVOLUCION_MENSUAL_M303.AsInteger = 0) then
           Write(f, Ajusta('2', 'I', 1, '0'))
        else
           Write(f, Ajusta('1', 'I', 1, '0'));
        Write(f, Ajusta('3', 'I', 1, '0')); // Tributa exclusivamente en regimen simplificado (1 si, 2 si y no, 3 no)
