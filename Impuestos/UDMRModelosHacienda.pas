        'C.CANAL=?CANAL AND ' +
        'C.MODO=3 AND ' + {las intracomunitarias SI}
        'C.DOC_SERIE<>''CI'' AND ' +
        '(C.SIGNO=''R'' OR (C.SIGNO=''S'' AND D.LINEA=2)) AND ' +
        'C.FECHA_REGISTRO BETWEEN ?DESDE AND ?HASTA ' +
        'ORDER BY C.SIGNO, C.REGISTRO, D.LINEA';
