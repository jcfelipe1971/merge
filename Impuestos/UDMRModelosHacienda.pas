procedure TDMRModelosHacienda.ExportarMod303(TipoDeclaracion: integer; EActividadPrincipal, EEpigrafeIAEPrincipal, EActividad1, EEpigrafeIAE1, EActividad2, EEpigrafeIAE2, EActividad3, EEpigrafeIAE3, EActividad4, EEpigrafeIAE4, EActividad5, EEpigrafeIAE5: string; ExoneradoPresentacionMod390: boolean = False; VolumenAnualDistintoCero: boolean = True);
begin
  if (REntorno.Ejercicio >= 2026) then
     ExportarMod303_2026(TipoDeclaracion,
        EActividadPrincipal, EEpigrafeIAEPrincipal, EActividad1, EEpigrafeIAE1, EActividad2, EEpigrafeIAE2, EActividad3, EEpigrafeIAE3,
        EActividad4, EEpigrafeIAE4, EActividad5, EEpigrafeIAE5, ExoneradoPresentacionMod390, VolumenAnualDistintoCero)
  else
  if (REntorno.Ejercicio >= 2025) then
     ExportarMod303_2025(TipoDeclaracion,
        EActividadPrincipal, EEpigrafeIAEPrincipal, EActividad1, EEpigrafeIAE1, EActividad2, EEpigrafeIAE2, EActividad3, EEpigrafeIAE3,
        EActividad4, EEpigrafeIAE4, EActividad5, EEpigrafeIAE5, ExoneradoPresentacionMod390, VolumenAnualDistintoCero)
  else
  if (REntorno.Ejercicio >= 2024) then
     ExportarMod303_2024(TipoDeclaracion,
        EActividadPrincipal, EEpigrafeIAEPrincipal, EActividad1, EEpigrafeIAE1, EActividad2, EEpigrafeIAE2, EActividad3, EEpigrafeIAE3,
        EActividad4, EEpigrafeIAE4, EActividad5, EEpigrafeIAE5, ExoneradoPresentacionMod390, VolumenAnualDistintoCero)
  else
  if (REntorno.Ejercicio >= 2023) then
     ExportarMod303_2023(TipoDeclaracion, ExoneradoPresentacionMod390, VolumenAnualDistintoCero)
  else
  if (REntorno.Ejercicio >= 2022) then
     ExportarMod303_2022(TipoDeclaracion, ExoneradoPresentacionMod390, VolumenAnualDistintoCero)
  else
  if (REntorno.Ejercicio >= 2021) then
     ExportarMod303_2021(TipoDeclaracion, ExoneradoPresentacionMod390, VolumenAnualDistintoCero)
  else
  if (REntorno.Ejercicio >= 2018) then
     ExportarMod303_2018(TipoDeclaracion)
  else
  if (REntorno.Ejercicio >= 2014) then
     ExportarMod303_2014
  else
     ExportarMod303_2013;
end;

