procedure TDMRModelosHacienda.ExportarMod303_2026(aTipoDeclaracion: integer; EActividadPrincipal, EEpigrafeIAEPrincipal, EActividad1, EEpigrafeIAE1, EActividad2, EEpigrafeIAE2, EActividad3, EEpigrafeIAE3, EActividad4, EEpigrafeIAE4, EActividad5, EEpigrafeIAE5: string; ExoneradoPresentacionMod390: boolean = False; VolumenAnualDistintoCero: boolean = True);
var
  f : TextFile;
  Archivo : string;
  Tipo_Declaracion : string;
  Periodo : string;
  Casilla80, Casilla94 : double;
begin
  { TODO : Ver cómo rellenar Tipo_Declaracion }
  // Tipo de Declaracion
  // C - Solicitud de compensación
  // D - Devolucion
  // G - Cuenta corriente tributaria-ingreso
  // I (ingreso)
  // N - Sin actividad/resultado cero
  // V - Cuenta corriente triguraria-devolucion
  // U - Domiciliacion del intgreso en CCC
  case aTipoDeclaracion of
     0: Tipo_Declaracion := 'C';
     1: Tipo_Declaracion := 'D';
     2: Tipo_Declaracion := 'G';
     3: Tipo_Declaracion := 'I';
     4: Tipo_Declaracion := 'N';
     5: Tipo_Declaracion := 'V';
     6: Tipo_Declaracion := 'U';
  end;

  Periodo := QMModelo303Periodo.AsString;
  {Si el periodo es trimestral tiene otro formato}
  if QMModelo303Periodo.AsString = '13' then
     Periodo := '1T';
  if QMModelo303Periodo.AsString = '14' then
     Periodo := '2T';
