     Params.ByName['DESDE'].AsDateTime := FechaDesde;
     Params.ByName['HASTA'].AsDateTime := FechaHasta;
     Open;
  end;
end;

procedure TDMRModelosHacienda.FormatoModelo340(Ejercicio: integer; Periodo: string; Secuencia, TipoDeclaracion: integer; DeclaracionAnterior: string; ModoPresentacion: integer);
var
  Archivo : string;      // Nombre del Fichero
  NFic : TextFile;       // Fichero
  sReg : string;         // Registro
begin
  Archivo := Format('Modelo340-%s-%d.txt', [REntorno.CifEmpresa, REntorno.Ejercicio]);
  if MySaveDialog(Archivo, 'TXT', '', 'DMRModelosHacienda-Mod340') then
  begin
     AbrirDatosModelo340(Ejercicio, Periodo);
     AssignFile(NFic, Archivo);
     // Inicializamos el fichero
    {$I+}
     Rewrite(Nfic);
    {$I-}
     // grabamos el declarante

     sReg := ajusta(declarante340(Ejercicio, Periodo, Secuencia, TipoDeclaracion, DeclaracionAnterior, ModoPresentacion), 'D', 500, ' ');
     sReg := AnsiUpperCase(sReg);
     WriteLn(NFic, sReg);

     // grabamos los declarados
     // Facturas normales
     xModelo340_expedidas.First;
     while not xModelo340_expedidas.EOF do
     begin
        sReg := ajusta(declarado340_expedidas, 'D', 500, ' ');
        sReg := AnsiUpperCase(sReg);
        WriteLn(NFic, sReg);
        xModelo340_expedidas.Next;
     end;

     // Facturas Tickets
     xModelo340_expedidas_ticket.First;
     while not xModelo340_expedidas_ticket.EOF do
     begin
        sReg := ajusta(declarado340_expedidas_ticket, 'D', 500, ' ');
        sReg := AnsiUpperCase(sReg);
        WriteLn(NFic, sReg);
        xModelo340_expedidas_ticket.Next;
     end;

     xModelo340_recibidas.First;
     while not xModelo340_recibidas.EOF do
     begin
        sReg := ajusta(declarado340_recibidas, 'D', 500, ' ');
        sReg := AnsiUpperCase(sReg);
        WriteLn(NFic, sReg);
        xModelo340_recibidas.Next;
     end;

     xModelo340_Op_Intracomunitarias.First;
     while not xModelo340_Op_Intracomunitarias.EOF do
     begin
        sReg := AnsiUpperCase(declarado340_op_intracomunitarias);
        WriteLn(NFic, sReg);
        xModelo340_Op_Intracomunitarias.Next;
     end;
     {
     while not xModelo340_BienesInversion.EOF do
     begin
        sReg := AnsiUpperCase(declarado340_BienesInversion);
        WriteLn(NFic, sReg);
        WriteLn(NFic, sReg);
        xModelo340_BienesInversion.Next;
     end;
}
     // cerramos el fichero
     CloseFile(NFic);
     ShowMessage(_('Exportación realizada con éxito'));
  end;
end;

