        Write(f, Ajusta(DMMain.FloatToStrSinComa(QMModelo303C25.AsFloat, 2, 17, 'N'), 'I', 17, '0')); // IVA Devengado - Modif. Bases y Cuotas de Rec. Equiv. - Base Imponible [25]
