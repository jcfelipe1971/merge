procedure TDMRModelosHacienda.frModelo340GetValue(const ParName: string; var ParValue: variant);
begin
  DMListados.GetValue(ParName, ParValue);

  if (ParName = 'FechaExpedicionExp') then
     ParValue := xModelo340_expedidasFECHA_REGISTRO.AsDateTime;
  if (ParName = 'FechaOperacionExp') then
  begin
     ParValue := xModelo340_expedidasDOC_FECHA.AsDateTime;
     {cuando la fecha de operación sea mayor a la de expedición las iguales - Fercam}
     if (xModelo340_expedidasDOC_FECHA.AsDateTime > xModelo340_expedidasFECHA_REGISTRO.AsDateTime) then
        ParValue := xModelo340_expedidasFECHA_REGISTRO.AsDateTime;
  end;

  if (ParName = 'FechaExpedicionExpTicket') then
     ParValue := xModelo340_expedidas_ticketFECHA_REGISTRO.AsDateTime;
  if (ParName = 'FechaOperacionExpTicket') then
  begin
     ParValue := xModelo340_expedidas_ticketDOC_FECHA.AsDateTime;
     {cuando la fecha de operación sea mayor a la de expedición las iguales - Fercam}
     if (xModelo340_expedidas_ticketDOC_FECHA.AsDateTime > xModelo340_expedidas_ticketFECHA_REGISTRO.AsDateTime) then
        ParValue := xModelo340_expedidas_ticketFECHA_REGISTRO.AsDateTime;
  end;

  if (ParName = 'FechaExpedicionRec') then
     ParValue := xModelo340_recibidasFECHA_REGISTRO.AsDateTime;
  if (ParName = 'FechaOperacionRec') then
  begin
     ParValue := xModelo340_recibidasDOC_FECHA.AsDateTime;
     {cuando la fecha de operación sea mayor a la de expedición las iguales - Fercam}
     if (xModelo340_recibidasDOC_FECHA.AsDateTime > xModelo340_recibidasFECHA_REGISTRO.AsDateTime) then
        ParValue := xModelo340_recibidasFECHA_REGISTRO.AsDateTime;
  end;

  if (ParName = 'FechaExpedicionIntra') then
     ParValue := xModelo340_Op_IntracomunitariasFECHA_REGISTRO.AsDateTime;
  if (ParName = 'FechaOperacionIntra') then
  begin
     ParValue := xModelo340_Op_IntracomunitariasDOC_FECHA.AsDateTime;
     {cuando la fecha de operación sea mayor a la de expedición las iguales - Fercam}
     if (xModelo340_Op_IntracomunitariasDOC_FECHA.AsDateTime > xModelo340_Op_IntracomunitariasFECHA_REGISTRO.AsDateTime) then
        ParValue := xModelo340_Op_IntracomunitariasFECHA_REGISTRO.AsDateTime;
  end;

  if (ParName = 'Periodo') then
     ParValue := Periodo_Hacienda;
end;

