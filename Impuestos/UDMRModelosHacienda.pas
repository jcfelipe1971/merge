           Write(f, Ajusta(DMMain.FloatToStrSinComa(0{QMModelo303C500.AsFloat}, 2, 17, 'N'), 'I', 17, '0')); // 13. Reg. Deducc. Diferenc.- 2 - IVA ded. Adquisic. intracomun. - Bienes corrientes y servicios - Cuota deducible [727]
           Write(f, Ajusta(DMMain.FloatToStrSinComa(0{QMModelo303C500.AsFloat}, 2, 17, 'N'), 'I', 17, '0')); // 13. Reg. Deducc. Diferenc.- 2 - IVA ded. Adquisic. intracomun. - Bienes inversión - Base imponible [728]
           Write(f, Ajusta(DMMain.FloatToStrSinComa(0{QMModelo303C500.AsFloat}, 2, 17, 'N'), 'I', 17, '0')); // 13. Reg. Deducc. Diferenc.- 2 - IVA ded. Adquisic. intracomun. - Bienes inversión - Cuota deducible [729]
           Write(f, Ajusta(DMMain.FloatToStrSinComa(0{QMModelo303C500.AsFloat}, 2, 17, 'N'), 'I', 17, '0')); // 13. Reg. Deducc. Diferenc.- 2 - Compensac. rég. especial agric./ganad./pesca - Base impon. [730]
           Write(f, Ajusta(DMMain.FloatToStrSinComa(0{QMModelo303C500.AsFloat}, 2, 17, 'N'), 'I', 17, '0')); // 13. Reg. Deducc. Diferenc.- 2 - Compensac. rég. especial agric./ganad./pesca - Cuota deduc. [731]

           Write(f, Ajusta(DMMain.FloatToStrSinComa(0{QMModelo303C500.AsFloat}, 2, 17, 'N'), 'I', 17, '0')); // 13. Reg. Deducc. Diferenc.- 2 - Rectificación de deducciones - Base impon.  [732]
           Write(f, Ajusta(DMMain.FloatToStrSinComa(0{QMModelo303C500.AsFloat}, 2, 17, 'N'), 'I', 17, '0')); // 13. Reg. Deducc. Diferenc.- 2 - Rectificación de deducciones - Cuota deduc. [733]
           Write(f, Ajusta(DMMain.FloatToStrSinComa(0{QMModelo303C500.AsFloat}, 2, 17, 'N'), 'I', 17, '0')); // 13. Reg. Deducc. Diferenc.- 2 - Regularización de bienes de inversión [734]
           Write(f, Ajusta(DMMain.FloatToStrSinComa(0{QMModelo303C500.AsFloat}, 2, 17, 'N'), 'I', 17, '0')); // 13. Reg. Deducc. Diferenc.- 2 - Suma de deducciones [735]

