        Write(f, Ajusta(DMMain.FloatToStrSinComa(QMModelo303C22.AsFloat, 2, 17, 'N'), 'I', 17, '0')); // IVA Devengado - Rec. Equiv. - Base Imponible [22]
        Write(f, Ajusta(DMMain.FloatToStrSinComa(QMModelo303C23.AsFloat, 2, 5, 'N'), 'I', 5, '0'));  // IVA Devengado - Rec. Equiv. - Tipo % [23]
