procedure TDMRModelosHacienda.ExportarMod390(ActividadPrincipal, Clave, Epigrafe, ActividadProrrata: string);
begin
  if (REntorno.Ejercicio >= 2025) then
     ExportarMod390_2025(ActividadPrincipal, Clave, Epigrafe, ActividadProrrata)
  else
  if (REntorno.Ejercicio >= 2023) then
     ExportarMod390_2023(ActividadPrincipal, Clave, Epigrafe, ActividadProrrata)
  else
  if (REntorno.Ejercicio >= 2022) then
     ExportarMod390_2022(ActividadPrincipal, Clave, Epigrafe, ActividadProrrata)
  else
  if (REntorno.Ejercicio >= 2021) then
     ExportarMod390_2021(ActividadPrincipal, Clave, Epigrafe, ActividadProrrata)
  else
  if (REntorno.Ejercicio >= 2018) then
     ExportarMod390_2018(ActividadPrincipal, Clave, Epigrafe, ActividadProrrata);
  {
  else
  if (REntorno.Ejercicio >= 2014) then
     ExportarMod390_2014
  else
     ExportarMod390_2013;
  }
end;

