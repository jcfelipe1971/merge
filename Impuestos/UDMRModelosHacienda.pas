procedure TDMRModelosHacienda.QMModelo390AfterOpen(DataSet: TDataSet);
var
  i : integer;
begin
  with DataSet do
  begin
     for i := 0 to FieldCount - 1 do
     begin
        if (Fields[i] is TFloatField) then
           TFloatField(Fields[i]).DisplayFormat := MascaraN;
        if (Fields[i] is TDateTimeField) then
           TDateTimeField(Fields[i]).DisplayFormat := ShortDateFormat;
     end;
  end;
end;

