        Write(f, Ajusta(DMMain.FloatToStrSinComa(QMModelo303C157.AsFloat, 2, 5, 'N'), 'I', 5, '0'));  // IVA Devengado - Rec. Equiv. - Tipo % [157]
        Write(f, Ajusta(DMMain.FloatToStrSinComa(QMModelo303C158.AsFloat, 2, 17, 'N'), 'I', 17, '0')); // IVA Devengado - Rec. Equiv. - Cuota [158]
        Write(f, Ajusta(DMMain.FloatToStrSinComa(QMModelo303C16.AsFloat, 2, 17, 'N'), 'I', 17, '0')); // IVA Devengado - Rec. Equiv. - Base Imponible [16]
        Write(f, Ajusta(DMMain.FloatToStrSinComa(QMModelo303C17.AsFloat, 2, 5, 'N'), 'I', 5, '0'));  // IVA Devengado - Rec. Equiv. - Tipo % [17]
        Write(f, Ajusta(DMMain.FloatToStrSinComa(QMModelo303C18.AsFloat, 2, 17, 'N'), 'I', 17, '0')); // IVA Devengado - Rec. Equiv. - Cuota [18]
        Write(f, Ajusta(DMMain.FloatToStrSinComa(QMModelo303C19.AsFloat, 2, 17, 'N'), 'I', 17, '0')); // IVA Devengado - Rec. Equiv. - Base Imponible [19]
