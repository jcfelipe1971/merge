uses UDMMain, UEntorno, UUtiles, UDameDato, UDMListados, UFormGest, UParam, UHojaCalc;

{$R *.DFM}

procedure TDMRModelosHacienda.DMRModelosHaciendaCreate(Sender: TObject);
begin
  TranslateComponent(Self); //IDIOMA_CODE
  if not TLocal.InTransaction then
     TLocal.StartTransaction;

  AsignaDisplayFormat(xMod110_Detalle, MascaraN, MascaraI, ShortDateFormat);
  xMod110_DetalleP_IRPF.DisplayFormat := MascaraP;

  AsignaDisplayFormat(QMModelo300, MascaraN, MascaraI, ShortDateFormat);
  QMModelo300C29.DisplayFormat := MascaraP;
  xModelo330C32.DisplayFormat := MascaraP;

  AsignaDisplayFormat(QMModelo303, MascaraN, MascaraI, ShortDateFormat);

  if (REntorno.Ejercicio >= 2014) then
  begin
     QMModelo303C27.DisplayLabel := _('IVA Devengado');
     QMModelo303C45.DisplayLabel := _('IVA Deducible');
     QMModelo303C46.DisplayLabel := _('Diferencia');
     QMModelo303C67.DisplayLabel := _('A Compensar');
     QMModelo303C71.DisplayLabel := _('Resultado');
  end;

  // A partir del 2009 los modelos 300 y 330 se reemplazan por el 303
  if (REntorno.Ejercicio <= 2009) then
  begin
     DMMain.FiltraRO(QMModelo300, '11100', True);
     DMMain.FiltraRO(xModelo330, '11100', True);
  end;
  DMMain.FiltraTabla(QMModelo390, '11100', True);
  FiltraDatosDeclarante;

  AbreData(TDMListados, DMListados);
end;

procedure TDMRModelosHacienda.FiltraDatosDeclarante;
begin
  with xDatosModelosHacienda do
  begin
     Close;
     Params.ByName['EMPRESA'].AsInteger := REntorno.Empresa;
     Params.ByName['EJERCICIO'].AsInteger := REntorno.Ejercicio;
     Params.ByName['CANAL'].AsInteger := REntorno.Canal;
     Open;
  end;
end;

procedure TDMRModelosHacienda.DMRModelosHaciendaDestroy(Sender: TObject);
begin
  CierraData(DMListados);
  Application.ProcessMessages;
end;

procedure TDMRModelosHacienda.Previsualizar(modo: smallint);
begin
  DMListados.Imprimir(132, 0, Modo, '', '', frModelo300, frxModelo300, nil);
end;

procedure TDMRModelosHacienda.Previsualizar303(Modo: smallint);
begin
  DMListados.Imprimir(5107, 0, Modo, '', '', frModelo303, frxModelo303, nil);
end;

procedure TDMRModelosHacienda.Previsualizar330(modo: smallint);
begin
  DMListados.Imprimir(133, 0, Modo, '', '', frModelo330, frxModelo330, nil);
end;

