<TfrxHYReport Name="" Version="3.19" DotMatrixReport="False" IniFile="\Software\Fast Reports" PreviewOptions.Buttons="4095" PreviewOptions.Zoom="1" PrintOptions.Printer="Default" ReportOptions.CreateDate="39293,6695771759" ReportOptions.Description.Text="" ReportOptions.LastChange="39294,5052101389" ScriptLanguage="PascalScript" ScriptText.Text="procedure Band1OnBeforePrint(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;  with Band1, Engine do&#13;&#10;  begin&#13;&#10;Begin&#13;&#10;  AlmacenAnt:='Inicializando';&#13;&#10;  ArticuloAnt:='Inicializando';&#13;&#10;  DescAnt:='Inicializando';&#13;&#10;end&#13;&#10;  end&#13;&#10;end;&#13;&#10;&#13;&#10;procedure Memo21OnBeforePrint(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;  with Memo21, Engine do&#13;&#10;  begin&#13;&#10;  if (([Almacen]='TO1')or([Almacen]='TO2')or&#13;&#10;      ([Almacen]='TO3'))&#13;&#10;    then Visible := false&#13;&#10;    else Visible := true;&#13;&#10;  end&#13;&#10;end;&#13;&#10;&#13;&#10;procedure Memo12OnBeforePrint(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;  with Memo12, Engine do&#13;&#10;  begin&#13;&#10;Begin&#13;&#10;  if (([Almacen]='TO1')or([Almacen]='TO2')or&#13;&#10;      ([Almacen]='TO3'))&#13;&#10;    then Visible := false&#13;&#10;    else begin&#13;&#10;      if ([Almacen]=AlmacenAnt)&#13;&#10;        then visible:=false&#13;&#10;        else visible:=true;&#13;&#10;      AlmacenAnt:=[Almacen];&#13;&#10;    end;&#13;&#10;end&#13;&#10;  end&#13;&#10;end;&#13;&#10;&#13;&#10;procedure Memo20OnBeforePrint(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;  with Memo20, Engine do&#13;&#10;  begin&#13;&#10;  if (([Almacen]='TO1')or([Almacen]='TO2')or&#13;&#10;      ([Almacen]='TO3'))&#13;&#10;    then Visible := false&#13;&#10;    else Visible := true;&#13;&#10;  end&#13;&#10;end;&#13;&#10;&#13;&#10;procedure Memo22OnBeforePrint(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;  with Memo22, Engine do&#13;&#10;  begin&#13;&#10;  if (([Almacen]='TO1')or([Almacen]='TO2')or&#13;&#10;      ([Almacen]='TO3'))&#13;&#10;    then Visible := false&#13;&#10;    else Visible := true;&#13;&#10;  end&#13;&#10;end;&#13;&#10;&#13;&#10;procedure Memo13OnBeforePrint(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;  with Memo13, Engine do&#13;&#10;  begin&#13;&#10;  if (([Almacen]='TO1')or([Almacen]='TO2')or&#13;&#10;      ([Almacen]='TO3'))&#13;&#10;    then Visible := false&#13;&#10;    else Visible := true;&#13;&#10;  end&#13;&#10;end;&#13;&#10;&#13;&#10;procedure Memo18OnBeforePrint(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;  with Memo18, Engine do&#13;&#10;  begin&#13;&#10;Begin&#13;&#10;  if (([Almacen]='TO1')or([Almacen]='TO2')or&#13;&#10;      ([Almacen]='TO3'))&#13;&#10;    then begin&#13;&#10;      Visible := false;&#13;&#10;      ArticuloAnt:='Inicializando';&#13;&#10;    end&#13;&#10;    else begin&#13;&#10;      if ([Articulo]=ArticuloAnt)&#13;&#10;        then visible:=false&#13;&#10;        else visible:=true;&#13;&#10;      ArticuloAnt:=[Articulo];&#13;&#10;    end;&#13;&#10;end&#13;&#10;  end&#13;&#10;end;&#13;&#10;&#13;&#10;procedure Memo28OnBeforePrint(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;  with Memo28, Engine do&#13;&#10;  begin&#13;&#10;  if (([Almacen]='TO1')or([Almacen]='TO2')or&#13;&#10;      ([Almacen]='TO3'))&#13;&#10;    then Visible := false&#13;&#10;    else Visible := true;&#13;&#10;  end&#13;&#10;end;&#13;&#10;&#13;&#10;procedure Memo19OnBeforePrint(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;  with Memo19, Engine do&#13;&#10;  begin&#13;&#10;  If (([Almacen]='TO1')or([Almacen]='TO2')or&#13;&#10;      ([Almacen]='TO3'))&#13;&#10;    then visible:= true&#13;&#10;    else visible:= Memo18.Visible;&#13;&#10;  end&#13;&#10;end;&#13;&#10;&#13;&#10;begin&#13;&#10;&#13;&#10;end." StoreInDFM="False" FIBOptions.DataSet="DMMain.QListados" FIBOptions.KeyField="LISTADO" FIBOptions.BlobField="DEF_LISTADO" FIBOptions.NameField="TITULO" FIBOptions.GroupField="GRUPO" FIBOptions.TypeField="TIPO" PropData="">
