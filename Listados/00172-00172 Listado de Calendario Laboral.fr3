<TfrxHYReport Name="" Version="3.19" DotMatrixReport="False" EngineOptions.DoublePass="True" IniFile="\Software\Fast Reports" PreviewOptions.Buttons="4095" PreviewOptions.Zoom="1" PrintOptions.Printer="Por defecto" ReportOptions.CreateDate="39108,5966684722" ReportOptions.Description.Text="" ReportOptions.LastChange="46020,9421237269" ScriptLanguage="PascalScript" ScriptText.Text="procedure GroupHeader1OnBeforePrint(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;  TotalHorasMarcaje := 0;&#13;&#10;  TotalHorasComputo := 0;&#13;&#10;  TotalHorasComputoFavor := 0;&#13;&#10;  TotalHorasComputoContra := 0;&#13;&#10;  TotalTiempo := 0;&#13;&#10;  TotalTiempoComputo := 0;&#13;&#10;end;&#13;&#10;&#13;&#10;procedure Memo7OnBeforePrint(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;  if ([frxDBDSQMLstCalendarioLaboral.&#34;FESTIVO&#34;] = 0) then&#13;&#10;  begin&#13;&#10;     Memo7.Text := 'Laboral';&#13;&#10;     Memo7.Color := clNone;&#13;&#10;     Memo7.Font.Color := clWindowText;&#13;&#10;  end&#13;&#10;  else&#13;&#10;  begin&#13;&#10;     Memo7.Text := 'Festivo';&#13;&#10;     Memo7.Color := clYellow;&#13;&#10;     Memo7.Font.Color := clWindowText;&#13;&#10;  end;&#13;&#10;end;&#13;&#10;&#13;&#10;procedure Memo6OnBeforePrint(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;  if ([frxDBDSQMLstCalendarioLaboral.&#34;HORAS_LABORAL&#34;] = 0) then&#13;&#10;     Memo6.Visible := False&#13;&#10;  else&#13;&#10;     Memo6.Visible := True;&#13;&#10;end;&#13;&#10;&#13;&#10;procedure Memo5OnBeforePrint(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;  if ([frxDBDSQMLstCalendarioLaboral.&#34;HORA_FIN_2&#34;] = 0) then&#13;&#10;     Memo5.Visible := False&#13;&#10;  else&#13;&#10;     Memo5.Visible := True;&#13;&#10;end;&#13;&#10;&#13;&#10;procedure Memo4OnBeforePrint(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;  if ([frxDBDSQMLstCalendarioLaboral.&#34;HORA_INI_2&#34;] = 0) then&#13;&#10;     Memo4.Visible := False&#13;&#10;  else&#13;&#10;     Memo4.Visible := True;&#13;&#10;end;&#13;&#10;&#13;&#10;procedure Memo3OnBeforePrint(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;    if ([frxDBDSQMLstCalendarioLaboral.&#34;HORA_FIN_1&#34;] = 0) then&#13;&#10;     Memo3.Visible := False&#13;&#10;  else&#13;&#10;     Memo3.Visible := True;&#13;&#10;end;&#13;&#10;&#13;&#10;procedure Memo2OnBeforePrint(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;    if ([frxDBDSQMLstCalendarioLaboral.&#34;HORA_INI_1&#34;] = 0) then&#13;&#10;     Memo2.Visible := False&#13;&#10;  else&#13;&#10;     Memo2.Visible := True;&#13;&#10;end;&#13;&#10;&#13;&#10;procedure Memo1OnBeforePrint(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;  if ([frxDBDSQMLstCalendarioLaboral.&#34;FESTIVO&#34;] = 0) then&#13;&#10;  begin&#13;&#10;     Memo1.Color := clNone;&#13;&#10;     Memo1.Font.Color := clWindowText;&#13;&#10;  end&#13;&#10;  else&#13;&#10;  begin&#13;&#10;     Memo1.Color := clYellow;&#13;&#10;     Memo1.Font.Color := clWindowText;&#13;&#10;  end;&#13;&#10;end;&#13;&#10;&#13;&#10;procedure Memo31OnBeforePrint(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;  // Memo del tipo de incidencia&#13;&#10;  if ([frxDBDSMarcajePresencia.&#34;REMUNERACION&#34;] = 1) then&#13;&#10;  begin&#13;&#10;     // Inicidencias que cuentan a favor (11 blanco, resto verde)&#13;&#10;     if (&#60;frxDBDSMarcajePresencia.&#34;INCIDENCIA&#34;&#62; = 11) then&#13;&#10;        Memo31.Color := clNone&#13;&#10;     else&#13;&#10;        Memo31.Color := clLime;&#13;&#10;&#13;&#10;     Memo31.Font.Color := clWindowText;&#13;&#10;  end&#13;&#10;  else&#13;&#10;  if ([frxDBDSMarcajePresencia.&#34;REMUNERACION&#34;] = 0) then&#13;&#10;  begin&#13;&#10;     // Inicidencias que no cuentan (amarillo)&#13;&#10;     Memo31.Color := clYellow;&#13;&#10;     Memo31.Font.Color := clWindowText;&#13;&#10;  end&#13;&#10;  else&#13;&#10;  begin&#13;&#10;     // Inicidencias que restan (rojo)&#13;&#10;     Memo31.Color := clRed;&#13;&#10;     Memo31.Font.Color := clWhite;&#13;&#10;  end;&#13;&#10;&#13;&#10;  // Memo del total de horas&#13;&#10;  Memo35.Color := Memo31.Color;&#13;&#10;  Memo35.Font.Color := Memo31.Font.Color;&#13;&#10;  // Memo del total de horas computadas&#13;&#10;  Memo38.Color := Memo31.Color;&#13;&#10;  Memo38.Font.Color := Memo31.Font.Color;&#13;&#10;end;&#13;&#10;&#13;&#10;procedure Memo35OnBeforePrint(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;  TotalHorasMarcaje := TotalHorasMarcaje + (&#60;frxDBDSMarcajePresencia.&#34;TIEMPO_TOTAL&#34;&#62;);&#13;&#10;end;&#13;&#10;&#13;&#10;procedure Memo8OnBeforePrint(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;  NombreEmpleado := &#60;frxDBDSQMLstCalendarioLaboral.&#34;TITULO_OPERARIO&#34;&#62;;&#13;&#10;end;&#13;&#10;&#13;&#10;procedure Memo38OnAfterPrint(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;&#13;&#10;  if ([frxDBDSMarcajePresencia.&#34;REMUNERACION&#34;] = 1) then&#13;&#10;  begin&#13;&#10;     if (&#60;frxDBDSMarcajePresencia.&#34;INCIDENCIA&#34;&#62; &#60;&#62; 11) then&#13;&#10;         TotalHorasComputoFavor := TotalHorasComputoFavor + (&#60;frxDBDSMarcajePresencia.&#34;TIEMPO_TOTAL_COMPUTO&#34;&#62;);&#13;&#10;  end&#13;&#10;  else&#13;&#10;  begin&#13;&#10;     if ([frxDBDSMarcajePresencia.&#34;REMUNERACION&#34;] = -1) then&#13;&#10;        TotalHorasComputoContra := TotalHorasComputoContra + (&#60;frxDBDSMarcajePresencia.&#34;TIEMPO_TOTAL_COMPUTO&#34;&#62;);&#13;&#10;  end;&#13;&#10;&#13;&#10;  if ([frxDBDSMarcajePresencia.&#34;REMUNERACION&#34;] &#60;&#62; 0) then&#13;&#10;  begin&#13;&#10;       TotalHorasComputo := TotalHorasComputo + (&#60;frxDBDSMarcajePresencia.&#34;TIEMPO_TOTAL_COMPUTO&#34;&#62;);&#13;&#10;       TotalTiempo := TotalTiempo + &#60;frxDBDSMarcajePresencia.&#34;TIEMPO_TOTAL&#34;&#62;;&#13;&#10;       TotalTiempoComputo := TotalTiempoComputo + &#60;frxDBDSMarcajePresencia.&#34;TIEMPO_TOTAL_COMPUTO&#34;&#62;;&#13;&#10;  end;&#13;&#10;end;&#13;&#10;&#13;&#10;procedure Memo28OnBeforePrint(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;   Signo := '';&#13;&#10;   if (Totaltiempo &#60; 0) then&#13;&#10;       Signo := '-';&#13;&#10;&#13;&#10;   Memo28.Text := FormatFloat('0',Abs(Trunc(Totaltiempo)))+':'+FormatFloat('00',(Abs(Frac(Totaltiempo)) * 60));&#13;&#10;end;&#13;&#10;&#13;&#10;procedure Memo39OnBeforePrint(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;  Signo := '';&#13;&#10;  if (TotalTiempoComputo &#60; 0) then&#13;&#10;       Signo := '-';&#13;&#10;&#13;&#10;  Memo39.Text := Signo+FormatFloat('0',Abs(Trunc(TotalTiempoComputo)))+':'+FormatFloat('00',(Abs(Frac(TotalTiempoComputo)) * 60));&#13;&#10;end;&#13;&#10;&#13;&#10;procedure MasterData1OnBeforePrint(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;  TotalTiempo := 0;&#13;&#10;  TotalTiempoComputo := 0;&#13;&#10;&#13;&#10;  MasterData1.Visible := (&#60;frxDBDSQMLstCalendarioLaboral.&#34;FESTIVO&#34;&#62; = 0) or ((&#60;frxDBDSQMLstCalendarioLaboral.&#34;FESTIVO&#34;&#62; = 1) and (&#60;frxDBDSQMLstCalendarioLaboral.&#34;TIENE_MARCAJES&#34;&#62; = 1));&#13;&#10;  DetailData1.Visible := MasterData1.Visible;&#13;&#10;  Footer1.Visible := MasterData1.Visible;&#13;&#10;end;&#13;&#10;&#13;&#10;begin&#13;&#10;&#13;&#10;end." StoreInDFM="False" FIBOptions.DataSet="DMMain.QListados" FIBOptions.KeyField="LISTADO" FIBOptions.BlobField="DEF_LISTADO" FIBOptions.NameField="TITULO" FIBOptions.GroupField="GRUPO" FIBOptions.TypeField="TIPO" PropData="">
