<TfrxHYReport Name="" Version="3.19" DotMatrixReport="False" EngineOptions.DoublePass="True" IniFile="\Software\Fast Reports" PreviewOptions.Buttons="4095" PreviewOptions.Zoom="1" PrintOptions.Printer="Default" ReportOptions.CreateDate="39324,7776822917" ReportOptions.Description.Text="" ReportOptions.LastChange="39325,4032284375" ScriptLanguage="PascalScript" ScriptText.Text="procedure CabeceraDe_grupo1OnBeforePrint(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;  with CabeceraDe_grupo1, Engine do&#13;&#10;  begin&#13;&#10;  lineas:=0;&#13;&#10;  NAgentes := NAgentes + 1;&#13;&#10;  art:=[xVentas_Agente_detalle.&#34;ARTICULO&#34;];&#13;&#10;  end&#13;&#10;end;&#13;&#10;&#13;&#10;procedure DatosOnBeforePrint(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;  with Datos, Engine do&#13;&#10;  begin&#13;&#10;  Lineas:=lineas+1;&#13;&#10;  end&#13;&#10;end;&#13;&#10;&#13;&#10;procedure T_tuloDel_informe1OnBeforePrint(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;  with T_tuloDel_informe1, Engine do&#13;&#10;  begin&#13;&#10;  vis:=true;&#13;&#10;  UnidadesT := 0;&#13;&#10;  PrecioT   := 0;&#13;&#10;  TVentaT   := 0;&#13;&#10;  TCosteT   := 0;&#13;&#10;  MargenT   := 0;&#13;&#10;  MargenPT  := 0;&#13;&#10;  ComisionT := 0;&#13;&#10;  ComisionPT:= 0;&#13;&#10;  NAgentes  := 0;&#13;&#10;  tot := 0;&#13;&#10;  tot2 := 0;&#13;&#10;  tot_margen := 0;&#13;&#10;  lineas := 0;&#13;&#10;  end&#13;&#10;end;&#13;&#10;&#13;&#10;procedure bHijaOnBeforePrint(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;  with bHija, Engine do&#13;&#10;  begin&#13;&#10;    bHija.visible:= [MostrarInfoLotes];&#13;&#10;  end&#13;&#10;end;&#13;&#10;&#13;&#10;procedure Memo47OnBeforePrint(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;  with Memo47, Engine do&#13;&#10;  begin&#13;&#10;  UnidadesT := UnidadesT + sum([xVentas_Agente_detalle.&#34;UNIDADES&#34;],datos);&#13;&#10;  end&#13;&#10;end;&#13;&#10;&#13;&#10;procedure Memo48OnBeforePrint(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;  with Memo48, Engine do&#13;&#10;  begin&#13;&#10;  visible:=vis;&#13;&#10;  PrecioT := PrecioT + (sumPV/lineas);&#13;&#10;  //[[[sum([xVentas_Agente_detalle.&#34;PV&#34;],datos)]/[LINEAS]]+[MascaraN]]&#13;&#10;  end&#13;&#10;end;&#13;&#10;&#13;&#10;procedure Memo49OnBeforePrint(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;  with Memo49, Engine do&#13;&#10;  begin&#13;&#10;  TVentaT := TVentaT + sumTOTAL;&#13;&#10;  end&#13;&#10;end;&#13;&#10;&#13;&#10;procedure Memo53OnBeforePrint(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;  with Memo53, Engine do&#13;&#10;  begin&#13;&#10;  TCosteT := TCosteT + sumT_COSTE;&#13;&#10;  end&#13;&#10;end;&#13;&#10;&#13;&#10;procedure Memo55OnBeforePrint(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;  with Memo55, Engine do&#13;&#10;  begin&#13;&#10;  MargenT := MargenT + sumMARGEN;&#13;&#10;  end&#13;&#10;end;&#13;&#10;&#13;&#10;procedure Memo57OnBeforePrint(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;  with Memo57, Engine do&#13;&#10;  begin&#13;&#10;    //tot_margen := sumMARGEN_POR;&#13;&#10;    //tot        := tot_margen / lineas;&#13;&#10;    MargenPT   := MargenPT + sumMARGEN_PORentreLINEAS;&#13;&#10;  end&#13;&#10;end;&#13;&#10;&#13;&#10;procedure Memo59OnBeforePrint(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;  with Memo59, Engine do&#13;&#10;  begin&#13;&#10;  ComisionT := ComisionT + sumCOMISION;&#13;&#10;  end&#13;&#10;end;&#13;&#10;&#13;&#10;procedure Memo61OnBeforePrint(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;  with Memo61, Engine do&#13;&#10;  begin&#13;&#10;  //tot_margen2  := sumCOMISION_POR;&#13;&#10;  //tot2         := tot_margen2 / lineas;&#13;&#10;  ComisionPT   := ComisionPT + sumCOMISION_PORentreLINEAS;&#13;&#10;  end&#13;&#10;end;&#13;&#10;&#13;&#10;procedure Memo24OnBeforePrint(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;  with Memo24, Engine do&#13;&#10;  begin&#13;&#10;  visible:=vis;&#13;&#10;  end&#13;&#10;end;&#13;&#10;&#13;&#10;begin&#13;&#10;&#13;&#10;end." StoreInDFM="False" FIBOpti