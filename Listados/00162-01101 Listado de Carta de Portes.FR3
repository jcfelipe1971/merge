    <TfrxFIBHYQuery Name="EmpTrans" UserName="EmpTrans" CloseDataSource="True" FieldAliases.Text="" Master="DMLstAlbaranes.frxDBDSxCartaPortes" SQL.Text="select t.nombre_r_social, t.nif, d.dir_completa_n,&#13;&#10;d.dir_localidad, l.codigo_postal, l.titulo&#13;&#10;from emp_acreedores a&#13;&#10;left join sys_terceros t on a.tercero = t.tercero&#13;&#10;join sys_terceros_direcciones d on (t.tercero =&#13;&#10;d.tercero )&#13;&#10;join sys_localidades l on (d.id_local = l.id_local)&#13;&#10;where acreedor = ?transportista&#13;&#10;and d.dir_defecto = 1" Database="FIBHYDatabase1" PropData="0A506172616D65746572730100"/>
