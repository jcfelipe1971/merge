<TfrxHYReport Name="" Version="3.19" DotMatrixReport="False" EngineOptions.DoublePass="True" IniFile="\Software\Fast Reports" PreviewOptions.Buttons="4095" PreviewOptions.Zoom="1" PrintOptions.Printer="Default" ReportOptions.CreateDate="39322,6961192477" ReportOptions.Description.Text="" ReportOptions.LastChange="40504,5080152199" ScriptLanguage="PascalScript" ScriptText.Text="var&#13;&#10;   B_Imponible_Autofacturas : Real;&#13;&#10;&#13;&#10;procedure Memo4OnBeforePrint(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;end;&#13;&#10;&#13;&#10;procedure Memo7OnBeforePrint(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;end;&#13;&#10;&#13;&#10;procedure Memo10OnBeforePrint(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;  if (([frxDBDSxModelo340_recibidas.&#34;PAIS&#34;]&#60;&#62;'ESP') or ([frxDBDSxModelo340_recibidas.&#34;PAIS&#34;]='ZZZ')) then&#13;&#10;  begin&#13;&#10;     Memo10.Color := clHotLight;&#13;&#10;     if ((&#60;frxDBDSxModelo340_recibidas.&#34;MODO&#34;&#62;=3) and (&#60;frxDBDSxModelo340_recibidas.&#34;PERTENECE_CEE&#34;&#62; &#60;&#62; 1)) then&#13;&#10;         Memo10.Color := clRed;&#13;&#10;     if ((&#60;frxDBDSxModelo340_recibidas.&#34;MODO&#34;&#62;&#60;&#62;3) and (&#60;frxDBDSxModelo340_recibidas.&#34;PERTENECE_CEE&#34;&#62; &#60;&#62; 1)) then&#13;&#10;         if (&#60;frxDBDSxModelo340_recibidas.&#34;MODO&#34;&#62;&#60;&#62;5) then&#13;&#10;             Memo10.Color := clRed;&#13;&#10;     Memo10.Font.Color := clWhite;&#13;&#10;  end else&#13;&#10;  begin&#13;&#10;     Memo10.Color := clNone;&#13;&#10;     Memo10.Font.Color := clWindowText;&#13;&#10;  end;&#13;&#10;end;&#13;&#10;&#13;&#10;procedure Memo11OnBeforePrint(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;end;&#13;&#10;&#13;&#10;procedure Memo21OnBeforePrint(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;  if (([frxDBDSxModelo340_expedidas.&#34;PAIS&#34;]&#60;&#62;'ESP') or ([frxDBDSxModelo340_expedidas.&#34;PAIS&#34;]='ZZZ')) then&#13;&#10;  begin&#13;&#10;     Memo21.Color :