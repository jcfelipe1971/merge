<TfrxHYReport Name="" Version="3.19" DotMatrixReport="False" EngineOptions.DoublePass="True" IniFile="\Software\Fast Reports" PreviewOptions.Buttons="4095" PreviewOptions.Zoom="1" PrintOptions.Printer="Default" ReportOptions.CreateDate="38691,6420385995" ReportOptions.Description.Text="" ReportOptions.LastChange="38698,5217132176" ScriptLanguage="PascalScript" ScriptText.Text="var&#13;&#10;  Base, Total: Double;&#13;&#10;&#13;&#10;procedure CabeceraDe_grupo1OnBeforePrint(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;  with CabeceraDe_grupo1, Engine do&#13;&#10;  begin&#13;&#10;    Visible := [FiltroSerie];&#13;&#10;    Base  := 0;&#13;&#10;    Total := 0;&#13;&#10;  end&#13;&#10;end;&#13;&#10;&#13;&#10;procedure PieDe_grupo1OnBeforePrint(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;  with PieDe_grupo1, Engine do&#13;&#10;  begin&#13;&#10;    Visible := [FiltroSerie];&#13;&#10;  end&#13;&#10;end;&#13;&#10;&#13;&#10;procedure Memo33OnBeforePrint(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;  with Memo33, Engine do&#13;&#10;  begin&#13;&#10;    Total := Total + [Total_Albaran];&#13;&#10;  end&#13;&#10;end;&#13;&#10;&#13;&#10;procedure Memo37OnBeforePrint(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;  with Memo37, Engine do&#13;&#10;  begin&#13;&#10;    if ([MBI]=0)&#13;&#10;      then width:= 443&#13;&#10;      else width:= 354;&#13;&#10;  end&#13;&#10;end;&#13;&#10;&#13;&#10;procedure Memo6OnBeforePrint(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;  with Memo6, Engine do&#13;&#10;  begin&#13;&#10;    if ([MBI]=0)&#13;&#10;      then width:= 443&#13;&#10;      else width:= 354;&#13;&#10;  end&#13;&#10;end;&#13;&#10;&#13;&#10;procedure Memo10OnBeforePrint(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;  with Memo10, Engine do&#13;&#10;  begin&#13;&#10;    Visible := ([MBI] = 1);&#13;&#10;    Base := Base + [BaseImponible];&#13;&#10;  end&#13;&#10;end;&#13;&#10;&#13;&#10;procedure Memo13OnBeforePrint(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;  with Memo13, Engine do&#13;&#10;  begin&#13;&#10;    Visible := ([MBI] = 1);&#13;&#10;  end&#13;&#10;end;&#13;&#10;&#13;&#10;procedure Memo14OnBeforePrint(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;  with Memo14, Engine do&#13;&#10;  begin&#13;&#10;    Visible := ([MBI] = 1);&#13;&#10;  end&#13;&#10;end;&#13;&#10;&#13;&#10;procedure Memo70OnBeforePrint(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;  with Memo70, Engine do&#13;&#10;  begin&#13;&#10;  If ([Moneda]=[Moneda_Canal])&#13;&#10;    then visible:= False&#13;&#10;    else visible:= True;&#13;&#10;  end&#13;&#10;end;&#13;&#10;&#13;&#10;procedure Memo18OnBeforePrint(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;  with Memo18, Engine do&#13;&#10;  begin&#13;&#10;    Visible := ([MBI] = 1);&#13;&#10;    Set('SBase', Base);&#13;&#10;  end&#13;&#10;end;&#13;&#10;&#13;&#10;procedure Memo17OnBeforePrint(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;  Set('STotal', Total);&#13;&#10;end;&#13;&#10;&#13;&#10;begin&#13;&#10;&#13;&#10;end." StoreInDFM="False" FIBOptions.DataSet="DMMain.QListados" FIBOptions.KeyField="LISTADO" FIBOptions.BlobField="DEF_LISTADO" FIBOptions.NameField="TITULO" FIBOptions.GroupField="GRUPO" FIBOptions.TypeField="TIPO" PropData="">
