 with Memo25, Engine do&#13;&#10;  begin&#13;&#10;  Visible := (([QMCabecera.&#34;ALBARAN_VALORADO&#34;] &#60;&#62; 0) and (&#60;frxDBDSCabecera.&#34;LIQUIDO&#34;&#62; &#60;&#62; '0'));&#13;&#10;  end&#13;&#10;end;&#13;&#10;&#13;&#10;procedure Memo29OnBeforePrint(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;  with Memo29, Engine do&#13;&#10;  begin&#13;&#10;  if (&#60;frxDBDSCabecera.&#34;S_BASES&#34;&#62; = '0') then visible :=false;&#13;&#10;  end&#13;&#10;end;&#13;&#10;&#13;&#10;procedure Memo47OnBeforePrint(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;  with Memo47, Engine do&#13;&#10;  begin&#13;&#10;  visible:= ([QMCabecera.&#34;CLIENTE&#34;]&#60;0);&#13;&#10;  end&#13;&#10;end;&#13;&#10;&#13;&#10;procedure Memo72OnBeforePrint(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;  with Memo72, Engine do&#13;&#10;  begin&#13;&#10;  visible:= (([QMCabecera.&#34;CLIENTE&#34;]&#62;0) or ([xDireccionFiscal.&#34;CODPOB&#34;]&#60;&#62; '00000 DESCONOCIDA'));&#13;&#10;  end&#13;&#10;end;&#13;&#10;&#13;&#10;procedure Memo80OnBeforePrint(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;  with Memo80, Engine do&#13;&#10;  begin&#13;&#10;     Visible :=([QMCabecera.&#34;CLIENTE&#34;]&#62;0);&#13;&#10;  end&#13;&#10;end;&#13;&#10;&#13;&#10;procedure Memo64OnBeforePrint(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;  with Memo64, Engine do&#13;&#10;  begin&#13;&#10;     Visible := ([xCliente.&#34;NOMBRE_COMERCIAL&#34;] &#60;&#62; [xCliente.&#34;TITULO&#34;])and ([QMCabecera.&#34;CLIENTE&#34;]&#62;0);&#13;&#10;  end&#13;&#10;end;&#13;&#10;&#13;&#10;procedure Memo83OnBeforePrint(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;  with Memo83, Engine do&#13;&#10;  begin&#13;&#10;     Visible :=([QMCabecera.&#34;CLIENTE&#34;]&#62;0);&#13;&#10;  end&#13;&#10;end;&#13;&#10;&#13;&#10;procedure Memo84OnBeforePrint(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;  with Memo84, Engine do&#13;&#10;  begin&#13;&#10;     Visible := ([xCliente.&#34;NOMBRE_COMERCIAL&#34;] &#60;&#62; [xCli