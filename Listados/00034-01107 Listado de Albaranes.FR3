<TfrxHYReport Name="" Version="3.19" DotMatrixReport="False" EngineOptions.DoublePass="True" IniFile="\Software\Fast Reports" PreviewOptions.Buttons="4095" PreviewOptions.Zoom="1" PrintOptions.Printer="Microsoft Print to PDF" ReportOptions.CreateDate="43480,5640806944" ReportOptions.Description.Text="" ReportOptions.LastChange="43703,5652986111" ScriptLanguage="PascalScript" ScriptText.Text="procedure Page1OnBeforePrint(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;  with Page1, Engine do&#13;&#10;  begin&#13;&#10;  ProcedenciaAnt := 'Se inicia la variable';&#13;&#10;  Cambio:=1;&#13;&#10;  end&#13;&#10;end;&#13;&#10;&#13;&#10;procedure bDetalleOnBeforePrint(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;  with bDetalle, Engine do&#13;&#10;  begin&#13;&#10;  // Altura normal de la banta&#13;&#10;  Height := 16;&#13;&#10;  cambio := 0;&#13;&#10;&#13;&#10;  // Si debo imprimir la procedencia, duplico la altura de la banda&#13;&#10;  if (ProcedenciaAnt &#60;&#62; [Proc]) then&#13;&#10;  begin&#13;&#10;     ProcedenciaAnt := [Proc];&#13;&#10;     Height := 32;&#13;&#10;     cambio := 1;&#13;&#10;  end;&#13;&#10;&#13;&#10;  // La altura de la banda debe ser mayor si hay PRO_NUM_PLANO&#13;&#10;  if (&#60;frxDBDSDetalle.&#34;PRO_NUM_PLANO&#34;&#62; &#60;&#62; '') then&#13;&#10;     Height := Height + 16;&#13;&#10;&#13;&#10;  // Las notas se imprimen solamente si hay algo escrito.&#13;&#10;  // CRC_NOTAS &#60;&#62; '' y &#60;&#62; '00000000' indica que hay algo en el campo NOTAS.&#13;&#10;  Hija1.Visible := ((&#60;frxDBDSDetalle.&#34;CRC_NOTAS&#34;&#62; &#60;&#62; '00000000') and (&#60;frxDBDSDetalle.&#34;CRC_NOTAS&#34;&#62; &#60;&#62; ''));&#13;&#10;  end&#13;&#10;end;&#13;&#10;&#13;&#10;procedure Band8OnBeforePrint(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;  with Band8, Engine do&#13;&#10;  begin&#13;&#10;  Page2.Visible:= (&#60;frxDBDSCabecera.&#34;TRANSPORTISTA&#34;&#62;= 180);&#13;&#10;  PaginasARestar := 0;&#13;&#10;  if (&#60;frxDBDSCabecera.&#34;TRANSPORTISTA&#34;&#62;= 180)then&#13;&#10;    PaginasARestar := 1;&#13;&#10;  end&#13;&#10;end;&#13;&#10;&#13;&#10;procedure Memo1OnBeforePrint(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;  with Memo1, Engine do&#13;&#10;  begin&#13;&#10;  Top :=  MProcedencia.Top;&#13;&#10;  if (cambio = 1) then&#13;&#10;     Top := bDetalle.Top + 16;&#13;&#10;  end&#13;&#10;end;&#13;&#10;&#13;&#10;procedure Memo13OnBeforePrint(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;  with Memo13, Engine do&#13;&#10;  begin&#13;&#10;  Top := MProcedencia.Top;&#13;&#10;  if (cambio = 1) then&#13;&#10;     Top := MProcedencia.Top + 16;&#13;&#10;  end&#13;&#10;end;&#13;&#10;&#13;&#10;procedure Memo14OnBeforePrint(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;  with Memo14, Engine do&#13;&#10;  begin&#13;&#10;  Top := MProcedencia.Top;&#13;&#10;  if (cambio = 1) then&#13;&#10;     Top := MProcedencia.Top + 16;&#13;&#10;  end&#13;&#10;end;&#13;&#10;&#13;&#10;procedure Memo15OnBeforePrint(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;  with Memo15, Engine do&#13;&#10;  begin&#13;&#10;  Top := MProcedencia.Top;&#13;&#10;  if (cambio = 1) then&#13;&#10;     Top := MProcedencia.Top + 16;&#13;&#10;     end&#13;&#10; end;&#13;&#10;&#13;&#10;procedure Memo18OnBeforePrint(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;  with Memo18, Engine do&#13;&#10;  begin&#13;&#10;  Top := MProcedencia.Top;&#13;&#10;  if (cambio = 1) then&#13;&#10;     Top := MProcedencia.Top + 16;&#13;&#10;      Visible := ([QMCabecera.&#34;ALBARAN_VALORADO&#34;] &#60;&#62; 0);&#13;&#10;  end&#13;&#10;end;&#13;&#10;&#13;&#10;procedure Memo19OnBeforePrint(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;  with Memo19, Engine do&#13;&#10;  begin&#13;&#10;  Top := MProcedencia.Top;&#13;&#10;  if (cambio = 1) then&#13;&#10;     Top := MProcedencia.Top + 16;&#13;&#10;     Visible := ([QMCabecera.&#34;ALBARAN_VALORADO&#34;] &#60;&#62; 0);&#13;&#10;  end&#13;&#10;end;&#13;&#10;&#13;&#10;procedure Memo23OnBeforePrint(Sender: TfrxComponent);