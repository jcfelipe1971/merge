<TfrxHYReport Name="" Version="3.19" DotMatrixReport="False" IniFile="\Software\Fast Reports" PreviewOptions.Buttons="4095" PreviewOptions.Zoom="1" PrintOptions.Printer="Default" ReportOptions.CreateDate="44698,6289329282" ReportOptions.Description.Text="" ReportOptions.LastChange="44776,5373001273" ScriptLanguage="PascalScript" ScriptText.Text="procedure Band2OnBeforePrint(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;  with Band2, Engine do&#13;&#10;  begin&#13;&#10;  if [Page#] = [TotalPages] then&#13;&#10;    TextoPie := 'TOTALES'&#13;&#10;  else&#13;&#10;    TextoPie := 'Suma y Sigue ...';&#13;&#10;  end&#13;&#10;end;&#13;&#10;&#13;&#10;procedure Band4OnBeforePrint(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;&#13;&#10;end;&#13;&#10;&#13;&#10;procedure Memo11OnBeforePrint(Sender: TfrxComponent);&#13;&#10;var&#13;&#10;  DeudorAcreedor: Double;&#13;&#10;begin&#13;&#10;  //Asignamos Deudor-Acreedor&#13;&#10;  DeudorAcreedor := 0;&#13;&#10;  DeudorAcreedor := [MDebemes]-[MHabermes];&#13;&#10;&#13;&#10;  if ((DeudorAcreedor) &#62; 0) then&#13;&#10;  begin&#13;&#10;    Memo11.Text := Format('%2.0n',[ABS(DeudorAcreedor)]);&#13;&#10;    TotalDeudor := TotalDeudor + ABS(DeudorAcreedor);&#13;&#10;  end&#13;&#10;  else&#13;&#10;    Memo11.Text := '0';&#13;&#10;end;&#13;&#10;procedure Memo49OnBeforePrint(Sender: TfrxComponent);&#13;&#10;var&#13;&#10;DeudorAcreedor: Double;&#13;&#10;begin&#13;&#10;  //Asignamos Deudor-Acreedor&#13;&#10;  DeudorAcreedor := [MDebemes]-[MHabermes];&#13;&#10;  if (DeudorAcreedor &#60; 0) then&#13;&#10;  begin&#13;&#10;    Memo49.Text := Format('%2.0n',[ABS(DeudorAcreedor)]);&#13;&#10;    TotalAcreedor := TotalAcreedor + ABS(DeudorAcreedor);&#13;&#10;  end&#13;&#10;  else&#13;&#10;    Memo49.Text := '0'&#13;&#10;end;&#13;&#10;&#13;&#10;procedure Memo18OnBeforePrint(Sender: TfrxComponent);&#13;&#10;var&#13;&#10;Activo: Double;&#13;&#10;digito_cuenta: String;&#13;&#10;begin&#13;&#10;  //Asignamos Deudor-Acreedor&#13;&#10;  Activo := [MDebemes]-[MHabermes];&#13;&#10;  Digito_Cuenta:= Copy([MCuenta], 1, 1);&#13;&#10;&#13;&#10;  if ((Activo &#62; 0) and( StrToInt(Digito_cuenta) &#60; 3)) then&#13;&#10;  begin&#13;&#10;    Memo18.Text := Format('%2.0n',[ABS(Activo)]);&#13;&#10;    TotalActivo := TotalActivo + ABS(Activo);&#13;&#10;  end&#13;&#10;  else&#13;&#10;    Memo18.Text := '0'&#13;&#10;end;&#13;&#10;&#13;&#10;procedure Memo19OnBeforePrint(Sender: TfrxComponent);&#13;&#10;var&#13;&#10;DeudorAcreedor: Double;&#13;&#10;Digito_Cuenta: String;&#13;&#10;begin&#13;&#10;  //Asignamos Deudor-Acreedor&#13;&#10;  Pasivo := [MDebemes]-[MHabermes];&#13;&#10;  Digito_cuenta:= Copy([MCuenta], 1, 1);&#13;&#10;&#13;&#10;  if ((Pasivo &#60; 0) and( StrToInt(Digito_cuenta) &#60; 3)) then&#13;&#10;  begin&#13;&#10;    Memo19.Text := Format('%2.0n',[ABS(Pasivo)]);&#13;&#10;    TotalPasivo := TotalPasivo + ABS(Pasivo);&#13;&#10;  end&#13;&#10;  else&#13;&#10;    Memo19.Text := '0'&#13;&#10;end;&#13;&#10;&#13;&#10;procedure Memo20OnBeforePrint(Sender: TfrxComponent);&#13;&#10;var&#13;&#10;DeudorAcreedor: Double;&#13;&#10;digito_cuenta: String;&#13;&#10;begin&#13;&#10;  //Asignamos Deudor-Acreedor&#13;&#10;  Perdidas := [MDebemes]-[MHabermes];&#13;&#10;  Digito_cuenta:= Copy([MCuenta], 1, 1);&#13;&#10;  if (((Perdidas) &#62; 0)and( StrToInt(Digito_cuenta) &#62;= 3)) then&#13;&#10;  begin&#13;&#10;    Memo20.Text := Format('%2.0n',[ABS(Perdidas)]);&#13;&#10;    TotalPerdidas := TotalPerdidas + ABS(Perdidas);&#13;&#10;  end&#13;&#10;  else&#13;&#10;    Memo20.Text := '0'&#13;&#10;end;&#13;&#10;&#13;&#10;procedure Memo30OnBeforePrint(Sender: TfrxComponent);&#13;&#10;var&#13;&#10;Ganancias: Double;&#13;&#10;Digito_cuenta: String;&#13;&#10;begin&#13;&#10;  //Asignamos Deudor-Acreedor&#13;&#10;  Ganancias := [MDebemes]-[MHabermes];&#13;&#10;  Digito_cuenta:= Copy([MCuenta], 1, 1);&#13;&#10;&#13;&#10;  if (((Ganancias) &#60; 0)and( StrToInt(Digito_cuenta) &#62;= 3)) then&#13;&#10;  begin&#13;&#10;    Memo30.Text := Format('%2.0n',[ABS(Ganancias)]);&#13;&#10;    TotalGanancias := TotalGanancias + ABS(Ganancias);&#13;&#10;  end&#13;&#10;  else&#13;&#10;    Memo30.Text := '0'&#13;&#10;end;&#13;&#10;&#13;&#10;procedure Page1OnBeforePrint(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;&#13;&#10;end;&#13;&#10;&#13;&#10;procedure Memo16OnBeforePrint(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;  TotalDebitos := TotalDebitos + [MDebemes];&#13;&#10;end;&#13;&#10;&#13;&#10;procedure Memo17OnBeforePrint(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;  TotalCreditos := TotalCreditos + [MHabermes];&#13;&#10;end;&#13;&#10;&#13;&#10;begin&#13;&#10;  TotalDebitos := 0;&#13;&#10;  TotalCreditos := 0;&#13;&#10;  TotalDeudor := 0;&#13;&#10;  TotalAcreedor := 0;&#13;&#10;  TotalActivo := 0;&#13;&#10;  TotalPasivo := 0;&#13;&#10;  TotalPerdidas := 0;&#13;&#10;  TotalGanancias := 0;&#13;&#10;end." StoreInDFM="False" FIBOptions.DataSet="DMMain.QListados" FIBOptions.KeyField="LISTADO" FIBOptions.BlobField="DEF_LISTADO" FIBOptions.NameField="TITULO" FIBOptions.GroupField="GRUPO" FIBOptions.TypeField="TIPO" PropData="">
