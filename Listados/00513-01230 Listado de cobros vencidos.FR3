<TfrxHYReport Name="" Version="3.19" DotMatrixReport="False" EngineOptions.DoublePass="True" IniFile="\Software\Fast Reports" PreviewOptions.Buttons="4095" PreviewOptions.Zoom="1" PrintOptions.Printer="Default" ReportOptions.CreateDate="39288,5960132639" ReportOptions.Description.Text="" ReportOptions.LastChange="39294,4901616667" ScriptLanguage="PascalScript" ScriptText.Text="procedure CabeceraDe_grupo1OnBeforePrint(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;  with CabeceraDe_grupo1, Engine do&#13;&#10;  begin&#13;&#10;  CorrienteCli := 0 ;&#13;&#10;  Vto_30Cli    := 0 ;&#13;&#10;  Vto_60Cli    := 0 ;&#13;&#10;  Vto_90Cli    := 0 ;&#13;&#10;  Vto_120Cli   := 0 ;&#13;&#10;  Vto_121Cli   := 0 ;&#13;&#10;  end&#13;&#10;end;&#13;&#10;&#13;&#10;procedure DatosMaestros1OnBeforePrint(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;  with DatosMaestros1, Engine do&#13;&#10;  begin&#13;&#10; Vto_Corriente_Can := Vto_Corriente_Can + [Vto_CorrienteCan];&#13;&#10; Vto_30_Can  := Vto_30_Can  + [Vto_30Can];&#13;&#10; Vto_60_Can  := Vto_60_Can  + [Vto_60Can];&#13;&#10; Vto_90_Can  := Vto_90_Can + [Vto_90Can];&#13;&#10; Vto_120_Can  := Vto_120_Can   + [Vto_120Can];&#13;&#10; Vto_121_Can  := Vto_121_Can  + [Vto_121Can];&#13;&#10;  end&#13;&#10;end;&#13;&#10;&#13;&#10;procedure T_tuloDel_informe1OnBeforePrint(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;  with T_tuloDel_informe1, Engine do&#13;&#10;  begin&#13;&#10;  CorrienteTotal := 0 ;&#13;&#10;  Vto_30Total    := 0 ;&#13;&#10;  Vto_60Total    := 0 ;&#13;&#10;  Vto_90Total    := 0 ;&#13;&#10;  Vto_120Total   := 0 ;&#13;&#10;  Vto_121Total   := 0 ;&#13;&#10;  CorrienteCli   := 0 ;&#13;&#10;  Vto_30Cli      := 0 ;&#13;&#10;  Vto_60Cli      := 0 ;&#13;&#10;  Vto_90Cli      := 0 ;&#13;&#10;  Vto_120Cli     := 0 ;&#13;&#10;  Vto_121Cli     := 0 ;&#13;&#10;  Vto_30_Can     := 0 ;&#13;&#10;  Vto_60_Can     := 0 ;&#13;&#10;  Vto_90_Can     := 0 ;&#13;&#10;  Vto_120_Can    := 0 ;&#13;&#10;  Vto_121_Can    := 0 ;&#13;&#10;  Vto_Corriente_Can:= 0 ;&#13;&#10;  end&#13;&#10;end;&#13;&#10;&#13;&#10;procedure SumarioDel_informe1OnBeforePrint(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;  with SumarioDel_informe1, Engine do&#13;&#10;  begin&#13;&#10;    if (MonedaEntidad=1) then&#13;&#10;      begin&#13;&#10;       AccCorriente := Vto_Corriente_Can;&#13;&#10;       Acc30        := Vto_30_Can;&#13;&#10;       Acc60        := Vto_60_Can;&#13;&#10;       Acc90        := Vto_90_Can;&#13;&#10;       Acc120       := Vto_120_Can;&#13;&#10;       Acc121       := Vto_121_Can;&#13;&#10;      end&#13;&#10;    else&#13;&#10;      begin&#13;&#10;        AccCorriente := CorrienteTotal;&#13;&#10;        Acc30 :=Vto_30Total;&#13;&#10;        Acc60 :=Vto_60Total;&#13;&#10;        Acc90 :=Vto_90Total;&#13;&#10;        Acc120:=Vto_120Total;&#13;&#10;        Acc121:=Vto_121Total;&#13;&#10;      end&#13;&#10;  end&#13;&#10;end;&#13;&#10;&#13;&#10;procedure CabeceraDe_grupo3OnBeforePrint(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;  with CabeceraDe_grupo3, Engine do&#13;&#10;  begin&#13;&#10;  CorrienteCli := 0 ;&#13;&#10;  Vto_30Cli    := 0 ;&#13;&#10;  Vto_60Cli    := 0 ;&#13;&#10;  Vto_90Cli    := 0 ;&#13;&#10;  Vto_120Cli   := 0 ;&#13;&#10;  Vto_121Cli   := 0 ;&#13;&#10;  end&#13;&#10;end;&#13;&#10;&#13;&#10;procedure Memo17OnBeforePrint(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;  with Memo17, Engine do&#13;&#10;  begin&#13;&#10; corrientecli := corrientecli + [corriente];&#13;&#10;  end&#13;&#10;end;&#13;&#10;&#13;&#10;procedure Memo18OnBeforePrint(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;  with Memo18, Engine do&#13;&#10;  begin&#13;&#10; vto_30cli := vto_30cli + [Vto_30];&#13;&#10;  end&#13;&#10;end;&#13;&#10;&#13;&#10;procedure Memo19OnBeforePrint(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;  with Memo19, Engine do&#13;&#10;  begin&#13;&#10; vto_60cli := vto_60cli + [Vto_60];&#13;&#10;  end&#13;&#10;end;&#13;&#10;&#13;&#10;procedure Memo21OnBeforePrint(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;  with Memo21, Engine do&#13;&#10;  begin&#13;&#10; CorrienteTotal := CorrienteTotal + CorrienteCli;&#13;&#10;  end&#13;&#10;end;&#13;&#10;&#13;&#10;procedure Memo22OnBeforePrint(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;  with Memo22, Engine do&#13;&#10;  begin&#13;&#10; vto_90cli := vto_90cli + [Vto_90];&#13;&#10;  end&#13;&#10;end;&#13;&#10;&#13;&#10;procedure Memo23OnBeforePrint(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;  with Memo23, Engine do&#13;&#10;  begin&#13;&#10; vto_120cli := vto_120cli + [Vto_120];&#13;&#10;  end&#13;&#10;end;&#13;&#10;&#13;&#10;procedure Memo24OnBeforePrint(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;  with Memo24, Engine do&#13;&#10;  begin&#13;&#10; vto_121cli := vto_121cli + [Vto_120];&#13;&#10;  end&#13;&#10;end;&#13;&#10;&#13;&#10;procedure Memo26OnBeforePrint(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;  with Memo26, Engine do&#13;&#10;  begin&#13;&#10;  visible := ProvAcr ;&#13;&#10;  end&#13;&#10;end;&#13;&#10;&#13;&#10;procedure Memo28OnBeforePrint(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;  with Memo28, Engine do&#13;&#10;  begin&#13;&#10;  Vto_30Total := Vto_30Total + Vto_30Cli;&#13;&#10;  end&#13;&#10;end;&#13;&#10;&#13;&#10;procedure Memo29OnBeforePrint(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;  with Memo29, Engine do&#13;&#10;  begin&#13;&#10;  Vto_60Total := Vto_60Total + Vto_60Cli;&#13;&#10;  end&#13;&#10;end;&#13;&#10;&#13;&#10;procedure Memo30OnBeforePrint(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;  with Memo30, Engine do&#13;&#10;  begin&#13;&#10;  Vto_90Total := Vto_90Total+ Vto_90Cli;&#13;&#10;  end&#13;&#10;end;&#13;&#10;&#13;&#10;procedure Memo31OnBeforePrint(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;  with Memo31, Engine do&#13;&#10;  begin&#13;&#10;  Vto_120Total := Vto_120Total + Vto_120Cli;&#13;&#10;  end&#13;&#10;end;&#13;&#10;&#13;&#10;procedure Memo32OnBeforePrint(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;  with Memo32, Engine do&#13;&#10;  begin&#13;&#10;  Vto_121Total := Vto_121Total + Vto_121Cli;&#13;&#10;  end&#13;&#10;end;&#13;&#10;&#13;&#10;begin&#13;&#10;&#13;&#10;end." StoreInDFM="False" FIBOptions.DataSet="DMMain.QListados" FIBOptions.KeyField="LISTADO" FIBOptions.BlobField="DEF_LISTADO" FIBOptions.NameField="TITULO" FIBOptions.GroupField="GRUPO" FIBOptions.TypeField="TIPO" PropData="">
