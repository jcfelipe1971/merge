<TfrxHYReport Name="" Version="3.19" DotMatrixReport="False" EngineOptions.DoublePass="True" IniFile="\Software\Fast Reports" PreviewOptions.Buttons="4095" PreviewOptions.Zoom="1" PrintOptions.Printer="Por defecto" ReportOptions.CreateDate="43644,4326313773" ReportOptions.Description.Text="" ReportOptions.LastChange="45222,3732036343" ScriptLanguage="PascalScript" ScriptText.Text="procedure Page1OnBeforePrint(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;  with Page1, Engine do&#13;&#10;  begin&#13;&#10;  ProcedenciaAnt := 'Se inicia la variable';&#13;&#10;  Cambio:=1;&#13;&#10;  end&#13;&#10;end;&#13;&#10;&#13;&#10;procedure bDetalleOnBeforePrint(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;  with bDetalle, Engine do&#13;&#10;  begin&#13;&#10;  // Altura normal de la banda&#13;&#10;  Height := 24;&#13;&#10;  cambio := 0;&#13;&#10;&#13;&#10;  if (ProcedenciaAnt &#60;&#62; [Proc]) then&#13;&#10;     // PesoIEPNR := PesoIEPNR + [QMCartaPorteAlb.&#34;PESO_BRUTO&#34;];&#13;&#10;&#13;&#10;  // Si debo imprimir la procedencia, duplico la altura de la banda&#13;&#10;   if (ProcedenciaAnt &#60;&#62; [Proc]) then&#13;&#10;  begin&#13;&#10;     ProcedenciaAnt := [Proc];&#13;&#10;     Height := Height + 16;&#13;&#10;     cambio := 1;&#13;&#10;  end;&#13;&#10;&#13;&#10;  // La altura de la banda debe ser mayor si hay PRO_NUM_PLANO&#13;&#10;  // if ([QMDetalle.&#34;NOTAS&#34;] &#60;&#62; '') then&#13;&#10;  //   Height := Height + 16;&#13;&#10;&#13;&#10;  // Las notas se imprimen solamente si hay algo escrito.&#13;&#10;  // CRC_NOTAS &#60;&#62; '' y &#60;&#62; '00000000' indica que hay algo en el campo NOTAS.&#13;&#10;  Child1.Visible := (([QMDetalle.&#34;CRC_NOTAS&#34;] &#60;&#62; '00000000') and ([QMDetalle.&#34;CRC_NOTAS&#34;] &#60;&#62; '')) or ([QMDetalle.&#34;NOTAS&#34;] &#62; ' ');&#13;&#10;  end&#13;&#10;end;&#13;&#10;&#13;&#10;procedure Memo23OnBeforePrint(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;    with Memo23, Engine do&#13;&#10;  begin&#13;&#10;  ProcedenciaAnt := '';&#13;&#10;  Cambio:=1;&#13;&#10;  PedidoAnt := '';&#13;&#10;  Cambio2:=1;&#13;&#10;  end&#13;&#10;end;&#13;&#10;&#13;&#10;procedure MProcedenciaOnBeforePrint(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10; with MProcedencia, Engine do&#13;&#10;  begin&#13;&#10;  visible := (Cambio = 1) and ([QSPProcedencia.&#34;RIG_O&#34;] &#60;&#62; 0);&#13;&#10;  end&#13;&#10;end;&#13;&#10;&#13;&#10;procedure MArticuloOnBeforePrint(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;  with MArticulo, Engine do&#13;&#10;  begin&#13;&#10;    // Imprimimos Memos debajo de Procedencia, si se imprime procedencia&#13;&#10;    Top := MProcedencia.Top;&#13;&#10;    if (Cambio = 1) then&#13;&#10;       Top := MProcedencia.Top + 16;&#13;&#10;&#13;&#10;    // Alineamos el resto de memos de la línea con el de código de articulo&#13;&#10;    Memo15.Top := Top;&#13;&#10;    Memo3.Top := Top;&#13;&#10;    Memo6.Top := Top;&#13;&#10;    Memo110.Top := Top;&#13;&#10;    Memo19.Top := Top;&#13;&#10;&#13;&#10;    Memo19.Visible := ([Total]&#60;&#62;0);&#13;&#10;  end&#13;&#10;end;&#13;&#10;&#13;&#10;begin&#13;&#10;&#13;&#10;end." StoreInDFM="False" FIBOptions.DataSet="DMMain.QListados" FIBOptions.KeyField="LISTADO" FIBOptions.BlobField="DEF_LISTADO" FIBOptions.NameField="TITULO" FIBOptions.GroupField="GRUPO" FIBOptions.TypeField="TIPO" PropData="">
