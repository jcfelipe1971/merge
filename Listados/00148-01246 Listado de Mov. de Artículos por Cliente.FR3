<TfrxHYReport Name="" Version="3.19" DotMatrixReport="False" EngineOptions.DoublePass="True" IniFile="\Software\Fast Reports" PreviewOptions.Buttons="4095" PreviewOptions.Zoom="1" PrintOptions.Printer="Default" ReportOptions.CreateDate="39289,7364201736" ReportOptions.Description.Text="" ReportOptions.LastChange="39294,4984239352" ScriptLanguage="PascalScript" ScriptText.Text="procedure ReportTitle1OnBeforePrint(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;  FiltroSerie := false;&#13;&#10;  Acum_U_E:=0;&#13;&#10;  Acum_U_S:=0;&#13;&#10;  Acum_V_E:=0;&#13;&#10;  Acum_V_S:=0;&#13;&#10;end;&#13;&#10;&#13;&#10;procedure Band6OnBeforePrint(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;&#13;&#10;  with Band6, Engine do&#13;&#10;  begin&#13;&#10;    U_E := 0;&#13;&#10;    V_E := 0;&#13;&#10;    U_S := 0;&#13;&#10;    V_S := 0;&#13;&#10;&#13;&#10;    // [Unidades Entrada]&#13;&#10;    if (([xArt_Mov_Stock.&#34;TIPO_OPER&#34;] = 'E') or&#13;&#10;        ([xArt_Mov_Stock.&#34;TIPO_OPER&#34;] = 'A') or&#13;&#10;        ([xArt_Mov_Stock.&#34;TIPO_OPER&#34;] = 'D')) then&#13;&#10;      U_E := U_E + [xArt_Mov_Stock.&#34;UNIDADES&#34;];&#13;&#10;    {else&#13;&#10;      Acum_U_E := Acum_U_E + 0; }&#13;&#10;&#13;&#10;    // [Valor Entrada]&#13;&#10;    if (([xArt_Mov_Stock.&#34;TIPO_OPER&#34;] = 'E') or&#13;&#10;        ([xArt_Mov_Stock.&#34;TIPO_OPER&#34;] = 'A') or&#13;&#10;        ([xArt_Mov_Stock.&#34;TIPO_OPER&#34;] = 'D')) then&#13;&#10;      V_E := V_E + [xArt_Mov_Stock.&#34;IMPORTE&#34;];&#13;&#10;&#13;&#10;    // [Unidades Salida]&#13;&#10;    if (([xArt_Mov_Stock.&#34;TIPO_OPER&#34;] = 'S') or&#13;&#10;        ([xArt_Mov_Stock.&#34;TIPO_OPER&#34;] = 'C') or&#13;&#10;        ([xArt_Mov_Stock.&#34;TIPO_OPER&#34;] = 'O')) then&#13;&#10;      U_S := U_S + [xArt_Mov_Stock.&#34;UNIDADES&#34;];&#13;&#10;&#13;&#10;    // [Valor Salida]&#13;&#10;    if (([xArt_Mov_Stock.&#34;TIPO_OPER&#34;] = 'S') or&#13;&#10;        ([xArt_Mov_Stock.&#34;TIPO_OPER&#34;] = 'C') or&#13;&#10;        ([xArt_Mov_Stock.&#34;TIPO_OPER&#34;] = 'O')) then&#13;&#10;      V_S := V_S + [xArt_Mov_Stock.&#34;IMPORTE&#34;];&#13;&#10;&#13;&#10;    Acum_U_E := Acum_U_E + U_E;&#13;&#10;    Acum_U_S := Acum_U_S + U_S;&#13;&#10;    Acum_V_E := Acum_V_E + V_E;&#13;&#10;    Acum_V_S := Acum_V_S + V_S;&#13;&#10;&#13;&#10;    Acum_U_E_aux := Acum_U_E_aux + U_E;&#13;&#10;    Acum_U_S_aux := Acum_U_S_aux + U_S;&#13;&#10;    Acum_V_E_aux := Acum_V_E_aux + V_E;&#13;&#10;    Acum_V_S_aux := Acum_V_S_aux + V_S;&#13;&#10;  end&#13;&#10;&#13;&#10;end;&#13;&#10;&#13;&#10;procedure CBSerieOnBeforePrint(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;  with CBSerie, Engine do&#13;&#10;  begin&#13;&#10;  Visible := FiltroSerie;&#13;&#10;  end&#13;&#10;end;&#13;&#10;&#13;&#10;procedure Memo52OnBeforePrint(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;  with Memo52, Engine do&#13;&#10;  begin&#13;&#10;    Visible := FiltroSerie;&#13;&#10;  end;&#13;&#10;  if (not FiltroSerie) then&#13;&#10;    CBSerie.Condition := '0=0';&#13;&#10;end;&#13;&#10;&#13;&#10;procedure Memo3OnBeforePrint(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;  if [xArt_Mov_Stock.&#34;TIPO_OPER&#34;] = 'O' then&#13;&#10;     Memo3.Text := 'S'&#13;&#10;  else&#13;&#10;    if [xArt_Mov_Stock.&#34;TIPO_OPER&#34;] = 'D' then&#13;&#10;       Memo3.Text := 'E'&#13;&#10;    else&#13;&#10;      Memo3.Text := [xArt_Mov_Stock.&#34;TIPO_OPER&#34;];&#13;&#10;end;&#13;&#10;&#13;&#10;procedure Memo37OnBeforePrint(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;&#13;&#10;end;&#13;&#10;&#13;&#10;procedure Band8OnBeforePrint(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;  Acum_U_E_aux := 0;&#13;&#10;  Acum_U_S_aux := 0;&#13;&#10;  Acum_V_E_aux := 0;&#13;&#10;  Acum_V_S_aux := 0;&#13;&#10;end;&#13;&#10;&#13;&#10;procedure Memo2OnAfterPrint(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;  FiltroSerie := (Trim(upperCase(Memo2.Text))) = 'TRUE';&#13;&#10;end;&#13;&#10;&#13;&#10;begin&#13;&#10;&#13;&#10;end." StoreInDFM="False" FIBOptions.DataSet="DMMain.QListados" FIBOptions.KeyField="LISTADO" FIBOptions.BlobField="DEF_LISTADO" FIBOptions.NameField="TITULO" FIBOptions.GroupField="GRUPO" FIBOptions.TypeField="TIPO" PropData="">
