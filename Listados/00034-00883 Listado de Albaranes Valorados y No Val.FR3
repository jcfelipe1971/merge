<TfrxHYReport Name="" Version="3.19" DotMatrixReport="False" IniFile="\Software\Fast Reports" PreviewOptions.Buttons="4095" PreviewOptions.Zoom="1" PrintOptions.Printer="Default" ReportOptions.CreateDate="38688,4546448264" ReportOptions.Description.Text="" ReportOptions.LastChange="38848,693905162" ScriptLanguage="PascalScript" ScriptText.Text="var&#13;&#10;  ProcedenciaAnt : string;&#13;&#10;  Cambio         : Boolean;&#13;&#10;  Valorado       : Boolean;&#13;&#10;&#13;&#10;&#13;&#10;procedure Band4OnBeforePrint(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;  with Band4, Engine do&#13;&#10;  begin&#13;&#10;    if [QMCabecera.&#34;ESTADO&#34;]=2 then&#13;&#10;      Visible := True&#13;&#10;    else&#13;&#10;      Visible := False;&#13;&#10;  end&#13;&#10;end;&#13;&#10;&#13;&#10;procedure bDetalleOnBeforePrint(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;  with bDetalle, Engine do&#13;&#10;  begin&#13;&#10;    if [Proc]=ProcedenciaAnt then&#13;&#10;    begin&#13;&#10;      Height := 18;&#13;&#10;      Cambio := False;&#13;&#10;    end&#13;&#10;    else&#13;&#10;      begin&#13;&#10;        ProcedenciaAnt := [Proc];&#13;&#10;        Height := 36;&#13;&#10;        Cambio := True;&#13;&#10;      end;&#13;&#10;&#13;&#10;    if [QMDetalle.&#34;NOTAS&#34;] &#60;&#62; '' then&#13;&#10;      bNotasArt.Visible := True&#13;&#10;    else&#13;&#10;      bNotasArt.Visible := False;&#13;&#10;  end&#13;&#10;end;&#13;&#10;&#13;&#10;procedure Band2OnBeforePrint(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;  with Band2, Engine do&#13;&#10;  begin&#13;&#10;    Set(&#60;Inc_Pagina&#62;,0);&#13;&#10;  end;&#13;&#10;  Band2.Visible := Valorado;&#13;&#10;end;&#13;&#10;&#13;&#10;procedure bPromocionesOnBeforePrint(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;  with bPromociones, Engine do&#13;&#10;  begin&#13;&#10;    //Height  := 30;&#13;&#10;    Visible := [DetalleVisible];&#13;&#10;    if [frxDBPromociones.&#34;NOTAS&#34;] = '' then&#13;&#10;      SubReport1.Height := 0&#13;&#10;    else&#13;&#10;      SubReport1.Height := 17;&#13;&#10;  end&#13;&#10;end;&#13;&#10;&#13;&#10;procedure Memo7OnBeforePrint(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;  with Memo7, Engine do&#13;&#10;  begin&#13;&#10;    if [PieVisible] = 1 then Visible := True&#13;&#10;    else Visible := False&#13;&#10;  end&#13;&#10;end;&#13;&#10;&#13;&#10;procedure Memo20OnBeforePrint(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;  with Memo20, Engine do&#13;&#10;  begin&#13;&#10;    if [PieVisible]=1 then Visible := True&#13;&#10;    else Visible := False;&#13;&#10;  end&#13;&#10;end;&#13;&#10;&#13;&#10;procedure Memo21OnBeforePrint(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;  with Memo21, Engine do&#13;&#10;  begin&#13;&#10;    if [PieVisible]=1 then Visible := True&#13;&#10;    else Visible := False;&#13;&#10;  end&#13;&#10;end;&#13;&#10;&#13;&#10;procedure Memo22OnBeforePrint(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;  with Memo22, Engine do&#13;&#10;  begin&#13;&#10;    if [PieVisible]=1 then visible := True&#13;&#10;    else visible := False;&#13;&#10;  end&#13;&#10;end;&#13;&#10;&#13;&#10;procedure Memo23OnBeforePrint(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;  with Memo23, Engine do&#13;&#10;  begin&#13;&#10;    if [PieVisible]=1 then visible := True&#13;&#10;    else visible := False;&#13;&#10;  end&#13;&#10;end;&#13;&#10;&#13;&#10;procedure Memo28OnBeforePrint(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;  with Memo28, Engine do&#13;&#10;  begin&#13;&#10;    if [PieVisible]=1 then visible := True&#13;&#10;    else visible := False;&#13;&#10;  end&#13;&#10;end;&#13;&#10;&#13;&#10;procedure Memo29OnBeforePrint(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;  with Memo29, Engine do&#13;&#10;  begin&#13;&#10;    if [PieVisible]=1 then visible := True&#13;&#10;    else visible := False;&#13;&#10;  end&#13;&#10;end;&#13;&#10;&#13;&#10;procedure Memo30OnBeforePrint(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;  with Memo30, Engine do&#13;&#