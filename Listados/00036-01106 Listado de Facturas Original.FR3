<TfrxHYReport Name="" Version="3.19" DotMatrixReport="False" IniFile="\Software\Fast Reports" PreviewOptions.Buttons="4095" PreviewOptions.Zoom="1" PrintOptions.Printer="Default" ReportOptions.CreateDate="38687,7006989468" ReportOptions.Description.Text="" ReportOptions.LastChange="39294,7778010995" ScriptLanguage="PascalScript" ScriptText.Text="var&#13;&#10;  ProcedenciaAnt: String;&#13;&#10;  Cambio: Boolean;&#13;&#10;&#13;&#10;procedure Page1OnBeforePrint(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;  ProcedenciaAnt := '';&#13;&#10;  Cambio := True;&#13;&#10;end;&#13;&#10;&#13;&#10;procedure bDetalleOnBeforePrint(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;  with bDetalle do&#13;&#10;  begin&#13;&#10;    if [Proc] = ProcedenciaAnt then&#13;&#10;    begin&#13;&#10;      Height := 17;&#13;&#10;      Cambio := False;&#13;&#10;    end&#13;&#10;    else&#13;&#10;    begin&#13;&#10;      ProcedenciaAnt := [Proc];&#13;&#10;      Height := 35;&#13;&#10;      Cambio := True;&#13;&#10;    end;&#13;&#10;    bSubDetSeries.Visible := True;&#13;&#10;  end;&#13;&#10;  bNotasArt.Visible := &#60;NotasDet&#62; &#60;&#62; '';&#13;&#10;end;&#13;&#10;&#13;&#10;procedure bNotasArtOnBeforePrint(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;  //bNotasArt.Height := 0;&#13;&#10;end;&#13;&#10;&#13;&#10;procedure bPromocionesOnBeforePrint(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;  with bPromociones do&#13;&#10;  begin&#13;&#10;    //Height  := 17;&#13;&#10;    Visible := [DetalleVisible];&#13;&#10;    if &#60;NotasArtPRM&#62; = '' then&#13;&#10;      Height := 17&#13;&#10;    else&#13;&#10;      Height := 36;&#13;&#10;  end;&#13;&#10;end;&#13;&#10;&#13;&#10;procedure Memo13OnBeforePrint(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;  with Memo13 do&#13;&#10;  begin&#13;&#10;    if not Cambio then&#13;&#10;      Top := 1&#13;&#10;    else&#13;&#10;      Top := 19;&#13;&#10;  end&#13;&#10;end;&#13;&#10;&#13;&#10;procedure Memo14OnBeforePrint(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;  with Memo14 do&#13;&#10;  begin&#13;&#10;    if not Cambio then&#13;&#10;      Top := 1&#13;&#10;    else&#13;&#10;      Top := 19;&#13;&#10;  end&#13;&#10;end;&#13;&#10;&#13;&#10;procedure Memo15OnBeforePrint(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;  with Memo15 do&#13;&#10;  begin&#13;&#10;    if not Cambio then&#13;&#10;      Top := 1&#13;&#10;    else&#13;&#10;      Top := 19;&#13;&#10;  end&#13;&#10;end;&#13;&#10;&#13;&#10;procedure Memo17OnBeforePrint(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;  with Memo17 do&#13;&#10;  begin&#13;&#10;    if not Cambio then&#13;&#10;      Top := 1&#13;&#10;    else&#13;&#10;      Top := 19;&#13;&#10;  end&#13;&#10;end;&#13;&#10;&#13;&#10;procedure Memo18OnBeforePrint(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;  with Memo18 do&#13;&#10;  begin&#13;&#10;    if not Cambio then&#13;&#10;      Top := 1&#13;&#10;    else&#13;&#10;      Top := 19;&#13;&#10;  end&#13;&#10;end;&#13;&#10;&#13;&#10;procedure Memo19OnBeforePrint(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;  with Memo19 do&#13;&#10;  begin&#13;&#10;    if not Cambio then&#13;&#10;      Top := 1&#13;&#10;    else&#13;&#10;      Top := 19;&#13;&#10;  end&#13;&#10;end;&#13;&#10;&#13;&#10;procedure Memo11OnBeforePrint(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;  with Memo11 do&#13;&#10;  begin&#13;&#10;    if not Cambio then&#13;&#10;      Top := 1&#13;&#10;    else&#13;&#10;      Top := 19;&#13;&#10;  end&#13;&#10;end;&#13;&#10;&#13;&#10;procedure Memo33OnBeforePrint(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;  with Memo33 do&#13;&#10;  begin&#13;&#10;    if not Cambio then&#13;&#10;      Top := 1&#13;&#10;    else&#13;&#10;      Top := 19;&#13;&#10;  end&#13;&#10;end;&#13;&#10;&#13;&#10;procedure Memo66OnBeforePrint(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;  with Memo66, Engine do&#13;&#10;  begin&#13;&#10;    if ([Moneda]= [Moneda_Sec]) then&#13;&#10;      Visible := False&#13;&#10;     else&#13;&#10;      Visible := True;&#13;&#10;  end&#13;&#10;end;&#13;&#10;&#13;&#10;procedure Memo67OnBeforePrint(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;  with Memo67, Engine do&#13;&#10;  begin&#13;&#10;    if ([Moneda]= [Moneda_Sec]) then&#13;&#10;      Visible := False&#13;&#10;    else&#13;&#10;      Visible:= True;&#13;&#10;  end&#13;&#10;end;&#13;&#10;&#13;&#10;procedure MemoProcedenciaOnBeforePrint(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;  with MemoProcedencia do&#13;&#10;  begin&#13;&#10;    if Cambio then&#13;&#10;      Visible := True&#13;&#10;    else&#13;&#10;      Visible := False;&#13;&#10;  end&#13;&#10;end;&#13;&#10;&#13;&#10;procedure Memo23OnBeforePrint(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;  ProcedenciaAnt := '';&#13;&#10;  Cambio := True;&#13;&#10;end;&#13;&#10;&#13;&#10;procedure Memo74OnBeforePrint(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;  with Memo74 do&#13;&#10;  begin&#13;&#10;    Visible := [PorteVisible]&#13;&#10;  end&#13;&#10;end;&#13;&#10;&#13;&#10;procedure Footer1OnBeforePrint(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;  bSubDetSeries.Visible := False;&#13;&#10;end;&#13;&#10;&#13;&#10;begin&#13;&#10;&#13;&#10;end." StoreInDFM="False" FIBOptions.DataSet="DMMain.QListados" FIBOptions.KeyField="LISTADO" FIBOptions.BlobField="DEF_LISTADO" FIBOptions.NameField="TITULO" FIBOptions.GroupField="GRUPO" FIBOptions.TypeField="TIPO" PropData="">
