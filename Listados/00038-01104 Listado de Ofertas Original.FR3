c])&#13;&#10;      then visible:= False&#13;&#10;      else visible:= True;&#13;&#10;  end&#13;&#10;end;&#13;&#10;&#13;&#10;procedure Memo14OnBeforePrint(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;  with Memo14, Engine do&#13;&#10;  begin&#13;&#10;    If ([Moneda]= [Moneda_Sec])&#13;&#10;      then visible:= False&#13;&#10;      else visible:= True;&#13;&#10;  end&#13;&#10;end;&#13;&#10;&#13;&#10;begin&#13;&#10;  Set('Num_Pagina', 1);&#13;&#10;end." StoreInDFM="False" FIBOptions.DataSet="DMMain.QListados" FIBOptions.KeyField="LISTADO" FIBOptions.BlobField="DEF_LISTADO" FIBOptions.NameField="TITULO" FIBOptions.GroupField="GRUPO" FIBOptions.TypeField="TIPO" PropData="">
