{$R *.DFM}

procedure TCrmFMContactos.FormCreate(Sender: TObject);
var
  Apertura, Cierre : TDateTime;
begin
  inherited;
  DragAcceptFiles(Self.Handle, True);
  AbreData(TCrmDMContactos, CrmDMContactos);

  CampoOrdenDetalleVentas := '';

  NavMain.DataSource := CrmDMContactos.DSQMContactos;
  DBGMain.DataSource := CrmDMContactos.DSQMContactos;
  G2kTableLoc.Base_de_datos := DMMain.DataBase;
  G2kTableLoc.DataSource := CrmDMContactos.DSQMContactos;
  NavContPers.DataSource := CrmDMContactos.DSQMPersonas;

  RellenaSeries(CBSerieVenta.Items);
  CBSerieVenta.ItemIndex := 0;

  DameMinMax('EJE', Apertura, Cierre);
  if (DEFechaVentasDesde.Date < EncodeDate(1900, 1, 1)) then
     DEFechaVentasDesde.Date := Apertura;
  if (DEFechaVentasHasta.Date < EncodeDate(1900, 1, 1)) then
     DEFechaVentasHasta.Date := Cierre;

  CBTipoDocumento.Text := 'FAC';
  CBTipoDocumento.ItemIndex := 4;

  DBEComentario.Enabled := False;
  DBEComentario.ReadOnly := True;

  PCVentas.ActivePage := TSVentasDocumentos;

  HabilitaEnlaces;

  // De momento ocultamos el botón hasta restablecer el código.
  TBDocs.Visible := False;

  SolapaControles(SBAGaleria, ETituloGaleria);
  ETituloGaleria.Color := REntorno.ColorEnlaceActivo;

  // sfg.albert - Web
  SolapaControles(SBAWeb, DBEWeb);
  DBEWeb.Color := REntorno.ColorEnlaceActivo;

  // sfg.albert - Mail
  SolapaControles(SBACorreu, DBEEmail);
  DBEEmail.Color := REntorno.ColorEnlaceActivo;
  //DBEEMail.Font.Style:=[fsUnderline];

  // sfg.albert - GoogleMaps
  SolapaControles(SBAGoogle, DBELinkGoogle);
  DBELinkGoogle.Color := REntorno.ColorEnlaceActivo;

  // sfg.albert - Documento asociado
  SolapaControles(SBADoc, LFDBDoc);
  LFDBDoc.Color := REntorno.ColorEnlaceActivo;

  SWFil := 0;
  EditandoDesdeFicha := False;

  // Color campo ID
  ColorCampoID(DBEIdContacto);
end;

procedure TCrmFMContactos.FormClose(Sender: TObject; var Action: TCloseAction);
begin
  inherited;
  // Cierro los DataSets para evitar actualizaciones de componentes durante el cierre que toman datos del DataModule.
  CrmDMContactos.CerrarDataSets;
end;

procedure TCrmFMContactos.FormDestroy(Sender: TObject);
begin
  inherited;
  CierraData(CrmDMContactos);
end;

procedure TCrmFMContactos.FormShow(Sender: TObject);
begin
  inherited;
  AgenteUsuario := DameAgenteUsuario(REntorno.Usuario);

  if (AgenteUsuario <> 0) then
     EFAgenteFiltro.Text := IntToStr(AgenteUsuario);

  if (DameRestriccionAgenteUsuario(REntorno.Usuario)) then
  begin
     G2KTableLoc.CondicionBusqueda := 'AGENTE = ' + IntToStr(AgenteUsuario);

     with DBEAgenteEmp do
     begin
        CondicionBusqueda := 'AGENTE = ' + IntToStr(AgenteUsuario);
        Enabled := False;
        ReadOnly := True;
        Color := clInfoBK;
     end;

     with EFAgenteFiltro do
     begin
        CondicionBusqueda := 'AGENTE = ' + IntToStr(AgenteUsuario);
        Enabled := False;
        ReadOnly := True;
        Color := clInfoBK;
     end;

     BLimpiaFiltroAgente.Visible := False;
  end
  else
  begin
     G2KTableLoc.CondicionBusqueda := '';

     with DBEAgenteEmp do
     begin
        CondicionBusqueda := 'AGENTE = ' + IntToStr(AgenteUsuario);
        Enabled := True;
        ReadOnly := False;
        Color := clInfoBK;
     end;

     with EFAgenteFiltro do
     begin
        CondicionBusqueda := 'AGENTE = ' + IntToStr(AgenteUsuario);
        Enabled := True;
        ReadOnly := False;
        Color := clInfoBK;
     end;

     BLimpiaFiltroAgente.Visible := True;
  end;

  EFAgenteFiltroChange(Sender);
end;

