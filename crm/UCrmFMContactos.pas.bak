procedure TCrmFMContactos.DBGMainDrawColumnCell(Sender: TObject; const Rect: TRect; DataCol: integer; Column: TColumn; State: TGridDrawState);
begin
  inherited;
  with THYTDBGrid(Sender) do
  begin
     if (gdFocused in State) then //If the cell has the focus
        ColorFocused(Canvas)
     else
     begin
        if (UpperCase(Column.FieldName) = 'FECHA_ULTIMA_VISITA') then
        begin
           if ((not CrmDMContactos.QMContactosFECHA_ULTIMA_VISITA.IsNull) and (CrmDMContactos.QMContactosDIAS_ENTRE_VISITAS.AsInteger <> 0)) then
              if ((Today - CrmDMContactos.QMContactosFECHA_ULTIMA_VISITA.AsDateTime) > CrmDMContactos.QMContactosDIAS_ENTRE_VISITAS.AsInteger) then
                 ColorResaltado6(Canvas);
        end;
     end;

     DefaultDrawColumnCell(Rect, DataCol, Column, State);
  end;
end;

procedure TCrmFMContactos.DBEIdContactoChange(Sender: TObject);
begin
  inherited;
  if ((not CrmDMContactos.QMContactosFECHA_ULTIMA_VISITA.IsNull) and (CrmDMContactos.QMContactosDIAS_ENTRE_VISITAS.AsInteger <> 0)) then
  begin
     if ((Today - CrmDMContactos.QMContactosFECHA_ULTIMA_VISITA.AsDateTime) > CrmDMContactos.QMContactosDIAS_ENTRE_VISITAS.AsInteger) then
        ColorResaltado(DBDEFechaUltimaVisita);
  end
  else
     ColorEdicion(DBDEFechaUltimaVisita);

  HabilitaEnlaces;
end;

procedure TCrmFMContactos.DBCBRutaExit(Sender: TObject);
begin
  inherited;
  if CrmDMContactos.QMContactos.State in [dsInsert, dsEdit] then
     CrmDMContactos.QMContactosID_RUTA.AsInteger := integer(DBCBRuta.Items.Objects[DBCBRuta.ItemIndex]);
end;

procedure TCrmFMContactos.EFAgenteFiltroChange(Sender: TObject);
var
  Agente, IdRuta : integer;
begin
  inherited;
  Agente := StrToIntDef(EFAgenteFiltro.Text, 0);
  if (Agente > 0) then
     EAgenteFiltro.Text := DameTituloAgente(Agente)
  else
     EAgenteFiltro.Text := _('Todos');

  RellenaRutasAgentes(Agente, CBRutaFiltro.Items, True, False);
  CBRutaFiltro.ItemIndex := 0;

  IdRuta := 0;
  if (CBRutaFiltro.ItemIndex >= 0) then
     IdRuta := integer(CBRutaFiltro.Items.Objects[CBRutaFiltro.ItemIndex]);
  CrmDMContactos.FiltraAgente(Agente, IdRuta);
end;

procedure TCrmFMContactos.CBRutaFiltroChange(Sender: TObject);
var
  Agente, IdRuta : integer;
begin
  inherited;
  Agente := StrToIntDef(EFAgenteFiltro.Text, 0);
  IdRuta := 0;
  if (CBRutaFiltro.ItemIndex >= 0) then
     IdRuta := integer(CBRutaFiltro.Items.Objects[CBRutaFiltro.ItemIndex]);
  CrmDMContactos.FiltraAgente(Agente, IdRuta);
end;

procedure TCrmFMContactos.AExportarEmailExecute(Sender: TObject);
var
  Fichero : string;
begin
  inherited;
  Fichero := Format(_('Correos_%s.csv'), [FormatDateTime('yyyymmdd_hhnnss', Now)]);
  if MySaveDialog(Fichero, 'CSV', '', 'CrmFMContactos') then
     CrmDMContactos.ExportarCorreos(Fichero);
end;

procedure TCrmFMContactos.WMDropFiles(var Msg: TWMDropFiles);
var
  i : integer;
  DropPoint : TPoint;
  RecibeFicheros : TRecibeFicheros;
  Ficheros : TStrings;
begin
  inherited;
  Ficheros := TStringList.Create;
  RecibeFicheros := TRecibeFicheros.Create(Msg.Drop);
  try
     for i := 0 to Pred(RecibeFicheros.FileCount) do
        Ficheros.Add(RecibeFicheros.Files[i]);

     DropPoint := RecibeFicheros.DropPoint;

     if ConfirmaMensaje(_('Esta seguro de importar los archivos?' + #13#10 + Ficheros.Text)) then
     begin
        AbreData(TDMAdjunto, DMAdjunto);
        try
           for i := 0 to Ficheros.Count - 1 do
              DMAdjunto.CreaAdjunto('CON', CrmDMContactos.QMContactosID_CONTACTO.AsInteger, Ficheros[i]);
        finally
           CierraData(DMAdjunto);
        end;

        AAdjuntoContacto.Execute;
     end;
  finally
     RecibeFicheros.Free;
     Ficheros.Free;
  end;
  Msg.Result := 0;
end;

procedure TCrmFMContactos.FiltraVentas;
var
  TipoDocumento, Serie : string;
begin
  inherited;
  if (PCMain.ActivePage = TSVentas) then
  begin
     CBPendientes.Visible := ((CBTipoDocumento.Text = 'OFC') or (CBTipoDocumento.Text = 'PEC') or (CBTipoDocumento.Text = 'ALB'));

     if (CBSerieVenta.Text = _('Todas las Series')) then
        Serie := ' '
     else
     begin
        // Obtengo el texto del item y no de la propiedad Text, por si escribieron y no conicide (mayúsculas/minúsculas, por ejemplo)
        Serie := CBSerieVenta.Items[CBSerieVenta.ItemIndex];
        Serie := Copy(Serie, 1, Pos(' ', Serie) - 1);
     end;

     TipoDocumento := CBTipoDocumento.Text;
     if (CBTipoDocumento.ItemIndex <= 0) then
        TipoDocumento := 'ALL';
     CrmDMContactos.FiltraVentas(TipoDocumento, Serie, DEFechaVentasDesde.Date, DEFechaVentasHasta.Date, EFArticuloVentas.Text, Trim(EDescripcion.Text), CBPendientes.Checked, CampoOrdenDetalleVentas);
  end;
end;

procedure TCrmFMContactos.FiltroVentasChange(Sender: TObject);
begin
  inherited;
  FiltraVentas;
end;

