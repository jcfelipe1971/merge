procedure TCrmFMContactos.NavAccionesDetClickBefore(Sender: TObject; Button: TNavigateBtn; var Continua: boolean);
var
  IdaccionDet : integer;
begin
  inherited;

  IdaccionDet := CrmDMContactos.QMAccionesDetID_ACCION_DET.AsInteger;

  if (Button = nbEdit) then
  begin
     CrmDMContactos.ObrirSeguiment('E');
     Continua := False;
  end;
  if (Button = nbInsert) then
  begin
     CrmDMContactos.ObrirSeguiment('I');
     Continua := False;
  end;

  Posicionar(CrmDMContactos.QMAccionesDet, 'ID_ACCION_DET', IdaccionDet, False, True);
end;

