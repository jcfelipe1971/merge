procedure TCrmFMContactos.ACrearClienteExecute(Sender: TObject);
var
  UltimoCliente : integer;
  FormaPago : string;
  Tercero : integer;
begin
  inherited;
  { TODO : Pasar todo este codigo a CrmDMContactos, que es donde pertenece }
  if (CrmDMContactos.QMContactosTERCERO.AsInteger > 0) then
  begin
     // sfg.albert - Si el cliente existe, no hacer nada, porqué daria error de duplicidad
     if (not CrmDMContactos.ExisteCliente) then
     begin
        if (StrToIntDef(CrmDMContactos.QMContactosCLI_PROV_IMP.AsString, 0) <> 0) then
        begin
           UltimoCliente := CrmDMContactos.QMContactosCLI_PROV_IMP.AsInteger;
           FormaPago := Trim(CrmDMContactos.QMContactosFORMA_DE_PAGO_IMP.AsString);
        end
        else
        begin
           UltimoCliente := DMMain.Contador_E('XCL');
           FormaPago := '';
        end;

        CRMDMContactos.CrearCliente(UltimoCliente,
           CrmDMContactos.QMContactosTERCERO.AsInteger,
           CrmDMContactos.QMContactosAGENTE.AsInteger,
           FormaPago);

        // Es busca l'últim número de cliente d'aquest tercer
        with THYFIBQuery.Create(nil) do
        begin
           try
              Close;
              DataBase := DMMain.DataBase;
              SQL.Text := 'SELECT MAX(CLIENTE) FROM VER_CLIENTES WHERE EMPRESA = :EMPRESA AND EJERCICIO = :EJERCICIO AND CANAL = :CANAL AND TERCERO = :TERCERO';
              Params.ByName['EMPRESA'].AsInteger := REntorno.Empresa;
              Params.ByName['EJERCICIO'].AsInteger := REntorno.Ejercicio;
              Params.ByName['CANAL'].AsInteger := REntorno.Canal;
              Params.ByName['TERCERO'].AsInteger := CrmDMContactos.QMContactosTERCERO.AsInteger;
              ExecQuery;
              UltimoCliente := FieldByName['MAX'].AsInteger;
              FreeHandle;
           finally
              Free;
           end;
        end;

        // S'assigna aquest cliente al contacte
        with THYFIBQuery.Create(nil) do
        begin
           try
              Close;
              DataBase := DMMain.DataBase;
              SQL.Text := 'UPDATE CRM_CONTACTOS SET CLIENTE = :CLIENTE, ZONA = :ZONA WHERE ID_CONTACTO = :ID_CONTACTO';
              Params.ByName['CLIENTE'].AsInteger := UltimoCliente;
              Params.ByName['ID_CONTACTO'].AsInteger := CrmDMContactos.QMContactosID_CONTACTO.AsInteger;
              Params.ByName['ZONA'].AsString := CrmDMContactos.QMContactosZONA.AsString;
              ExecQuery;
              FreeHandle;
           finally
              Free;
           end;
        end;
     end // fi not ExisteCliente
     else
     begin
        with CrmDMContactos do
        begin
           // Busco el tercero al que pertenece el cliente imp.
           with THYFIBQuery.Create(nil) do
           begin
              try
                 Close;
                 DataBase := DMMain.DataBase;
                 SQL.Add(' SELECT FIRST (1) TERCERO ');
                 SQL.Add(' FROM VER_CLIENTES ');
                 SQL.Add(' WHERE ');
                 SQL.Add(' EMPRESA = :EMPRESA AND ');
                 SQL.Add(' EJERCICIO = :EJERCICIO AND ');
                 SQL.Add(' CANAL = :CANAL AND ');
                 SQL.Add(' CLIENTE = :CLI_PROV_IMP ');
                 SQL.Add(' ORDER BY CLIENTE DESC ');
                 Params.ByName['EMPRESA'].AsInteger := REntorno.Empresa;
                 Params.ByName['EJERCICIO'].AsInteger := REntorno.Ejercicio;
                 Params.ByName['CANAL'].AsInteger := REntorno.Canal;
                 Params.ByName['CLI_PROV_IMP'].AsInteger := StrToIntDef(QMContactosCLI_PROV_IMP.AsString, 0);
                 ExecQuery;
                 Tercero := FieldByName['TERCERO'].AsInteger;
                 FreeHandle;
              finally
                 Free;
              end;
           end;

           // Pongo el tercero y el cliente en este contacto crm
           with THYFIBQuery.Create(nil) do
           begin
              try
                 Close;
                 DataBase := DMMain.DataBase;
                 SQL.Text := 'UPDATE CRM_CONTACTOS SET TERCERO = :TERCERO, CLIENTE = :CLIENTE WHERE ID_CONTACTO = :ID_CONTACTO';
                 Params.ByName['TERCERO'].AsInteger := Tercero;
                 Params.ByName['CLIENTE'].AsInteger := StrToIntDef(QMContactosCLI_PROV_IMP.AsString, 0);
                 Params.ByName['ID_CONTACTO'].AsInteger := QMContactosID_CONTACTO.AsInteger;
                 ExecQuery;
                 FreeHandle;
              finally
                 Free;
              end;
           end;
        end;
     end;

     CrmDMContactos.QMContactos.Refresh;
  end
  else
  begin
     if (CrmDMContactos.QMContactosCLIENTE.AsInteger = 0) then
        ShowMessage(_('El tercero aún no ha sido creado.'));
  end;
end;

