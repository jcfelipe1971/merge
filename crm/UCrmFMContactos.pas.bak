procedure TCrmFMContactos.HabilitaEnlaces;
begin
  if (FMain.ATerceros.Enabled = False) or (DBEFTercero.Text = '') then
  begin
     SBATercero.Width := 0;
     MIVerDatosTercero.Visible := False;
     DBETituloTercero.Color := clInfoBk;
     // TbuttComp.Visible := False;
     // TSepTerc.Visible := False;
  end
  else
  begin
     SolapaControles(SBATercero, DBETituloTercero);
     DBETituloTercero.Color := REntorno.ColorEnlaceActivo;
     // TbuttComp.Visible := True;
     // TSepTerc.Visible := True;
  end;

  if (FMain.AClientes.Enabled = False) or (DBEClienteEmp.Text = '') then
  begin
     SBACliente.Width := 0;
     MIVerDatosCliente.Visible := False;
     DBEDescClienteEmp.Color := clInfoBk;
  end
  else
  begin
     SolapaControles(SBACliente, DBEDescClienteEmp);
     DBEDescClienteEmp.Color := REntorno.ColorEnlaceActivo;
  end;

  if (FMain.AAgentes.Enabled = False) or (DBEAgenteEmp.Text = '') then
  begin
     SBAAgente.Width := 0;
     MIVerDatosAgente.Visible := False;
     DBEDescAgenteEmp.Color := clInfoBk;
  end
  else
  begin
     SolapaControles(SBAAgente, DBEDescAgenteEmp);
     DBEDescAgenteEmp.Color := REntorno.ColorEnlaceActivo;
  end;

  MISepEnlaces.Visible := MIVerDatosTercero.Visible or
     MIVerDatosCliente.Visible or
     MIVerDatosAgente.Visible;

  // Solo permito crear oferta si no hay una asociada
  VisibilidadBotonOferta((CrmDMContactos.QMAccionesDOC_ACCION.AsInteger = 0));

  if (CrmDMContactos.QMContactosCLIENTE.AsInteger = 0) or (CrmDMContactos.QMContactosCLIENTE.AsInteger = -1) then
     AAsociarCliente.Enabled := True
  else
     AAsociarCliente.Enabled := False;

  if (CrmDMContactos.QMContactosTERCERO.AsInteger = 0) or (CrmDMContactos.QMContactosTERCERO.AsInteger = -1) then
     ANuevoTercero.Enabled := True
  else
     ANuevoTercero.Enabled := False;

  if (((CrmDMContactos.QMContactosTERCERO.AsInteger = 0) or (CrmDMContactos.QMContactosTERCERO.AsInteger = -1)) and
     ((CrmDMContactos.QMContactosCLIENTE.AsInteger = 0) or (CrmDMContactos.QMContactosCLIENTE.AsInteger = -1))) then
     ATerceroCliente.Enabled := True
  else
     ATerceroCliente.Enabled := False;
end;

