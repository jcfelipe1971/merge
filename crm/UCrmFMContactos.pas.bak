procedure TCrmFMContactos.FiltroContactos(Filtro: string; AgenteFiltro: integer = -1; IdAccion: integer = -1; IdAccionDet: integer = -1);
begin
  if (AgenteFiltro <> -1) then
     EFAgenteFiltro.Text := IntToStr(AgenteFiltro);

  CrmDMContactos.FiltroContactos(Filtro);

  if (IdAccion <> -1) then
     PCMain.ActivePage := TSAcciones;

  PCMainChange(nil);

  if (IdAccion <> -1) then
     PCAcciones.ActivePage := TSFichaAcciones;

  if (IdAccion <> -1) then
     Posicionar(CrmDMContactos.QMAcciones, 'ID_ACCION', IdAccion);

  if (IdAccionDet <> -1) then
     Posicionar(CrmDMContactos.QMAccionesDet, 'ID_ACCION_DET', IdAccionDet);
end;

procedure TCrmFMContactos.DBEAgenteEmpChange(Sender: TObject);
var
  i : integer;
begin
  inherited;
  DBEDescAgenteEmp.Text := DameTituloAgente(StrToIntDef(DBEAgenteEmp.Text, 0));
  RellenaRutasAgentes(StrToIntDef(DBEAgenteEmp.Text, 0), DBCBRuta.Items, False, True);
  DBCBRuta.Values.Clear;
  for i := 0 to DBCBRuta.Items.Count - 1 do
     DBCBRuta.Values.Add(IntToStr(integer(DBCBRuta.Items.Objects[i])));
end;

