procedure TCrmFMContactos.ACrearOfertaExecute(Sender: TObject);
var
  Serie : string;
  IdAgente : integer;
begin
  inherited;
  if (CRMDMcontactos.QMAcciones.State in [dsEdit, dsInsert]) then
     CRMDMcontactos.QMAcciones.Post;

  Serie := REntorno.Serie;
  if PideDato('SER', Serie, _('Serie para documento')) then
  begin
     // Obtenemos de forma segura el ID del agente asignado a la acción del CRM
     IdAgente := CrmDMContactos.QMAcciones.FieldByName('AGENTE').AsInteger;

     FMain.EjecutaAccion(FMain.AOfertas);

     // Pasamos el IdAgente como nuevo parámetro
     FMOfertas.CrearOfertaCrm(CrmDMContactos.QMAccionesID_ACCION.AsInteger,
        CrmDMContactos.QMContactosID_CONTACTO.AsInteger,
        CrmDMContactos.QMContactosCLIENTE.AsInteger,
        IdAgente,
        Serie);

     CrmDMContactos.RefrescarAcciones;
  end;
end;


